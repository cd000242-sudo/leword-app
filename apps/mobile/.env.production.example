# LEWORD Mobile production example.
# Copy these values into EAS environment variables or the release shell.

# Public HTTPS LEWORD API. Production builds must not use localhost or 127.0.0.1.
EXPO_PUBLIC_LEWORD_API_URL=https://api.leword.app

# EAS project id is required for real-device Expo push tokens.
EXPO_PUBLIC_EAS_PROJECT_ID=

# Store compliance and in-app footer link.
EXPO_PUBLIC_LEWORD_PRIVACY_URL=https://leword.app/privacy

# EAS submit credentials. Keep real secrets in the release machine or EAS secrets.
GOOGLE_APPLICATION_CREDENTIALS=apps/mobile/credentials/google-play-service-account.json
EXPO_APPLE_ID=
EXPO_APPLE_APP_SPECIFIC_PASSWORD=
EXPO_ASC_APP_ID=
EXPO_APPLE_TEAM_ID=
EXPO_ASC_API_KEY_P8_B64=
EXPO_ASC_API_KEY_ISSUER_ID=
EXPO_ASC_API_KEY_ID=
