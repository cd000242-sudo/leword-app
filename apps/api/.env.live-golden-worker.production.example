# Dedicated production environment for leword-live-golden-worker only.
# Copy this to .env.live-golden-worker.production on the server and keep it
# outside source control. Do not add web-session, mobile bearer, commerce,
# analytics, mail, or payment credentials to this file.

# Naver Open API: broad document-count measurement.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Naver SearchAd: exact PC/mobile search-volume measurement.
NAVER_SEARCH_AD_ACCESS_LICENSE=
NAVER_SEARCH_AD_SECRET_KEY=
NAVER_SEARCH_AD_CUSTOMER_ID=

# Optional additional SearchAd accounts live in /searchad/searchad-accounts.json,
# a dedicated read-only credential volume for the API and measurement worker.
