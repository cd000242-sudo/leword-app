# LEWORD Mobile API production example.
# Copy the names into the real production secret manager. Do not commit real values.

# Optional single admin/staging bearer token. Production should prefer the entitlement URL.
LEWORD_MOBILE_API_TOKEN=

# Production account/license entitlement service. Required for public mobile exposure.
LEWORD_MOBILE_ENTITLEMENT_URL=https://api.leword.app/mobile/entitlement
LEWORD_MOBILE_PANEL_LOGIN_URL=https://script.google.com/macros/s/AKfycbxBOGkjVj4p-6XZ4SEFYKhW3FBmo5gt7Fv6djWhB1TljnDDmx_qlfZ4YdlJNohzIZ8NJw/exec

# Server-side cache and prewarm. Required so mobile users receive fast PC-grade results.
LEWORD_MOBILE_CACHE_FILE=C:\leword\mobile-cache.json
LEWORD_MOBILE_PREWARM_INTERVAL_MINUTES=15
LEWORD_MOBILE_PREWARM_LIMIT=4
LEWORD_MOBILE_PREWARM_ON_START=false
LEWORD_MOBILE_LIVE_GOLDEN_ENABLED=true
LEWORD_MOBILE_LIVE_GOLDEN_ON_START=true
LEWORD_MOBILE_LIVE_GOLDEN_IGNORE_PREWARM=true
LEWORD_MOBILE_LIVE_GOLDEN_INTERVAL_MINUTES=2
LEWORD_MOBILE_LIVE_GOLDEN_LIMIT=15
LEWORD_MOBILE_LIVE_GOLDEN_MAX_SEEDS=1000
LEWORD_MOBILE_LIVE_GOLDEN_MAX_CANDIDATES=3600
LEWORD_MOBILE_LIVE_GOLDEN_BOARD_TARGET=60
LEWORD_MOBILE_LIVE_GOLDEN_BOARD_FILE=/data/live-golden-board.json
LEWORD_PUBLIC_GOLDEN_PREVIEW_COUNT=5

# Push delivery. Use either Expo direct delivery or a custom HTTPS gateway.
LEWORD_MOBILE_PUSH_PROVIDER=expo
LEWORD_MOBILE_PUSH_ENDPOINT=
LEWORD_MOBILE_PUSH_TOKEN=
LEWORD_MOBILE_PUSH_TIMEOUT_MS=5000

# Public mobile API guardrails. Tune upward only after worker capacity is proven.
LEWORD_MOBILE_MAX_BODY_BYTES=65536
LEWORD_MOBILE_RATE_LIMIT_PER_MINUTE=120

# Commerce, Toss Payments, and first-party analytics.
# Keep Toss secret keys only on the server. The client key is intentionally public.
LEWORD_COMMERCE_STORE_FILE=/data/leword-commerce-store.json
TOSS_PAYMENTS_CLIENT_KEY=
TOSS_PAYMENTS_SECRET_KEY=
LEWORD_ANALYTICS_EXCLUDED_IPS=

# Browser runtime for server-side SERP/browser work. The Docker image sets this automatically.
LEWORD_CHROME_PATH=/usr/bin/chromium

# Naver Open API. Required for measured document counts.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Naver SearchAd. Required for measured PC/mobile/total search volume and CPC.
NAVER_SEARCH_AD_ACCESS_LICENSE=
NAVER_SEARCH_AD_SECRET_KEY=
NAVER_SEARCH_AD_CUSTOMER_ID=
# Optional additional SearchAd accounts. Production compose reads a JSON array
# from /data/searchad-accounts.json in the private shared volume. Each object is
# {"accessLicense":"...","secretKey":"...","customerId":"..."}.
# Never commit that file or expose it through container environment variables.
