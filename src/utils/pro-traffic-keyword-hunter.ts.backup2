/**
 * 🔥 네이버 뉴스에서 최신 이슈 키워드 수집
 */
/**
 * 🔥🔥🔥🔥🔥 진짜 끝판왕 - 실시간 트렌드 기반 키워드 수집 🔥🔥🔥🔥🔥
 * 
 * 1. Signal.bz 실시간 검색어 (네이버 기반)
 * 2. Zum 실시간 검색어
 * 3. Daum 실시간 검색어
 * 4. Nate 실시간 검색어
 * 5. 네이버 뉴스 헤드라인
 * 6. 정책브리핑 (정부 정책)
 */
async function getMultiSourceKeywords(): Promise<string[]> {
  console.log('[PRO-TRAFFIC] 🔥🔥🔥 실시간 트렌드 수집 시작! 🔥🔥🔥');
  const allKeywords: string[] = [];
  
  // 🔥 실시간 검색어 4대장 + 뉴스 + 정책 (병렬 수집!)
  const results = await Promise.allSettled([
    // 🔥 실시간 검색어 (진짜 트렌드!)
    getSignalBzKeywords(20).then(r => r.map(k => k.keyword)),   // Signal.bz (네이버)
    getZumRealtimeKeywordsWithPuppeteer(20).then(r => r.map(k => k.keyword)),  // Zum
    getDaumRealtimeKeywordsWithPuppeteer(20).then(r => r.map(k => k.keyword)), // Daum
    getNateRealtimeKeywordsWithPuppeteer(20).then(r => r.map(k => k.keyword)), // Nate
    // 📰 뉴스 + 정책
    getNewsIssueKeywords(),           // 네이버 뉴스 헤드라인
    getPolicyBriefingKeywords(),      // 정책브리핑 (정부 정책)
    getSeasonalEventKeywords(),       // 시즌 키워드
  ]);
  
  let successCount = 0;
  const sourceNames = ['Signal.bz', 'Zum', 'Daum', 'Nate', '뉴스', '정책브리핑', '시즌'];
  
  for (let i = 0; i < results.length; i++) {
    const result = results[i];
    if (result.status === 'fulfilled' && result.value && result.value.length > 0) {
      console.log(`[PRO-TRAFFIC] ✅ ${sourceNames[i]}: ${result.value.length}개 수집`);
      allKeywords.push(...result.value.slice(0, 30)); // 각 소스당 30개
      successCount++;
    } else {
      console.log(`[PRO-TRAFFIC] ❌ ${sourceNames[i]}: 수집 실패`);
    }
  }
  
  console.log(`[PRO-TRAFFIC] 🔥 ${successCount}/${sourceNames.length}개 소스에서 총 ${allKeywords.length}개 실시간 키워드 수집!`);
  
  // 중복 제거 및 빈 문자열 제거
  const uniqueKeywords = [...new Set(allKeywords)].filter(k => k && k.length >= 2);
  console.log(`[PRO-TRAFFIC] 📊 중복 제거 후: ${uniqueKeywords.length}개`);
  
  return uniqueKeywords.slice(0, 100); // 최대 100개
}

/**
 * 📝 네이버 블로그 인기글에서 키워드 추출
 */
async function getNaverBlogPopularKeywords(): Promise<string[]> {
  const keywords: string[] = [];
  
  try {
    const axios = (await import('axios')).default;
    const cheerio = await import('cheerio');
    
    // 네이버 블로그 주제별 인기글
    const topics = [
      'https://section.blog.naver.com/ThemePost.naver?directoryNo=11', // 경제/비즈니스
      'https://section.blog.naver.com/ThemePost.naver?directoryNo=4',  // 여행
      'https://section.blog.naver.com/ThemePost.naver?directoryNo=5',  // IT/컴퓨터
    ];
    
    for (const url of topics) {
      try {
        const response = await axios.get(url, {
          headers: { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36' },
          timeout: 5000
        });
        
        const $ = cheerio.load(response.data);
        $('.title, .desc, .tit').each((_, el) => {
          const text = $(el).text().trim();
          if (text.length > 3 && text.length < 40) {
            // 핵심 명사 추출
            const words = text.split(/[\s\|\-\[\]()\/]+/).filter(w => w.length > 1 && w.length < 15);
            keywords.push(...words);
          }
        });
      } catch { /* 개별 실패 무시 */ }
    }
    
    console.log(`[PRO-TRAFFIC] 📝 블로그 인기글 ${keywords.length}개`);
  } catch { /* 무시 */ }
  
  return [...new Set(keywords)].slice(0, 100);
}

