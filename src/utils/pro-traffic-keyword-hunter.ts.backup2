    ],
    'life': ['청소', '정리', '인테리어', '수납', '살림꿀팁', '자취'],
    'travel': ['여행지', '숙소', '맛집', '카페', '드라이브', '당일치기'],
    'food': ['레시피', '맛집', '카페', '디저트', '밀키트', '간편식'],
    'tech': ['앱추천', '꿀팁', '설정', '아이폰', '갤럭시', '노트북'],
    'beauty': ['화장품', '스킨케어', '메이크업', '헤어', '네일'],
