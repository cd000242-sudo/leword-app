// 📁 카테고리별 황금키워드 가져오기
function getCategoryGoldenKeywords(category: string): string[] {
  const baseKeywords = CATEGORY_GOLDEN_KEYWORDS[category] || CATEGORY_GOLDEN_KEYWORDS['all'];
  const allKeywords = CATEGORY_GOLDEN_KEYWORDS['all'];
  
  // 카테고리 키워드 + 기본 키워드 조합
  const combined: string[] = [];
  
  baseKeywords.forEach(base => {
    combined.push(base);
    // 질문형 패턴 조합
    QUESTION_PATTERNS.slice(0, 5).forEach(pattern => {
      combined.push(`${base} ${pattern}`);
    });
  });
  
  return combined;
}

/**
 * 🏆 PRO 트래픽 키워드 헌팅 - 20년차 블로거도 탐내는 황금키워드 발굴!
 * 
 * 🎯 핵심 전략:
 * 1. 실시간 검색어가 아닌, 틈새 수익화 키워드 발굴
 * 2. 검색량 500~5000 + 문서수 1000 이하 = 블루오션
 * 3. 구매의도 키워드 ("~추천", "~비교", "~가격", "~후기")
 * 4. 네이버 검색광고 API 연관키워드 활용
 * 5. 실제 API로 황금비율 검증
 */
export async function huntProTrafficKeywords(options: {
  mode?: 'realtime' | 'category' | 'season'; // 🎯 분석 모드
  seedKeywords?: string[];
  category?: string;
  targetRookie?: boolean;
  includeSeasonKeywords?: boolean;
  count?: number;
  forceRefresh?: boolean; // 🔥 강제 새로고침 옵션 추가
}): Promise<ProTrafficHuntResult> {
  const {
    mode = 'realtime', // 🎯 기본: 실시간 이슈
    seedKeywords = [],
    category = 'all',
    targetRookie = true,
    includeSeasonKeywords = true,
    count = 20,
    forceRefresh = true // 기본적으로 새로고침 시 캐시 초기화
  } = options;
  
  const modeLabels: Record<string, string> = {
    'realtime': '🔥 실시간 이슈',
    'category': '📁 카테고리별 황금키워드',
    'season': '📅 시즌별/월별 황금키워드'
  };
  console.log(`[PRO-TRAFFIC] 🏆 PRO 황금키워드 헌팅 시작 - ${modeLabels[mode] || mode}`);
  
  // 🔥 새로고침 시 캐시 초기화 (매번 새로운 결과!)
  if (forceRefresh) {
    apiCache.clear();
    console.log('[PRO-TRAFFIC] 🗑️ 캐시 초기화 완료 - 새로운 키워드 발굴 시작!');
  }
  
  const results: ProTrafficKeyword[] = [];
  const currentMonth = new Date().getMonth() + 1;
  const currentHour = new Date().getHours();
  
  let allSeedKeywords: string[] = [...seedKeywords];
  
  // 🎯 모드별 시드 키워드 수집
  if (mode === 'season') {
    // 📅 시즌별/월별 황금키워드 모드
    console.log('[PRO-TRAFFIC] 📅 시즌별/월별 황금키워드 모드 활성화');
    const monthlyKeywords = getMonthlyGoldenKeywords(currentMonth);
    const upcomingKeywords = getUpcomingSeasonKeywords(currentMonth);
    allSeedKeywords = [...allSeedKeywords, ...shuffleArray(monthlyKeywords), ...shuffleArray(upcomingKeywords)];
    console.log(`[PRO-TRAFFIC] 📅 시즌 키워드 ${monthlyKeywords.length + upcomingKeywords.length}개 로드`);
    
  } else if (mode === 'category') {
    // 📁 카테고리별 황금키워드 모드
    console.log('[PRO-TRAFFIC] 📁 카테고리별 황금키워드 모드 활성화');
    const categoryKeywords = getCategoryGoldenKeywords(category);
    allSeedKeywords = [...allSeedKeywords, ...shuffleArray(categoryKeywords)];
    console.log(`[PRO-TRAFFIC] 📁 카테고리 키워드 ${categoryKeywords.length}개 로드`);
    
  } else {
    // 🔥 실시간 이슈 모드 (기본)
    console.log('[PRO-TRAFFIC] 🔥 실시간 이슈 모드 활성화');
    
    // 🎯 1단계: 수익화 가능한 시드 키워드 수집 (정부 정책 + 이슈)
    const profitableSeeds = getProfitableSeedKeywords(category, currentMonth);
    allSeedKeywords = [...allSeedKeywords, ...profitableSeeds];
    
    // 시즌 키워드 추가 (정부 지원 + 이슈)
    if (includeSeasonKeywords) {
      const seasonKeywords = getProfitableSeasonKeywords(currentMonth);
      allSeedKeywords = [...allSeedKeywords, ...seasonKeywords];
    }
    
    // 🔥 시드 키워드 셔플 (매번 다른 순서로 탐색 → 다른 결과!)
    allSeedKeywords = shuffleArray(allSeedKeywords);
    
    // 🔥🔥🔥 다중 소스에서 키워드 수집 (끝판왕!) 🔥🔥🔥
    try {
      console.log('[PRO-TRAFFIC] 🌐 다중 소스 키워드 수집 시작...');
      const multiSourceKeywords = await getMultiSourceKeywords();
      if (multiSourceKeywords.length > 0) {
        console.log(`[PRO-TRAFFIC] 🌐 다중 소스 ${multiSourceKeywords.length}개 수집!`);
        // 🔥 다중 소스 키워드도 셔플!
        allSeedKeywords = [...allSeedKeywords, ...shuffleArray(multiSourceKeywords)];
      }
    } catch (error) {
      console.warn('[PRO-TRAFFIC] 다중 소스 수집 부분 실패, 기본 시드로 진행');
    }
  }
  
  // 🔥 중복 제거 후 다시 셔플 (매번 다른 조합!)
  allSeedKeywords = shuffleArray([...new Set(allSeedKeywords)]).slice(0, 50); // 🚀 시드 50개 (속도 최적화)
  console.log(`[PRO-TRAFFIC] 📊 시드 키워드 ${allSeedKeywords.length}개: ${allSeedKeywords.slice(0, 5).join(', ')}...`);
  
  // 🎯 2단계: 네이버 검색광고 API로 연관 키워드 수집 + 검색량 조회
  const allKeywords: { keyword: string; source: string; searchVolume?: number; documentCount?: number }[] = [];
  
  try {
    const { loadEnvFromFile } = await import('../env');
    const env = loadEnvFromFile() as any;
    
    const accessLicense = env.naverSearchAdAccessLicense || env.NAVER_SEARCHAD_ACCESS_LICENSE;
    const secretKey = env.naverSearchAdSecretKey || env.NAVER_SEARCHAD_SECRET_KEY;
    const customerId = env.naverSearchAdCustomerId || env.NAVER_SEARCHAD_CUSTOMER_ID;
    
    if (accessLicense && secretKey && customerId) {
      console.log('[PRO-TRAFFIC] 🔥 네이버 검색광고 API로 연관키워드 수집...');
      
      const config: NaverSearchAdConfig = { accessLicense, secretKey, customerId };
      
      // 🚀 병렬로 연관 키워드 수집 (시드 30개에서 각 50개씩 - 속도 최적화!)
      const suggestionPromises = allSeedKeywords.slice(0, 30).map(async (seed) => {
        try {
          const suggestions = await getNaverSearchAdKeywordSuggestions(config, seed, 50); // 각 시드당 50개
          
          return suggestions.map(s => ({
            keyword: s.keyword,
            source: seed,
            searchVolume: s.totalSearchVolume || ((s.monthlyPcQcCnt || 0) + (s.monthlyMobileQcCnt || 0)),
            documentCount: 0 // 나중에 조회
          }));
        } catch {
          return [];
        }
      });
      
      const suggestionResults = await Promise.all(suggestionPromises);
      for (const result of suggestionResults) {
        allKeywords.push(...result);
      }
      
      console.log(`[PRO-TRAFFIC] ✅ 검색광고 API에서 ${allKeywords.length}개 연관 키워드 수집`);
    }
  } catch (error) {
    console.warn('[PRO-TRAFFIC] 검색광고 API 실패, 자동완성으로 폴백');
  }
  
  // 🚀 3단계: 자동완성 API로 추가 키워드 수집 (검색광고 결과 부족 시)
  if (allKeywords.length < 50) {
    console.log('[PRO-TRAFFIC] 🔍 네이버 자동완성으로 추가 키워드 수집...');
    
    // 🚀 20개 시드만 확장 (속도 최적화)
    const expandPromises = allSeedKeywords.slice(0, 20).map(async (seed) => {
      const expanded = await expandToLongtailReal(seed);
      return expanded.slice(0, 10).map(kw => ({ keyword: kw, source: seed })); // 각 10개만
    });
    
    const expandResults = await Promise.all(expandPromises);
    for (const result of expandResults) {
      for (const item of result) {
        if (!allKeywords.some(k => k.keyword === item.keyword)) {
          allKeywords.push({ ...item, searchVolume: 0, documentCount: 0 });
        }
      }
    }
  }
  
  // 🎯 4단계: 수익화 의도 키워드 필터링 (핵심!)
  // PRO는 월 10억+ 초고수 키워드만, Lite는 월 200만+ 고수 키워드
  const isPro = category === 'pro_premium' || category === 'all';
  
  const profitableKeywords = allKeywords.filter(k => {
    const kw = k.keyword;
    if (!kw || kw.length < 4) return false;
    if (isDangerKeyword(kw)) return false;
    
    // 🚫 PRO에서는 저가치 키워드 제외! (Lite용 키워드는 PRO에서 안나옴)
    if (isPro && LOW_VALUE_KEYWORDS_FOR_PRO.some(lv => kw.includes(lv))) {
      return false;
    }
    
    // 수익화 의도 키워드 우선
    const hasProfitIntent = PROFIT_INTENT_PATTERNS.some(p => kw.includes(p));
    
    // 롱테일 키워드 (2단어 이상)
    const isLongtail = kw.split(' ').length >= 2 || kw.length >= 6;
    
    // 검색량이 있는 경우 500~10000 범위 필터
    if (k.searchVolume && k.searchVolume > 0) {
      return k.searchVolume >= 100 && k.searchVolume <= 50000 && (hasProfitIntent || isLongtail);
    }
    
    return hasProfitIntent || isLongtail;
  });
  
  console.log(`[PRO-TRAFFIC] 🎯 수익화 의도 키워드 ${profitableKeywords.length}개 필터링`);
  
  // 🚀 중복 제거 (최대 300개 분석 - 속도 최적화!)
  const uniqueKeywords = [...new Map(profitableKeywords.map(k => [k.keyword, k])).values()].slice(0, 300);
  
  // 🎯 5단계: API 데이터 보강 (검색량/문서수)
  await fetchKeywordDataBatch(uniqueKeywords.map(k => k.keyword));
  console.log(`[PRO-TRAFFIC] ✅ ${uniqueKeywords.length}개 키워드 데이터 준비 완료`);
  
  // 🎯 6단계: 각 키워드 분석 및 황금비율 계산
  for (const { keyword, source } of uniqueKeywords) {
    // ⚠️ 캐시 조회: 원본 키워드와 clean 키워드 모두 확인
    const cleanKeyword = keyword.replace(/\s/g, '');
    const cached = apiCache.get(keyword) || apiCache.get(cleanKeyword);
    // ⚠️ 캐시된 실제 API 값을 우선 사용! (수집 단계 값은 부정확할 수 있음)
    const finalSearchVolume = cached?.searchVolume || 0;
    const finalDocCount = cached?.documentCount || 0;
    
    // 황금비율 계산 (핵심!) - 검색량 / 문서수 = 높을수록 좋음!
    const goldenRatio = finalDocCount > 0 ? finalSearchVolume / finalDocCount : (finalSearchVolume > 0 ? 999 : 0);
    
    // 🚨 핵심 필터링: 황금비율이 너무 낮으면 무조건 제외!
    // 황금비율 0.5 미만 = 문서수가 검색량의 2배 이상 = 경쟁 치열
    if (goldenRatio < 0.5 && finalDocCount > 0) {
      console.log(`[PRO-TRAFFIC] ❌ 황금비율 부족으로 제외: "${keyword}" (검색량=${finalSearchVolume}, 문서수=${finalDocCount}, 비율=${goldenRatio.toFixed(2)})`);
      continue;
    }
    
    // 🚨 문서수가 검색량보다 훨씬 많으면 제외 (경쟁 치열)
    if (finalDocCount > finalSearchVolume * 2 && finalDocCount > 1000) {
      console.log(`[PRO-TRAFFIC] ❌ 문서수 과다로 제외: "${keyword}" (검색량=${finalSearchVolume}, 문서수=${finalDocCount})`);
      continue;
    }
    
    // 🏆 블루오션 조건: 검색량 100+ AND 문서수 5000 이하 AND 황금비율 1.0+
    const isBlueOcean = finalSearchVolume >= 100 && finalDocCount <= 5000 && goldenRatio >= 1.0;
    
    // 검색량 50 미만은 스킵
    if (finalSearchVolume < 50) continue;
    
    const analysis = analyzeKeyword(keyword, source, currentMonth, currentHour, targetRookie);
    
    // 보너스 점수: 수익화 의도 키워드
    if (PROFIT_INTENT_PATTERNS.some(p => keyword.includes(p))) {
      analysis.totalScore += 15;
    }
    
    // 보너스 점수: 블루오션
    if (isBlueOcean) {
      analysis.totalScore += 20;
      analysis.blueOcean.score += 30;
    }
    
    if (analysis.totalScore >= 40) {
      results.push(analysis);
    }
  }
  
  // 🎯 7단계: 정렬 (황금비율 + 블루오션 + 수익화 의도)
  const sortedResults = results
    .sort((a, b) => {
      // 1순위: 블루오션 점수
      const blueOceanDiff = b.blueOcean.score - a.blueOcean.score;
      if (Math.abs(blueOceanDiff) > 20) return blueOceanDiff;
      
      // 2순위: 황금비율
      const ratioDiff = b.goldenRatio - a.goldenRatio;
      if (Math.abs(ratioDiff) > 0.5) return ratioDiff > 0 ? 1 : -1;
      
      // 3순위: 신생 적합도
      if (targetRookie) {
        const rookieDiff = b.rookieFriendly.score - a.rookieFriendly.score;
        if (Math.abs(rookieDiff) > 15) return rookieDiff;
      }
      
      // 4순위: 종합 점수
      return b.totalScore - a.totalScore;
    })
    .slice(0, count * 3); // 3배수 후보 확보
  
  // 🔥🔥🔥 8단계: 최종 결과 키워드 실제 API 검증 (끝판왕 핵심!) 🔥🔥🔥
  console.log(`[PRO-TRAFFIC] 🔍🔍🔍 최종 ${sortedResults.length}개 키워드 실제 API 검증 시작...`);
  
  const verifiedResults: ProTrafficKeyword[] = [];
  
  // 환경 설정 로드
  const { EnvironmentManager } = await import('./environment-manager');
  const env = EnvironmentManager.getInstance().getConfig();
  
  if (env.naverClientId && env.naverClientSecret && env.naverSearchAdAccessLicense) {
    const axios = (await import('axios')).default;
    const crypto = await import('crypto');
    
    // 🔥 API 호출 헬퍼 함수 (재시도 로직 포함 - 절대 실패 안함!)
    const MAX_RETRIES = 3;
    const RETRY_DELAY = 500; // 500ms
    const API_TIMEOUT = 15000; // 15초 타임아웃
    
    async function callBlogApi(keyword: string, retries = MAX_RETRIES): Promise<number | null> {
      for (let attempt = 1; attempt <= retries; attempt++) {
        try {
          const res = await axios.get('https://openapi.naver.com/v1/search/blog.json', {
            params: { query: keyword, display: 1 },
            headers: {
              'X-Naver-Client-Id': env.naverClientId,
              'X-Naver-Client-Secret': env.naverClientSecret
            },
            timeout: API_TIMEOUT
          });
          if (res.data.total !== undefined) {
            return res.data.total;
          }
        } catch (e: any) {
          const isRateLimit = e.response?.status === 429;
          const isTimeout = e.code === 'ECONNABORTED' || e.code === 'ETIMEDOUT';
          
          if (attempt < retries) {
            const delay = isRateLimit ? RETRY_DELAY * 3 : (isTimeout ? RETRY_DELAY * 2 : RETRY_DELAY);
            console.log(`[PRO-TRAFFIC] 🔄 블로그 API 재시도 ${attempt}/${retries} (${keyword}) - ${delay}ms 대기`);
            await new Promise(r => setTimeout(r, delay));
          }
        }
      }
      return null;
    }
    
    async function callSearchAdApi(keyword: string, retries = MAX_RETRIES): Promise<number | null> {
      for (let attempt = 1; attempt <= retries; attempt++) {
        try {
          const timestamp = Date.now().toString();
          const signature = crypto.createHmac('sha256', env.naverSearchAdSecretKey)
            .update(timestamp + '.GET./keywordstool')
            .digest('base64');
          
          const res = await axios.get('https://api.searchad.naver.com/keywordstool', {
            params: { hintKeywords: keyword, showDetail: '1' },
            headers: {
              'X-Timestamp': timestamp,
              'X-API-KEY': env.naverSearchAdAccessLicense,
              'X-Customer': env.naverSearchAdCustomerId,
              'X-Signature': signature
            },
            timeout: API_TIMEOUT
          });
          
          const vol = res.data.keywordList?.[0];
          if (vol) {
            const pcRaw = vol.monthlyPcQcCnt;
            const mobileRaw = vol.monthlyMobileQcCnt;
            const pc = (typeof pcRaw === 'string' && pcRaw.includes('10')) ? 5 : (typeof pcRaw === 'number' ? pcRaw : 0);
            const mobile = (typeof mobileRaw === 'string' && mobileRaw.includes('10')) ? 5 : (typeof mobileRaw === 'number' ? mobileRaw : 0);
            return pc + mobile;
          }
          return 0;
        } catch (e: any) {
          const isRateLimit = e.response?.status === 429;
          const isTimeout = e.code === 'ECONNABORTED' || e.code === 'ETIMEDOUT';
          
          if (attempt < retries) {
            const delay = isRateLimit ? RETRY_DELAY * 3 : (isTimeout ? RETRY_DELAY * 2 : RETRY_DELAY);
            console.log(`[PRO-TRAFFIC] 🔄 검색광고 API 재시도 ${attempt}/${retries} (${keyword}) - ${delay}ms 대기`);
            await new Promise(r => setTimeout(r, delay));
          }
        }
      }
      return null;
    }
    
    // 순차 처리 (안정성 + 정확성 우선)
    for (const result of sortedResults) {
      // 키워드 전처리: 특수문자 제거, 숫자는 유지
      const cleanKeyword = result.keyword
        .replace(/\s/g, '')           // 띄어쓰기 제거
        .replace(/[^\w가-힣0-9]/g, '') // 특수문자 제거 (한글, 영문, 숫자만)
        .trim();
      
      if (cleanKeyword.length < 2) continue; // 너무 짧은 키워드 스킵
      
      // 🔥 기존 수집 데이터 우선 활용 (API 실패 시 fallback)
      let realDocCount = result.documentCount || 0;
      let realSearchVolume = result.searchVolume || 0;
      let apiSuccess = false;
      
      // 1. 블로그 API 호출 (재시도 포함)
      const blogResult = await callBlogApi(cleanKeyword);
      if (blogResult !== null) {
        realDocCount = blogResult;
        apiSuccess = true;
      } else {
        console.log(`[PRO-TRAFFIC] ⚠️ ${result.keyword}: 블로그 API 3회 실패, 기존 데이터 사용 (${realDocCount})`);
      }
      
      // API 호출 간 딜레이 (Rate Limit 방지)
      await new Promise(r => setTimeout(r, 100));
      
      // 2. 검색광고 API 호출 (재시도 포함)
      const searchResult = await callSearchAdApi(cleanKeyword);
      if (searchResult !== null) {
        if (searchResult > 0) {
          realSearchVolume = searchResult;
        }
        apiSuccess = true;
      } else {
        console.log(`[PRO-TRAFFIC] ⚠️ ${result.keyword}: 검색광고 API 3회 실패, 기존 데이터 사용 (${realSearchVolume})`);
      }
      
      // 실제 데이터로 업데이트
      const realGoldenRatio = realDocCount > 0 ? realSearchVolume / realDocCount : (realSearchVolume > 0 ? 999 : 0);
      
      // 🚨🚨🚨 핵심 필터링: 황금비율이 낮으면 제외! 🚨🚨🚨
      // 황금비율 0.5 미만 = 문서수가 검색량의 2배 이상 = 경쟁 치열 = 황금키워드 아님!
      if (realGoldenRatio < 0.5 && realDocCount > 0) {
        console.log(`[PRO-TRAFFIC] ❌ 검증단계 - 황금비율 부족 제외: "${result.keyword}" (검색량=${realSearchVolume}, 문서수=${realDocCount}, 비율=${realGoldenRatio.toFixed(2)})`);
        continue;
      }
      
      // 문서수가 검색량보다 훨씬 많으면 제외 (경쟁 치열)
      if (realDocCount > realSearchVolume * 2 && realDocCount > 500) {
        console.log(`[PRO-TRAFFIC] ❌ 검증단계 - 문서수 과다 제외: "${result.keyword}" (검색량=${realSearchVolume}, 문서수=${realDocCount})`);
        continue;
      }
      
      // 데이터가 있는지 확인
      const hasData = realSearchVolume > 0 || realDocCount > 0 || result.searchVolume > 0 || result.documentCount > 0;
      
      // 블루오션 조건 (황금비율 기반)
      const isRealBlueOcean = realSearchVolume >= 50 && realDocCount <= 10000 && realGoldenRatio >= 1.0;
      const isLowCompetition = realGoldenRatio >= 0.5 && realDocCount <= 20000;
      
      if (hasData) {
        // 🏆 등급 재계산 (황금비율 기반!)
        let newGrade: 'SSS' | 'SS' | 'S' | 'A' | 'B' | 'C' = result.grade || 'B';
        
        // 실제 API 성공 시에만 등급 재계산
        if (apiSuccess) {
          // SSS: 황금비율 10+ (검색량이 문서수의 10배 이상) & 검색량 100+
          if (realGoldenRatio >= 10 && realSearchVolume >= 100) newGrade = 'SSS';
          // SS: 황금비율 5+ & 검색량 50+ & 문서수 5000 이하
          else if (realGoldenRatio >= 5 && realSearchVolume >= 50 && realDocCount <= 5000) newGrade = 'SS';
          // S: 황금비율 2+ & 검색량 30+ & 문서수 10000 이하
          else if (realGoldenRatio >= 2 && realSearchVolume >= 30 && realDocCount <= 10000) newGrade = 'S';
          // A: 황금비율 1+ & 문서수 20000 이하
          else if (realGoldenRatio >= 1 && realDocCount <= 20000) newGrade = 'A';
          // B: 황금비율 0.5+ (최소 기준)
          else if (realGoldenRatio >= 0.5) newGrade = 'B';
          // C: 그 외 (사실상 이 단계까지 오면 안됨)
          else newGrade = 'C';
        }
        
        verifiedResults.push({
          ...result,
          searchVolume: realSearchVolume || result.searchVolume || 0,
          documentCount: realDocCount || result.documentCount || 0,
          goldenRatio: realGoldenRatio,
          grade: newGrade,
          blueOcean: {
            ...result.blueOcean,
            score: isRealBlueOcean ? Math.min(100, 50 + Math.round(realGoldenRatio * 10)) : (isLowCompetition ? 60 : result.blueOcean.score)
          }
        });
        
        const apiLabel = apiSuccess ? '✅' : '⚡';
        console.log(`[PRO-TRAFFIC] ${apiLabel} ${result.keyword}: 검색량 ${realSearchVolume} / 문서수 ${realDocCount} / 황금비율 ${realGoldenRatio.toFixed(2)} [${newGrade}급]`);
      } else {
        console.log(`[PRO-TRAFFIC] ⏭️ ${result.keyword}: 데이터 없음`);
      }
      
      // Rate Limit 방지 (속도 최적화)
      await new Promise(r => setTimeout(r, 50));
      
      // 목표 개수 달성 시 중단
      if (verifiedResults.length >= count) break;
    }
    
    // 🔥 API 호출 후에도 결과가 없으면 기존 데이터 사용 (0개 방지!)
    // 단, 황금비율 필터링은 적용!
    if (verifiedResults.length === 0) {
      console.log('[PRO-TRAFFIC] ⚠️ API 검증 실패, 기존 수집 데이터로 결과 생성 (황금비율 필터링 적용)');
      for (const result of sortedResults.slice(0, count * 3)) {
        const ratio = result.documentCount > 0 ? result.searchVolume / result.documentCount : 0;
        // 황금비율 0.5 이상만 포함
        if (ratio >= 0.5 || result.documentCount === 0) {
          verifiedResults.push({
            ...result,
            goldenRatio: ratio,
            source: result.source + ' (API 검증 실패, 수집 데이터)'
          });
          if (verifiedResults.length >= count) break;
        }
      }
    }
  } else {
    console.log('[PRO-TRAFFIC] ⚠️ API 키 미설정, 기존 결과 사용 (황금비율 필터링 적용)');
    for (const result of sortedResults.slice(0, count * 3)) {
      const ratio = result.documentCount > 0 ? result.searchVolume / result.documentCount : 0;
      if (ratio >= 0.5 || result.documentCount === 0) {
        verifiedResults.push(result);
        if (verifiedResults.length >= count) break;
      }
    }
  }
  
  // 🔥 최종 안전장치: 결과가 여전히 없으면 sortedResults에서 황금비율 높은 것만
  if (verifiedResults.length === 0 && sortedResults.length > 0) {
    console.log('[PRO-TRAFFIC] ⚠️ 최종 안전장치: 황금비율 높은 키워드만 선별');
    const filtered = sortedResults
      .filter(r => {
        const ratio = r.documentCount > 0 ? r.searchVolume / r.documentCount : 999;
        return ratio >= 0.3; // 최소 기준 완화
      })
      .slice(0, count);
    verifiedResults.push(...filtered);
  }
  
  // 🔥 검증된 결과 재정렬 (랜덤 요소 추가 - 같은 등급 내 다양성!)
  const sortedFinalResults = shuffleArray(verifiedResults) // 먼저 셔플
    .sort((a, b) => {
      // 1순위: 등급 (SSS > SS > S > A > B > C)
      const gradeOrder: Record<string, number> = { 'SSS': 6, 'SS': 5, 'S': 4, 'A': 3, 'B': 2, 'C': 1 };
      const gradeA = gradeOrder[a.grade] || 0;
      const gradeB = gradeOrder[b.grade] || 0;
      if (gradeB !== gradeA) return gradeB - gradeA;
      // 2순위: 황금비율 (같은 등급 내에서)
      if (Math.abs(b.goldenRatio - a.goldenRatio) > 0.5) return b.goldenRatio - a.goldenRatio;
      // 3순위: 랜덤 (완전히 같은 조건이면 랜덤 순서 유지)
      return 0;
    })
    .slice(0, count);
  
  // 🔥🔥🔥 10단계: 급상승 이유 분석 (상위 키워드만 - 속도 최적화)
  console.log('[PRO-TRAFFIC] 🔥 급상승 이유 분석 시작...');
  const finalResults: ProTrafficKeyword[] = [];
  for (const result of sortedFinalResults) {
    try {
      // 상위 키워드에 대해서만 트렌드 분석 수행
      const trendAnalysis = await analyzeKeywordTrendingReason(result.keyword, {
        searchVolume: result.searchVolume,
        documentCount: result.documentCount,
        growthRate: result.timing.score
      });
      
      finalResults.push({
        ...result,
        trendAnalysis: {
          trendingReason: trendAnalysis.trendingReason,
          whyNow: trendAnalysis.whyNow,
          newsSource: trendAnalysis.source || trendAnalysis.sourceType || '자동 분석'
        }
      });
      
      console.log(`[PRO-TRAFFIC] ✅ ${result.keyword}: 급상승 이유 분석 완료`);
    } catch (error) {
      // 트렌드 분석 실패 시 기본값 사용
      finalResults.push({
        ...result,
        trendAnalysis: {
          trendingReason: `"${result.keyword}"는 현재 검색량이 급상승 중입니다. 관련 정보에 대한 관심이 높아지고 있어요.`,
          whyNow: '지금 글을 작성하면 상위노출 가능성이 높습니다.',
          newsSource: '자동 분석'
        }
      });
    }
    
    // Rate Limit 방지
    await new Promise(r => setTimeout(r, 100));
  }
  
  // 🎯 11단계: 요약 통계
  const summary = {
    totalFound: finalResults.length,
    sssCount: finalResults.filter(k => k.grade === 'SSS').length,
    ssCount: finalResults.filter(k => k.grade === 'SS').length,
    sCount: finalResults.filter(k => k.grade === 'S').length,
    rookieFriendlyCount: finalResults.filter(k => k.rookieFriendly.score >= 70).length,
    urgentCount: finalResults.filter(k => k.timing.urgency === 'NOW' || k.timing.urgency === 'TODAY').length,
    blueOceanCount: finalResults.filter(k => k.blueOcean.score >= 70).length
  };
  
  console.log(`[PRO-TRAFFIC] 🏆🏆🏆 ${finalResults.length}개 황금 키워드 발굴 완료 (실제 API 검증 완료!)`);
  console.log(`[PRO-TRAFFIC] 💎 블루오션: ${summary.blueOceanCount}개, 신생적합: ${summary.rookieFriendlyCount}개`);
  console.log(`[PRO-TRAFFIC] 📊 TOP 키워드: ${finalResults.slice(0, 3).map(k => `${k.keyword}(${k.searchVolume}/${k.documentCount})`).join(', ')}`);
  
  return {
    keywords: finalResults,
    summary,
    huntingStrategy: '🏆 끝판왕 블루오션 전략: 실제 API 검증 완료된 황금 키워드',
    timestamp: new Date().toISOString()
  };
}

