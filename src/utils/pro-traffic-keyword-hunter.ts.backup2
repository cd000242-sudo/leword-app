/**
 * 📅 시즌/이벤트 키워드 자동 생성
 */
async function getSeasonalEventKeywords(): Promise<string[]> {
  const keywords: string[] = [];
  const now = new Date();
  const year = now.getFullYear();
  const month = now.getMonth() + 1;
  
  // 현재 시즌 기반 키워드 자동 생성
  const yearKeywords = [
    `${year}`, `${year}년`, `${year + 1}`, `${year + 1}년`
  ];
  
  const monthKeywords: Record<number, string[]> = {
    1: ['새해', '신년', '연말정산', '설'],
    2: ['발렌타인', '졸업', '입학'],
    3: ['봄', '벚꽃', '황사', '미세먼지'],
    4: ['봄꽃', '어버이날', '어린이날'],
    5: ['종합소득세', '휴가', '여름준비'],
    6: ['여름', '에어컨', '장마'],
    7: ['휴가', '바다', '피서'],
    8: ['개학', '추석준비'],
    9: ['추석', '단풍'],
    10: ['독감', '난방', '김장'],
    11: ['블랙프라이데이', '연말', '크리스마스준비'],
    12: ['크리스마스', '연말정산', '새해준비']
  };
  
  // 조합 생성
  for (const y of yearKeywords) {
    for (const m of (monthKeywords[month] || [])) {
      keywords.push(`${y} ${m}`);
      keywords.push(`${m} ${y}`);
    }
  }
  
  // 정부 지원금 시즌 키워드
  const govSeasonKeywords = [
    `${year} 청년지원금`, `${year} 근로장려금`, `${year} 연말정산`,
    `${year + 1} 청년정책`, `${year + 1} 지원금`, `${month}월 지원금 신청`
  ];
  keywords.push(...govSeasonKeywords);
  
  console.log(`[PRO-TRAFFIC] 📅 시즌 키워드 ${keywords.length}개`);
  return keywords;
}

/**
 * 질문에서 핵심 키워드 추출
 */
function extractQuestionKeywords(question: string): string[] {
  const keywords: string[] = [];
  
  // "~하는 법", "~방법", "~추천" 등의 패턴 추출
  const patterns = [
    /(.+)(하는\s*법|방법|추천|비교|가격|후기|신청|조건)/g,
    /어떻게\s*(.+)/g,
    /(.+)\s*(어디서|언제|얼마)/g
  ];
  
  for (const pattern of patterns) {
    const matches = question.match(pattern);
    if (matches) {
      keywords.push(...matches);
    }
  }
  
  // 단어 추출
  const words = question.split(/[\s\?\!\.\,]+/).filter(w => w.length > 1 && w.length < 15);
  keywords.push(...words);
  
  return keywords;
}

/**
 * 📊 네이버 데이터랩 인기 검색어
 */
async function getNaverDataLabKeywords(): Promise<string[]> {
  const keywords: string[] = [];
  
  try {
    const axios = (await import('axios')).default;
    
    // 네이버 쇼핑 인사이트 인기 검색어
    const categories = [
      '50000000', // 패션의류
      '50000001', // 화장품/미용
      '50000002', // 디지털/가전
      '50000003', // 가구/인테리어
      '50000004', // 출산/육아
      '50000005', // 식품
      '50000006', // 스포츠/레저
      '50000007', // 생활/건강
    ];
    
    // 각 카테고리별 인기 검색어 수집
    for (const category of categories.slice(0, 4)) {
      try {
        const response = await axios.get(
          `https://datalab.naver.com/shoppingInsight/getCategory.naver?cid=${category}`,
          {
            headers: {
              'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
              'Referer': 'https://datalab.naver.com/shoppingInsight/sCategory.naver'
            },
            timeout: 5000
          }
        );
        
        if (response.data && Array.isArray(response.data)) {
          for (const item of response.data) {
            if (item.title) keywords.push(item.title);
          }
        }
      } catch {
        // 개별 카테고리 실패 무시
      }
    }
    
    console.log(`[PRO-TRAFFIC] 📊 네이버 데이터랩 ${keywords.length}개 키워드`);
  } catch (error) {
    console.warn('[PRO-TRAFFIC] 데이터랩 키워드 수집 실패:', error);
  }
  
  return keywords;
}

/**
 * 🌍 구글 트렌드 인기 검색어
 */
async function getGoogleTrendsKeywords(): Promise<string[]> {
  const keywords: string[] = [];
  
  try {
    const axios = (await import('axios')).default;
    
    // 구글 트렌드 RSS (한국)
    const response = await axios.get(
      'https://trends.google.co.kr/trends/trendingsearches/daily/rss?geo=KR',
      {
        headers: {
          'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
        },
        timeout: 5000
      }
    );
    
    // RSS 파싱
    const titleMatches = response.data.match(/<title>([^<]+)<\/title>/g);
    if (titleMatches) {
      for (const match of titleMatches.slice(1)) { // 첫 번째는 피드 제목
        const keyword = match.replace(/<\/?title>/g, '').trim();
        if (keyword && keyword.length > 1 && keyword.length < 30) {
          keywords.push(keyword);
        }
      }
    }
    
    console.log(`[PRO-TRAFFIC] 🌍 구글 트렌드 ${keywords.length}개 키워드`);
  } catch (error) {
    console.warn('[PRO-TRAFFIC] 구글 트렌드 수집 실패:', error);
  }
  
  return keywords;
}

/**
 * 📺 유튜브 인기 검색어/주제
 */
async function getYouTubeTrendKeywords(): Promise<string[]> {
  const keywords: string[] = [];
  
  try {
    const axios = (await import('axios')).default;
    
    // 유튜브 트렌딩 페이지 크롤링
    const response = await axios.get(
      'https://www.youtube.com/feed/trending?gl=KR&hl=ko',
      {
        headers: {
          'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
          'Accept-Language': 'ko-KR,ko;q=0.9'
        },
        timeout: 5000
      }
    );
    
    // 비디오 제목에서 키워드 추출
    const titleMatches = response.data.match(/"title":\s*{"runs":\s*\[{"text":\s*"([^"]+)"/g);
    if (titleMatches) {
      for (const match of titleMatches.slice(0, 20)) {
        const titleMatch = match.match(/"text":\s*"([^"]+)"/);
        if (titleMatch && titleMatch[1]) {
          const title = titleMatch[1];
          // 제목에서 핵심 키워드 추출
          const words = title.split(/[\s\|\-\[\]()]+/).filter(w => w.length > 1 && w.length < 15);
          keywords.push(...words);
        }
      }
    }
    
    console.log(`[PRO-TRAFFIC] 📺 유튜브 트렌드 ${keywords.length}개 키워드`);
  } catch (error) {
    console.warn('[PRO-TRAFFIC] 유튜브 트렌드 수집 실패:', error);
  }
  
  return keywords;
}

/**
 * 📰 뉴스 이슈 키워드 (확장)
 */
async function getNewsIssueKeywords(): Promise<string[]> {
  const keywords: string[] = [];
  
  try {
    // 정책/경제/생활 뉴스에서 키워드 추출
    const newsCategories = [
      'https://news.naver.com/section/101', // 경제
      'https://news.naver.com/section/102', // 사회
      'https://news.naver.com/section/103', // 생활/문화
      'https://news.naver.com/section/105', // IT/과학
    ];
    
    const axios = (await import('axios')).default;
    const cheerio = await import('cheerio');
    
    for (const url of newsCategories.slice(0, 2)) { // 경제, 사회 섹션
      try {
        const response = await axios.get(url, {
          headers: {
            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
          },
          timeout: 5000
        });
        
        const $ = cheerio.load(response.data);
        
        // 뉴스 헤드라인에서 키워드 추출
        $('a.sa_text_title, .sa_text_strong, .cluster_text_headline').each((_, el) => {
          const text = $(el).text().trim();
          if (text.length > 5 && text.length < 50) {
            // 정부 정책/지원금 관련 키워드 필터
            const policyPatterns = ['지원', '신청', '혜택', '대상', '보조금', '환급', '감면', '정책'];
            if (policyPatterns.some(p => text.includes(p))) {
              // 핵심 키워드 추출
              const cleanText = text.replace(/[…\[\]"'']/g, '').trim();
              if (cleanText.length > 3) {
                keywords.push(cleanText);
              }
            }
          }
        });
      } catch {
        // 개별 URL 실패는 무시
      }
    }
  } catch (error) {
    console.warn('[PRO-TRAFFIC] 뉴스 크롤링 실패:', error);
  }
  
  return [...new Set(keywords)].slice(0, 10);
}

