  } catch { /* 무시 */ }
  
  return [...new Set(keywords)].slice(0, 50);
}

/**
 * 📜 정책브리핑 RSS에서 정부 정책 키워드
 */
async function getPolicyBriefingKeywords(): Promise<string[]> {
  const keywords: string[] = [];
  
  try {
    const axios = (await import('axios')).default;
    
    // 정책브리핑 RSS
    const response = await axios.get('https://www.korea.kr/rss/policy.xml', {
      headers: { 'User-Agent': 'Mozilla/5.0' },
      timeout: 5000
    });
    
    // RSS 파싱
    const titleMatches = response.data.match(/<title>([^<]+)<\/title>/g);
    if (titleMatches) {
      for (const match of titleMatches.slice(1, 30)) {
        const title = match.replace(/<\/?title>/g, '').trim();
        if (title.length > 3 && title.length < 50) {
          // 정책 관련 키워드 추출
          const policyWords = title.split(/[\s\|\-\[\]()\/]+/).filter(w => 
            w.length > 1 && w.length < 15 && 
            (w.includes('지원') || w.includes('정책') || w.includes('사업') || 
             w.includes('혜택') || w.includes('신청') || w.includes('대상'))
          );
          keywords.push(title, ...policyWords);
        }
      }
    }
    
    console.log(`[PRO-TRAFFIC] 📜 정책브리핑 ${keywords.length}개`);
  } catch { /* 무시 */ }
  
  return [...new Set(keywords)].slice(0, 50);
}

