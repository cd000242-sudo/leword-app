{
  "name": "leword",
  "version": "2.49.87",
  "description": "LEWORD - 키워드 마스터 독립 앱",
  "main": "dist/src/main.js",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.electron.json",
    "start": "set ELECTRON_RUN_AS_NODE=&& electron .",
    "dev": "ts-node src/main.ts",
    "test:crawler": "ts-node test-crawler.ts",
    "test:pro:runner": "node -r ts-node/register scripts/pro-hunter-runner.ts",
    "test:sanity": "node scripts/run-sanity-gate-test.js",
    "lint:sss": "node scripts/lint-no-direct-sss.js --strict",
    "health:sanity": "node scripts/health-check-sanity.js",
    "api:start": "npm --prefix apps/api run start",
    "api:start:prod": "npm --prefix apps/api run start:prod",
    "api:typecheck": "npm --prefix apps/api run typecheck",
    "mobile:api:local": "node scripts/mobile-api-local.js",
    "mobile:dev": "node scripts/mobile-dev-start.js",
    "verify:mobile": "npm --prefix apps/api run typecheck && npm --prefix apps/mobile run typecheck && node scripts/mobile-api-deploy-gate.js && node scripts/mobile-ui-release-gate.js && node scripts/mobile-store-listing-gate.js && node scripts/mobile-store-assets-gate.js && node scripts/mobile-store-submission-package.js && node scripts/mobile-launch-sla-report.js && node scripts/mobile-release-status.js && node scripts/mobile-release-secret-scan.js && node scripts/mobile-release-gate.js && node scripts/mobile-native-env-gate.js",
    "mobile:doctor": "node scripts/run-mobile-command.js -- npm --prefix apps/mobile run doctor",
    "mobile:audit": "node scripts/run-mobile-command.js -- npm --prefix apps/mobile audit --omit=dev",
    "mobile:export:android": "node scripts/run-mobile-command.js --cwd apps/mobile -- npx expo export --platform android --output-dir .expo-export/android",
    "mobile:eas:whoami": "node scripts/run-mobile-command.js --cwd apps/mobile -- npx eas-cli whoami",
    "mobile:api-deploy-gate": "node scripts/mobile-api-deploy-gate.js",
    "mobile:api:docker:build": "docker build -f apps/api/Dockerfile -t leword-mobile-api:latest .",
    "mobile:ci-secrets-gate": "node scripts/mobile-ci-secrets-gate.js",
    "mobile:api-runtime-gate": "node scripts/mobile-api-runtime-gate.js",
    "mobile:api-smoke": "node scripts/mobile-api-smoke-test.js",
    "mobile:api-performance-smoke": "node scripts/mobile-api-performance-smoke.js",
    "mobile:api-performance-smoke:save": "node scripts/mobile-api-performance-smoke.js --out .codex-build-cache/mobile-api-performance-smoke.json",
    "mobile:ui-release-gate": "node scripts/mobile-ui-release-gate.js",
    "mobile:ui-release-gate:save": "node scripts/mobile-ui-release-gate.js --out .codex-build-cache/mobile-ui-release-gate.json",
    "mobile:store-compliance": "node scripts/mobile-store-compliance-gate.js",
    "mobile:store-listing": "node scripts/mobile-store-listing-gate.js",
    "mobile:assets:generate": "node scripts/mobile-generate-assets.js",
    "mobile:store-assets": "node scripts/mobile-store-assets-gate.js",
    "mobile:store-submission-package": "node scripts/mobile-store-submission-package.js",
    "mobile:store-submission-package:save": "node scripts/mobile-store-submission-package.js --out .codex-build-cache/mobile-store-submission-package.json --google-play-out .codex-build-cache/mobile-store-submission-google-play.txt --app-store-out .codex-build-cache/mobile-store-submission-app-store.txt",
    "mobile:launch-sla": "node scripts/mobile-launch-sla-report.js",
    "mobile:launch-sla:save": "node scripts/mobile-launch-sla-report.js --out .codex-build-cache/mobile-launch-sla-report.json",
    "mobile:release-audit": "node scripts/mobile-release-audit.js",
    "mobile:release-audit:save": "node scripts/mobile-release-audit.js --out .codex-build-cache/mobile-release-audit.json",
    "mobile:release-kit": "node scripts/mobile-release-kit.js",
    "mobile:release-kit:save": "node scripts/mobile-release-kit.js --out .codex-build-cache/mobile-release-kit.json",
    "mobile:github-setup-plan": "node scripts/mobile-github-setup-plan.js",
    "mobile:github-setup-plan:save": "node scripts/mobile-github-setup-plan.js --out .codex-build-cache/mobile-github-setup-plan.json --ps1 .codex-build-cache/mobile-github-setup.ps1",
    "mobile:release-dry-run": "node scripts/mobile-release-dry-run.js",
    "mobile:release-dry-run:save": "node scripts/mobile-release-dry-run.js --out .codex-build-cache/mobile-release-dry-run.json",
    "mobile:release-dispatch-plan": "node scripts/mobile-release-dispatch-plan.js",
    "mobile:release-dispatch-plan:save": "node scripts/mobile-release-dispatch-plan.js --out .codex-build-cache/mobile-release-dispatch-plan.json",
    "mobile:release-status": "node scripts/mobile-release-status.js",
    "mobile:release-status:save": "node scripts/mobile-release-status.js --out .codex-build-cache/mobile-release-status.json",
    "mobile:release-secret-scan": "node scripts/mobile-release-secret-scan.js",
    "mobile:release-secret-scan:save": "node scripts/mobile-release-secret-scan.js --out .codex-build-cache/mobile-release-secret-scan.json",
    "mobile:public-release-gate": "node scripts/mobile-public-release-gate.js",
    "mobile:public-release-gate:android": "node scripts/mobile-public-release-gate.js --platform android",
    "mobile:public-release-gate:android:save": "node scripts/mobile-public-release-gate.js --platform android --out .codex-build-cache/mobile-public-release-gate-android.json --report-only",
    "mobile:public-release-gate:save": "node scripts/mobile-public-release-gate.js --out .codex-build-cache/mobile-public-release-gate.json --report-only",
    "mobile:release-gate:cloud": "node scripts/mobile-cloud-release-gate.js",
    "mobile:deploy-readiness": "node scripts/mobile-deploy-readiness.js",
    "mobile:deploy-readiness:android": "node scripts/mobile-deploy-readiness.js --platform android",
    "mobile:deploy-readiness:ios": "node scripts/mobile-deploy-readiness.js --platform ios",
    "mobile:submit-config:materialize": "node scripts/mobile-materialize-submit-config.js",
    "mobile:submit-gate:android": "node scripts/mobile-submit-gate.js --platform android",
    "mobile:submit-gate:android:public": "node scripts/mobile-submit-gate.js --platform android --profile public",
    "mobile:submit-gate:ios": "node scripts/mobile-submit-gate.js --platform ios",
    "mobile:preflight:production": "npm run verify:all && npm run mobile:doctor && npm run mobile:audit && npm run mobile:export:android && npm run mobile:release-gate:production && npm run mobile:store-compliance && npm run mobile:store-listing && npm run mobile:store-assets && npm run mobile:api-runtime-gate && npm run mobile:readiness",
    "mobile:build:android:internal": "npm run mobile:release-gate:cloud && node scripts/run-mobile-command.js --cwd apps/mobile -- npx eas-cli build --platform android --profile internal --non-interactive",
    "mobile:build:android:production": "npm run mobile:release-gate:cloud && node scripts/run-mobile-command.js --cwd apps/mobile -- npx eas-cli build --platform android --profile production --non-interactive",
    "mobile:build:ios:testflight": "npm run mobile:release-gate:cloud && node scripts/run-mobile-command.js --cwd apps/mobile -- npx eas-cli build --platform ios --profile production --non-interactive",
    "mobile:submit:android:internal": "npm run mobile:submit-gate:android && node scripts/run-mobile-command.js --cwd apps/mobile -- npx eas-cli submit --platform android --profile production --latest --non-interactive",
    "mobile:submit:android:public": "npm run mobile:submit-gate:android:public && node scripts/run-mobile-command.js --cwd apps/mobile -- npx eas-cli submit --platform android --profile public --latest --non-interactive",
    "mobile:submit:ios:testflight": "npm run mobile:submit-gate:ios && node scripts/run-mobile-command.js --cwd apps/mobile -- npx eas-cli submit --platform ios --profile production --latest --non-interactive",
    "mobile:deploy:android:internal": "npm run mobile:preflight:production && npm run mobile:deploy-readiness:android && npm run mobile:build:android:production && npm run mobile:submit:android:internal",
    "mobile:deploy:ios:testflight": "npm run mobile:preflight:production && npm run mobile:deploy-readiness:ios && npm run mobile:build:ios:testflight && npm run mobile:submit:ios:testflight",
    "mobile:readiness": "node scripts/mobile-readiness-report.js",
    "mobile:release-gate:production": "node scripts/mobile-production-release-gate.js",
    "install:hooks": "node scripts/install-git-hooks.js",
    "verify:all": "npm run build && npm run lint:sss && npm run test:sanity && npm run verify:mobile && npm run health:sanity",
    "prepare-dist": "node scripts/prepare-dist.js",
    "postinstall": "node scripts/download-chromium.js",
    "dist": "npm run prepare-dist && npm run build && electron-builder",
    "dist:win": "npm run prepare-dist && npm run build && electron-builder --win --publish always",
    "dist:mac": "node scripts/build-mac.js --arch both",
    "release": "npm run verify:all && npm run prepare-dist && npm run build && electron-builder --win --publish always && node scripts/publish-release.js",
    "release:mac": "node scripts/build-mac.js --arch both --publish",
    "release:all": "npm run verify:all && npm run prepare-dist && npm run build && electron-builder --win --mac --publish always && node scripts/publish-release.js",
    "dist:mac:arm64": "node scripts/build-mac.js --arch arm64",
    "dist:mac:x64": "node scripts/build-mac.js --arch x64",
    "dist:mac:universal": "node scripts/build-mac.js --arch universal",
    "dist:mac:unsigned": "node scripts/build-mac.js --arch both --unsigned",
    "dist:mac:arm64:unsigned": "node scripts/build-mac.js --arch arm64 --unsigned",
    "dist:mac:universal:unsigned": "node scripts/build-mac.js --arch universal --unsigned",
    "release:mac:unsigned": "node scripts/build-mac.js --arch both --unsigned --publish"
  },
  "keywords": [
    "keyword",
    "master",
    "leword",
    "electron"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.24.1",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.13.0",
    "cheerio": "^1.1.2",
    "dayjs": "^1.11.18",
    "dotenv": "^16.3.1",
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "googleapis": "^164.1.0",
    "iconv-lite": "^0.7.0",
    "patchright": "^1.60.0",
    "playwright": "^1.59.1",
    "puppeteer": "^21.5.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@types/node": "^20.10.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.leword.app",
    "productName": "LEWORD",
    "artifactName": "LEWORD-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "ui/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/updater-splash.hta",
        "to": "updater-splash.hta"
      },
      {
        "from": "resources/chromium",
        "to": "chromium"
      }
    ],
    "asarUnpack": [
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/256.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "runAfterFinish": false,
      "shortcutName": "LEWORD 키워드마스터",
      "include": "build/installer.nsh"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "singleArchFiles": "**/node_modules/@img/*darwin*/**/*",
      "x64ArchFiles": "**/node_modules/@img/*darwin*/**/*",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "artifactName": "LEWORD-${version}-${arch}.${ext}",
      "extendInfo": {
        "NSDownloadsFolderUsageDescription": "LEWORD saves exported keyword and automation files to Downloads.",
        "NSDocumentsFolderUsageDescription": "LEWORD may open or save user-selected keyword files."
      }
    },
    "publish": [
      {
        "provider": "github",
        "owner": "cd000242-sudo",
        "repo": "leword-app",
        "releaseType": "release"
      }
    ],
    "dmg": {
      "title": "LEWORD ${version}",
      "artifactName": "LEWORD-${version}-${arch}.${ext}"
    }
  }
}
