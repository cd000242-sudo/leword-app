          <!-- 저장 버튼 -->
          <div style="display: flex; gap: 12px; margin-top: 32px; padding-top: 24px; border-top: 2px solid rgba(255, 255, 255, 0.1);">
            <button onclick="saveKeywordSettings()" style="flex: 1; padding: 16px 32px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; border-radius: 12px; font-size: 16px; font-weight: 600; cursor: pointer; box-shadow: 0 8px 24px rgba(102, 126, 234, 0.3); transition: all 0.3s ease; display: flex; align-items: center; justify-content: center; gap: 8px;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 12px 32px rgba(102, 126, 234, 0.4)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 8px 24px rgba(102, 126, 234, 0.3)'">
              <span>💾</span>
              <span>저장</span>
            </button>
            <button onclick="closeKeywordSettingsModal()" style="padding: 16px 32px; background: rgba(255, 255, 255, 0.1); color: white; border: 2px solid rgba(255, 255, 255, 0.2); border-radius: 12px; font-size: 16px; font-weight: 600; cursor: pointer; transition: all 0.3s ease;" onmouseover="this.style.background='rgba(255, 255, 255, 0.2)'" onmouseout="this.style.background='rgba(255, 255, 255, 0.1)'">
              닫기
            </button>
          </div>
          </div>
        </div>
      </div>
    </div>

  <!-- 모달 컨테이너 (동적으로 생성) -->
  <div id="modalContainer"></div>

  <script>
    // =====================================================
    // 유틸리티 함수들
    // =====================================================
    
    // 클립보드 복사 함수
    async function copyToClipboard(text) {
      try {
        await navigator.clipboard.writeText(text);
        showToast(`"${text}" 복사됨!`, 'success');
      } catch (err) {
        // fallback for older browsers
        const textArea = document.createElement('textarea');
        textArea.value = text;
        textArea.style.position = 'fixed';
        textArea.style.left = '-999999px';
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand('copy');
          showToast(`"${text}" 복사됨!`, 'success');
        } catch (e) {
          showToast('복사 실패', 'error');
        }
        document.body.removeChild(textArea);
      }
    }
    
    // 토스트 알림 표시 함수
    function showToast(message, type = 'info') {
      const existingToast = document.querySelector('.toast-notification');
      if (existingToast) existingToast.remove();
      
      const toast = document.createElement('div');
      toast.className = 'toast-notification';
      toast.style.cssText = `
        position: fixed;
        bottom: 30px;
        left: 50%;
        transform: translateX(-50%);
        padding: 14px 28px;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 600;
        z-index: 10000;
        animation: slideUp 0.3s ease;
        box-shadow: 0 4px 20px rgba(0,0,0,0.3);
        ${type === 'success' ? 'background: linear-gradient(135deg, #10b981, #059669); color: white;' : 
          type === 'error' ? 'background: linear-gradient(135deg, #ef4444, #dc2626); color: white;' :
          'background: linear-gradient(135deg, #3b82f6, #2563eb); color: white;'}
      `;
      toast.textContent = message;
      document.body.appendChild(toast);
      
      setTimeout(() => {
        toast.style.animation = 'slideDown 0.3s ease';
        setTimeout(() => toast.remove(), 300);
      }, 2000);
    }
    
    // 토스트 애니메이션 스타일 추가
    if (!document.querySelector('#toast-styles')) {
      const style = document.createElement('style');
      style.id = 'toast-styles';
      style.textContent = `
        @keyframes slideUp {
          from { transform: translateX(-50%) translateY(100px); opacity: 0; }
          to { transform: translateX(-50%) translateY(0); opacity: 1; }
        }
        @keyframes slideDown {
          from { transform: translateX(-50%) translateY(0); opacity: 1; }
          to { transform: translateX(-50%) translateY(100px); opacity: 0; }
        }
      `;
      document.head.appendChild(style);
    }
    
    // =====================================================
    // 디버깅: window 객체 확인
    // =====================================================
    console.log('[INIT] window.electronAPI:', window.electronAPI);
    console.log('[INIT] window.blogger:', window.blogger);
    console.log('[INIT] window.api:', window.api);
    console.log('[INIT] typeof window.electronAPI?.invoke:', typeof window.electronAPI?.invoke);
    
    // window.blogger API 초기화 - 즉시 실행하고 fallback 즉시 활성화
    (function() {
      // 먼저 fallback을 즉시 설정 (preload가 없어도 작동하도록)
      function setupFallback() {
        if (!window.blogger) {
          window.blogger = {};
        }
        
        // IPC 요청을 부모 창으로 전송 (Electron 환경)
        function sendIPCRequest(method, ...args) {
          return new Promise((resolve, reject) => {
            // 우선순위 1: window.electronAPI.invoke 사용 (가장 안전하고 권장되는 방법)
            if (window.electronAPI && typeof window.electronAPI.invoke === 'function') {
              console.log('[SEND-IPC] window.electronAPI.invoke 사용:', method);
              window.electronAPI.invoke(method, ...args)
                .then(resolve)
                .catch(reject);
              return;
            }
            
            // 우선순위 2: window.blogger의 직접 메서드 사용
            if (window.blogger && typeof window.blogger[method] === 'function') {
              console.log('[SEND-IPC] window.blogger 메서드 사용:', method);
              try {
                const result = window.blogger[method](...args);
                if (result && typeof result.then === 'function') {
                  result.then(resolve).catch(reject);
                } else {
                  resolve(result);
                }
                return;
              } catch (e) {
                console.warn('[SEND-IPC] window.blogger 메서드 호출 실패:', e);
              }
            }
            
            // 우선순위 3: Electron의 ipcRenderer를 직접 사용 시도 (contextIsolation이 false인 경우만)
            if (typeof require !== 'undefined') {
              try {
                const { ipcRenderer } = require('electron');
                if (ipcRenderer && typeof ipcRenderer.invoke === 'function') {
                  console.log('[SEND-IPC] ipcRenderer 직접 사용:', method);
                  ipcRenderer.invoke(method, ...args)
                    .then(resolve)
                    .catch(reject);
                  return;
                }
              } catch (e) {
                console.warn('[SEND-IPC] ipcRenderer 직접 사용 실패:', e);
              }
            }
            
            // 우선순위 4: window.opener를 통한 통신 (일반 브라우저 환경)
            if (window.opener && window.opener.postMessage) {
              const requestId = Date.now() + Math.random();
              
              const handler = (event) => {
                if (event.data && event.data.type === 'BLOGGER_API_RESPONSE' && event.data.requestId === requestId) {
                  window.removeEventListener('message', handler);
                  if (event.data.error) {
                    reject(new Error(event.data.error));
                  } else {
                    resolve(event.data.result);
                  }
                }
              };
              
              window.addEventListener('message', handler);
              window.opener.postMessage({
                type: 'REQUEST_BLOGGER_API',
                method: method,
                args: args,
                requestId: requestId
              }, '*');
              
              // 타임아웃
              setTimeout(() => {
                window.removeEventListener('message', handler);
                reject(new Error('Request timeout'));
              }, 30000);
              return;
            }
            
            // 모든 방법 실패
            console.error('[SEND-IPC] ❌ IPC 통신 방법을 찾을 수 없습니다:', {
              hasElectronAPI: !!(window.electronAPI && typeof window.electronAPI.invoke === 'function'),
              hasBlogger: !!window.blogger,
              hasRequire: typeof require !== 'undefined',
              hasOpener: !!(window.opener && window.opener.postMessage)
            });
            reject(new Error('IPC 통신 방법을 찾을 수 없습니다'));
          });
        }

        // 모든 키워드 마스터 API 등록 (IPC 메서드 이름은 kebab-case)
        window.blogger.findGoldenKeywords = window.blogger.findGoldenKeywords || ((keyword, options) => {
          // keyword와 options를 모두 전달
          if (typeof keyword === 'object' && keyword.keyword) {
            // 이미 객체 형태로 전달된 경우
            return sendIPCRequest('find-golden-keywords', keyword);
          } else {
            // keyword와 options를 별도로 전달
            return sendIPCRequest('find-golden-keywords', keyword, options);
          }
        });
        window.blogger.getTrendingKeywords = window.blogger.getTrendingKeywords || ((source) => sendIPCRequest('get-trending-keywords', source));
        window.blogger.getRealtimeKeywords = window.blogger.getRealtimeKeywords || ((options) => sendIPCRequest('get-realtime-keywords', options));
        // sendIPCRequest를 외부에서도 사용 가능하도록 등록 (fallback용)
        window.blogger.sendIPCRequest = window.blogger.sendIPCRequest || sendIPCRequest;
        window.blogger.huntTimingGold = window.blogger.huntTimingGold || ((category) => sendIPCRequest('hunt-timing-gold', category));
        window.blogger.checkKeywordRank = window.blogger.checkKeywordRank || ((data) => sendIPCRequest('check-keyword-rank', data));
        window.blogger.analyzeCompetitors = window.blogger.analyzeCompetitors || ((keyword) => sendIPCRequest('analyze-competitors', keyword));
        window.blogger.getSchedules = window.blogger.getSchedules || (() => sendIPCRequest('get-schedules'));
        window.blogger.addSchedule = window.blogger.addSchedule || ((schedule) => sendIPCRequest('add-schedule', schedule));
        window.blogger.toggleSchedule = window.blogger.toggleSchedule || ((id, enabled) => sendIPCRequest('toggle-schedule', id, enabled));
        window.blogger.getNotifications = window.blogger.getNotifications || (() => sendIPCRequest('get-notifications'));
        window.blogger.saveNotificationSettings = window.blogger.saveNotificationSettings || ((settings) => sendIPCRequest('save-notification-settings', settings));
        window.blogger.getDashboardStats = window.blogger.getDashboardStats || (() => sendIPCRequest('get-dashboard-stats'));
        window.blogger.getKeywordGroups = window.blogger.getKeywordGroups || (() => sendIPCRequest('get-keyword-groups'));
        window.blogger.addKeywordGroup = window.blogger.addKeywordGroup || ((group) => sendIPCRequest('add-keyword-group', group));
        window.blogger.updateKeywordGroup = window.blogger.updateKeywordGroup || ((id, updates) => sendIPCRequest('update-keyword-group', id, updates));
        window.blogger.deleteKeywordGroup = window.blogger.deleteKeywordGroup || ((id) => sendIPCRequest('delete-keyword-group', id));
        window.blogger.getKeywordSchedules = window.blogger.getKeywordSchedules || (() => sendIPCRequest('get-keyword-schedules'));
        window.blogger.addKeywordSchedule = window.blogger.addKeywordSchedule || ((scheduleData) => sendIPCRequest('add-keyword-schedule', scheduleData));
        window.blogger.toggleKeywordSchedule = window.blogger.toggleKeywordSchedule || ((id, enabled) => sendIPCRequest('toggle-keyword-schedule', id, enabled));
        window.blogger.getSNSTrends = window.blogger.getSNSTrends || ((platform) => sendIPCRequest('get-sns-trends', platform));
        window.blogger.getYouTubeVideos = window.blogger.getYouTubeVideos || ((options) => sendIPCRequest('get-youtube-videos', options));
        window.blogger.getGoogleTrendKeywords = window.blogger.getGoogleTrendKeywords || (() => sendIPCRequest('get-google-trend-keywords'));
        window.blogger.openLink = window.blogger.openLink || ((href) => {
          // window.electronAPI 또는 window.blogger.openExternal 우선 사용
          if (window.electronAPI && typeof window.electronAPI.openExternal === 'function') {
            return window.electronAPI.openExternal(href);
          }
          if (window.blogger && typeof window.blogger.openExternal === 'function') {
            return window.blogger.openExternal(href);
          }
          // IPC 호출 시도
          if (window.electronAPI && typeof window.electronAPI.invoke === 'function') {
            return window.electronAPI.invoke('open-external', href).catch(() => {
              window.open(href, '_blank');
              return true;
            });
          }
          // 브라우저에서 열기 (기본 동작)
          window.open(href, '_blank');
          return Promise.resolve(true);
        });
        
        // openExternal도 등록
        window.blogger.openExternal = window.blogger.openExternal || window.blogger.openLink;
        
        // Fallback 모드 활성화 완료
      };

      // 즉시 fallback 설정
      setupFallback();
      
      // 전역으로 노출 (다른 함수에서 사용 가능하도록)
      window.setupFallback = setupFallback;
      
      // IPC 요청 헬퍼 함수 (sendIPCRequest)
      window.sendIPCRequest = async function(channel, ...args) {
        try {
          if (window.electronAPI && typeof window.electronAPI.invoke === 'function') {
            return await window.electronAPI.invoke(channel, ...args);
          } else if (window.blogger && typeof window.blogger[channel] === 'function') {
            return await window.blogger[channel](...args);
          } else {
            console.error('[IPC] 채널을 찾을 수 없습니다:', channel);
            return { error: true, message: 'IPC 채널을 찾을 수 없습니다.' };
          }
        } catch (error) {
          console.error('[IPC] 요청 실패:', channel, error);
          return { error: true, message: error.message };
        }
      };
      
      // 실시간 검색어를 빠르게 로드 (즉시 실행, 최소 대기)
      const loadRealtimeOnReady = () => {
        console.log('[KEYWORD-MASTER] loadRealtimeOnReady 실행, loadRealtimeKeywordsTop:', typeof window.loadRealtimeKeywordsTop);
        setTimeout(() => {
          if (typeof window.loadRealtimeKeywordsTop === 'function') {
            console.log('[KEYWORD-MASTER] loadRealtimeKeywordsTop 호출 시작');
            window.loadRealtimeKeywordsTop().catch(err => {
              console.error('[KEYWORD-MASTER] loadRealtimeKeywordsTop 오류:', err);
            });
          } else {
            console.error('[KEYWORD-MASTER] loadRealtimeKeywordsTop 함수 없음, 1초 후 재시도');
            setTimeout(() => {
              if (typeof window.loadRealtimeKeywordsTop === 'function') {
                console.log('[KEYWORD-MASTER] 재시도: loadRealtimeKeywordsTop 호출');
                window.loadRealtimeKeywordsTop().catch(err => {
                  console.error('[KEYWORD-MASTER] 재시도 오류:', err);
                });
              }
            }, 1000);
          }
        }, 500); // 500ms로 증가 (함수가 정의될 시간 확보)
      };
      
      console.log('[KEYWORD-MASTER] document.readyState:', document.readyState);
      if (document.readyState === 'loading') {
        console.log('[KEYWORD-MASTER] DOMContentLoaded 리스너 등록');
        document.addEventListener('DOMContentLoaded', () => {
          loadRealtimeOnReady();
          checkLicenseStatus(); // 라이선스 상태 확인
        });
      } else {
        console.log('[KEYWORD-MASTER] DOM 로드 완료, 즉시 실행');
        loadRealtimeOnReady();
        checkLicenseStatus(); // 라이선스 상태 확인
      }
      
      // 새로고침 버튼 이벤트 리스너 등록 (여러 방법으로 시도)
      function setupRefreshButton() {
        console.log('[REFRESH-BUTTON] 새로고침 버튼 설정 시작...');
        const refreshBtn = document.getElementById('refreshRealtimeTop');
        
        if (!refreshBtn) {
          console.error('[REFRESH-BUTTON] ❌ 버튼을 찾을 수 없습니다!');
          console.log('[REFRESH-BUTTON] document.readyState:', document.readyState);
          console.log('[REFRESH-BUTTON] 전체 body 내용 확인 중...');
          setTimeout(setupRefreshButton, 500); // 0.5초 후 재시도
          return;
        }
        
        console.log('[REFRESH-BUTTON] ✅ 버튼 찾음:', refreshBtn);
        console.log('[REFRESH-BUTTON] 버튼 ID:', refreshBtn.id);
        console.log('[REFRESH-BUTTON] 버튼 클래스:', refreshBtn.className);
        
        // 기존 이벤트 리스너 제거 후 새로 등록
        const newBtn = refreshBtn.cloneNode(true);
        refreshBtn.parentNode?.replaceChild(newBtn, refreshBtn);
        
        const finalBtn = document.getElementById('refreshRealtimeTop');
        if (!finalBtn) {
          console.error('[REFRESH-BUTTON] ❌ 버튼 교체 후에도 찾을 수 없습니다!');
          return;
        }
        
        // 클릭 이벤트 등록
        finalBtn.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          console.log('[REFRESH-BUTTON] 🔵 클릭 이벤트 발생!');
          
          if (typeof window.loadRealtimeKeywordsTop === 'function') {
            console.log('[REFRESH-BUTTON] ✅ loadRealtimeKeywordsTop 함수 있음, 호출 시작');
            window.loadRealtimeKeywordsTop().catch(err => {
              console.error('[REFRESH-BUTTON] ❌ 로드 실패:', err);
            });
          } else {
            console.error('[REFRESH-BUTTON] ❌ loadRealtimeKeywordsTop 함수 없음');
            location.reload();
          }
        });
        
        // 마우스오버 이벤트로 테스트
        finalBtn.addEventListener('mouseover', function() {
          console.log('[REFRESH-BUTTON] 마우스오버됨');
        });
        
        console.log('[REFRESH-BUTTON] ✅ 이벤트 리스너 등록 완료!');
      }
      
      // 즉시 실행
      setupRefreshButton();
      
      // DOMContentLoaded 후에도 실행
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setupRefreshButton);
      }
      
      // 추가 보험: 1초 후에도 실행
      setTimeout(setupRefreshButton, 1000);
      
      // 주기적 자동 새로고침 (5분마다) - 실시간 키워드 업데이트
      setInterval(() => {
        if (typeof window.loadRealtimeKeywordsTop === 'function') {
          window.loadRealtimeKeywordsTop();
        }
      }, 5 * 60 * 1000); // 5분
    })();

    // 키워드 발굴 상태 관리
    let isDiscovering = false;
    let discoveryResults = [];
    let discoveryAbort = false;

    // 개수 제한 라디오 버튼 이벤트
    document.addEventListener('DOMContentLoaded', function() {
      const limitRadios = document.querySelectorAll('input[name="keywordLimit"]');
      const customInput = document.getElementById('customKeywordLimit');
      
      // customInput이 존재하는 경우에만 이벤트 리스너 추가
      if (customInput) {
      limitRadios.forEach(radio => {
        radio.addEventListener('change', function() {
          if (this.value === 'custom') {
            customInput.style.display = 'block';
            customInput.focus();
          } else {
            customInput.style.display = 'none';
          }
        });
      });
      }
      
      // API 키 연동 상태 체크
      checkApiStatus();
      
              // 주기적으로 API 상태 확인 (30초마다) - 비활성화: 연결 오류 다이얼로그 반복 표시 방지
        // 사용자가 수동으로 새로고침 버튼을 클릭하거나 페이지를 다시 열 때만 확인
        // setInterval(() => {
        //   checkApiStatus();
        // }, 30000);
    });
    
    // API 키 연동 상태 체크 함수
        async function checkApiStatus() {
        try {
          const naverBadge = document.getElementById('naverApiBadge');
          const youtubeBadge = document.getElementById('youtubeApiBadge');
          if (!naverBadge || !youtubeBadge) return;
          
          // 연결 오류 시 조용히 처리 (에러 다이얼로그 표시 안 함)
          // 에러가 발생해도 콘솔에만 기록하고 다이얼로그는 표시하지 않음
        
        let hasNaverId = false;
        let hasNaverSecret = false;
        let hasYouTubeKey = false;
        let hasSearchAdLicense = false;
        let hasSearchAdSecret = false;
        
        // 방법 1: window.electronAPI를 통한 IPC 확인 (최우선)
        try {
          // window.electronAPI가 준비될 때까지 대기
          let retries = 0;
          while ((!window.electronAPI || typeof window.electronAPI.invoke !== 'function') && retries < 20) {
            await new Promise(resolve => setTimeout(resolve, 100));
            retries++;
          }
          
          if (window.electronAPI && typeof window.electronAPI.invoke === 'function') {
            console.log('[API-STATUS] ✅ window.electronAPI.invoke 사용');
            const apiKeys = await window.electronAPI.invoke('check-api-keys');
            console.log('[API-STATUS] ✅ check-api-keys 응답 받음:', {
              hasNaverId: !!(apiKeys?.naverClientId),
              hasNaverSecret: !!(apiKeys?.naverClientSecret),
              hasYouTubeKey: !!(apiKeys?.youtubeApiKey),
              hasSearchAdLicense: !!(apiKeys?.naverSearchAdAccessLicense),
              hasSearchAdSecret: !!(apiKeys?.naverSearchAdSecretKey),
              licenseLength: apiKeys?.naverSearchAdAccessLicense?.length || 0,
              secretLength: apiKeys?.naverSearchAdSecretKey?.length || 0
            });
            if (apiKeys) {
              hasNaverId = !!(apiKeys.naverClientId || apiKeys.naver_client_id || apiKeys.NAVER_CLIENT_ID);
              hasNaverSecret = !!(apiKeys.naverClientSecret || apiKeys.naver_client_secret || apiKeys.NAVER_CLIENT_SECRET);
              hasYouTubeKey = !!(apiKeys.youtubeApiKey || apiKeys.youtube_api_key || apiKeys.YOUTUBE_API_KEY);
              hasSearchAdLicense = !!(apiKeys.naverSearchAdAccessLicense || apiKeys.naver_search_ad_access_license || apiKeys.NAVER_SEARCH_AD_ACCESS_LICENSE);
              hasSearchAdSecret = !!(apiKeys.naverSearchAdSecretKey || apiKeys.naver_search_ad_secret_key || apiKeys.NAVER_SEARCH_AD_SECRET_KEY);
              
              console.log('[API-STATUS] ✅ IPC에서 API 키 확인 완료:', {
                naver: hasNaverId && hasNaverSecret,
                youtube: hasYouTubeKey,
                searchAd: hasSearchAdLicense && hasSearchAdSecret
              });
            }
          } else {
            console.warn('[API-STATUS] ⚠️ window.electronAPI.invoke를 사용할 수 없습니다');
          }
        } catch (electronApiError) {
          console.warn('[API-STATUS] ⚠️ IPC 확인 실패, window.blogger 시도:', electronApiError.message || electronApiError);
        }
        
        // 방법 2: window.blogger.getEnv 시도 (IPC 실패 시 또는 검색광고 키가 없는 경우)
        if (!hasSearchAdLicense || !hasSearchAdSecret) {
        if (window.blogger && typeof window.blogger.getEnv === 'function') {
            try {
              const envResult = await window.blogger.getEnv();
              
              // getEnv는 { ok: true, data: {...} } 형식으로 반환될 수 있음
              const env = (envResult && envResult.ok && envResult.data) ? envResult.data : envResult;
              
              if (env) {
                // 다양한 필드명으로 네이버 API 키 확인
                // EnvironmentManager에서 로드하는 형식: naverClientId, naverClientSecret 등
                hasNaverId = !!(
                  env.naverClientId || 
                  env.naver_client_id || 
                  env.NAVER_CLIENT_ID ||
                  (env.apiKeys && (env.apiKeys.naverClientId || env.apiKeys.naver_client_id || env.apiKeys.NAVER_CLIENT_ID))
                );
                hasNaverSecret = !!(
                  env.naverClientSecret || 
                  env.naver_client_secret || 
                  env.NAVER_CLIENT_SECRET ||
                  (env.apiKeys && (env.apiKeys.naverClientSecret || env.apiKeys.naver_client_secret || env.apiKeys.NAVER_CLIENT_SECRET))
                );
                
                // YouTube API 키 확인 (다양한 필드명 지원)
                hasYouTubeKey = !!(
                  env.youtubeApiKey || 
                  env.youtube_api_key || 
                  env.YOUTUBE_API_KEY ||
                  (env.apiKeys && (env.apiKeys.youtubeApiKey || env.apiKeys.youtube_api_key || env.apiKeys.YOUTUBE_API_KEY))
                );
                
                // 네이버 검색광고 API 키 확인
                hasSearchAdLicense = !!(
                  env.naverSearchAdAccessLicense || 
                  env.naver_search_ad_access_license || 
                  env.NAVER_SEARCH_AD_ACCESS_LICENSE ||
                  (env.apiKeys && (env.apiKeys.naverSearchAdAccessLicense || env.apiKeys.naver_search_ad_access_license || env.apiKeys.NAVER_SEARCH_AD_ACCESS_LICENSE))
                );
                hasSearchAdSecret = !!(
                  env.naverSearchAdSecretKey || 
                  env.naver_search_ad_secret_key || 
                  env.NAVER_SEARCH_AD_SECRET_KEY ||
                  (env.apiKeys && (env.apiKeys.naverSearchAdSecretKey || env.apiKeys.naver_search_ad_secret_key || env.apiKeys.NAVER_SEARCH_AD_SECRET_KEY))
                );
                
                // 실제 키 값 확인 (빈 문자열이 아닌지 체크)
                const actualNaverId = env.naverClientId || env.naver_client_id || env.NAVER_CLIENT_ID || 
                  (env.apiKeys && (env.apiKeys.naverClientId || env.apiKeys.naver_client_id || env.apiKeys.NAVER_CLIENT_ID));
                const actualNaverSecret = env.naverClientSecret || env.naver_client_secret || env.NAVER_CLIENT_SECRET ||
                  (env.apiKeys && (env.apiKeys.naverClientSecret || env.apiKeys.naver_client_secret || env.apiKeys.NAVER_CLIENT_SECRET));
                const actualYouTubeKey = env.youtubeApiKey || env.youtube_api_key || env.YOUTUBE_API_KEY ||
                  (env.apiKeys && (env.apiKeys.youtubeApiKey || env.apiKeys.youtube_api_key || env.apiKeys.YOUTUBE_API_KEY));
                const actualSearchAdLicense = env.naverSearchAdAccessLicense || env.naver_search_ad_access_license || env.NAVER_SEARCH_AD_ACCESS_LICENSE ||
                  (env.apiKeys && (env.apiKeys.naverSearchAdAccessLicense || env.apiKeys.naver_search_ad_access_license || env.apiKeys.NAVER_SEARCH_AD_ACCESS_LICENSE));
                const actualSearchAdSecret = env.naverSearchAdSecretKey || env.naver_search_ad_secret_key || env.NAVER_SEARCH_AD_SECRET_KEY ||
                  (env.apiKeys && (env.apiKeys.naverSearchAdSecretKey || env.apiKeys.naver_search_ad_secret_key || env.apiKeys.NAVER_SEARCH_AD_SECRET_KEY));
                
                // 빈 문자열이 아닌 실제 값이 있는지 확인
                hasNaverId = !!(actualNaverId && actualNaverId.trim().length > 0);
                hasNaverSecret = !!(actualNaverSecret && actualNaverSecret.trim().length > 0);
                hasYouTubeKey = !!(actualYouTubeKey && actualYouTubeKey.trim().length > 0);
                hasSearchAdLicense = !!(actualSearchAdLicense && actualSearchAdLicense.trim().length > 0);
                hasSearchAdSecret = !!(actualSearchAdSecret && actualSearchAdSecret.trim().length > 0);
                
                console.log('[API-STATUS] 검색광고 API 키 확인:', {
                  hasLicense: hasSearchAdLicense,
                  hasSecret: hasSearchAdSecret,
                  licenseValue: actualSearchAdLicense ? `${actualSearchAdLicense.substring(0, 10)}...` : '없음',
                  secretValue: actualSearchAdSecret ? `${actualSearchAdSecret.substring(0, 10)}...` : '없음',
                  licenseLength: actualSearchAdLicense?.length || 0,
                  secretLength: actualSearchAdSecret?.length || 0
                });
                
                // 디버깅 정보는 콘솔에만 출력 (환경변수 구조 확인용)
                if (env && Object.keys(env).length > 0) {
                  console.log('[API-STATUS] window.blogger.getEnv로 API 키 확인:', {
                    naver: { 
                      hasId: hasNaverId, 
                      hasSecret: hasNaverSecret,
                      idValue: actualNaverId ? `${actualNaverId.substring(0, 10)}...` : '없음',
                      secretValue: actualNaverSecret ? `${actualNaverSecret.substring(0, 10)}...` : '없음'
                    },
                    youtube: { 
                      hasKey: hasYouTubeKey,
                      keyValue: actualYouTubeKey ? `${actualYouTubeKey.substring(0, 10)}...` : '없음'
                    },
                    searchAd: {
                      hasLicense: hasSearchAdLicense,
                      hasSecret: hasSearchAdSecret,
                      licenseValue: actualSearchAdLicense ? `${actualSearchAdLicense.substring(0, 10)}...` : '없음',
                      secretValue: actualSearchAdSecret ? `${actualSearchAdSecret.substring(0, 10)}...` : '없음',
                      licenseLength: actualSearchAdLicense?.length || 0,
                      secretLength: actualSearchAdSecret?.length || 0
                    },
                    envKeys: Object.keys(env),
                    // 전체 env 객체의 모든 키-값 쌍 (민감 정보는 앞부분만)
                    envPreview: Object.keys(env).reduce((acc, key) => {
                      const val = env[key];
                      if (typeof val === 'string' && val.length > 0) {
                        acc[key] = val.length > 20 ? `${val.substring(0, 20)}...` : val;
                      } else {
                        acc[key] = val;
                      }
                      return acc;
                    }, {})
                  });
                }
              }
            } catch (getEnvError) {
              console.warn('[API-STATUS] window.blogger.getEnv 실패:', getEnvError);
            }
          }
        }
        
        // 네이버 API 배지 업데이트
          if (hasNaverId && hasNaverSecret) {
            naverBadge.style.background = '#d1fae5';
            naverBadge.style.color = '#065f46';
            naverBadge.innerHTML = '<span>✅</span><span>네이버 API: 연동됨</span>';
          console.log('[API-STATUS] ✅ 네이버 API 연동됨');
          } else {
            naverBadge.style.background = '#fee2e2';
            naverBadge.style.color = '#991b1b';
            naverBadge.innerHTML = '<span>⚠️</span><span>네이버 API: 미연동</span>';
          console.log('[API-STATUS] ❌ 네이버 API 미연동');
        }
        
        // YouTube API 배지 업데이트
        if (hasYouTubeKey) {
          youtubeBadge.style.background = '#d1fae5';
          youtubeBadge.style.color = '#065f46';
          youtubeBadge.innerHTML = '<span>✅</span><span>유튜브 API: 연동됨</span>';
          console.log('[API-STATUS] ✅ 유튜브 API 연동됨');
        } else {
          youtubeBadge.style.background = '#fee2e2';
          youtubeBadge.style.color = '#991b1b';
          youtubeBadge.innerHTML = '<span>⚠️</span><span>유튜브 API: 미연동</span>';
          console.log('[API-STATUS] ❌ 유튜브 API 미연동');
        }
        
        // 네이버 검색광고 API 배지 업데이트
        const searchAdBadge = document.getElementById('naverSearchAdApiBadge');
        if (searchAdBadge) {
          if (hasSearchAdLicense && hasSearchAdSecret) {
            searchAdBadge.style.background = '#d1fae5';
            searchAdBadge.style.color = '#065f46';
            searchAdBadge.innerHTML = '<span>✅</span><span>검색광고 API: 연동됨</span>';
            console.log('[API-STATUS] ✅ 네이버 검색광고 API 연동됨');
          } else {
            searchAdBadge.style.background = '#fee2e2';
            searchAdBadge.style.color = '#991b1b';
            searchAdBadge.innerHTML = '<span>⚠️</span><span>검색광고 API: 미연동</span>';
            console.log('[API-STATUS] ❌ 네이버 검색광고 API 미연동');
          }
        }
      } catch (error) {
        console.error('[API-STATUS] API 상태 확인 실패:', error);
      }
    }

    // 🆕 수식어 키워드 검색 (방법, 꿀팁 등)
    window.searchSuffixKeywords = async function searchSuffixKeywords() {
      const suffix = document.getElementById('suffixInput')?.value.trim() || '';
      
      if (!suffix) {
        alert('접미사를 입력해주세요 (예: 방법, 꿀팁, 추천)');
        return;
      }
      
      // 진행 상태 표시
      const statusDiv = document.getElementById('discoveryStatus');
      const statusText = document.getElementById('statusText');
      const discoveryCount = document.getElementById('discoveryCount');
      const progressBar = document.getElementById('progressBar');
      const progressPercent = document.getElementById('progressPercent');
      const progressStatus = document.getElementById('progressStatus');
      
      statusDiv.style.display = 'block';
      statusText.textContent = `"${suffix}" 관련 키워드 수집 중...`;
      discoveryCount.textContent = '0개';
      progressBar.style.width = '10%';
      progressPercent.textContent = '10%';
      progressStatus.textContent = '네이버 자동완성에서 키워드 수집 중...';
      
      try {
        const result = await window.electron.ipcRenderer.invoke('search-suffix-keywords', {
          suffix: suffix,
          maxResults: 100
        });
        
        if (result.success) {
          progressBar.style.width = '100%';
          progressPercent.textContent = '100%';
          progressStatus.textContent = `완료! ${result.total}개 키워드 발견`;
          discoveryCount.textContent = `${result.total}개`;
          
          // 결과 표시
          discoveryResults = result.keywords.map(kw => ({
            keyword: kw.keyword,
            pcSearchVolume: kw.pcSearchVolume,
            mobileSearchVolume: kw.mobileSearchVolume,
            searchVolume: kw.totalVolume,
            documentCount: kw.documentCount,
            goldenRatio: kw.goldenRatio
          }));
          
          displayResults(discoveryResults);
          
          // 엑셀 내보내기 버튼 표시
          document.getElementById('exportSection').style.display = 'block';
          
          setTimeout(() => {
            statusDiv.style.display = 'none';
          }, 2000);
          
        } else {
          alert(result.message || '키워드 검색에 실패했습니다.');
          statusDiv.style.display = 'none';
        }
        
      } catch (error) {
        console.error('[SUFFIX-SEARCH] 오류:', error);
        alert('키워드 검색 중 오류가 발생했습니다: ' + error.message);
        statusDiv.style.display = 'none';
      }
    };

    // 키워드 발굴 시작 (전역 스코프에 노출)
    window.startKeywordDiscovery = async function startKeywordDiscovery() {
      const keyword = document.getElementById('keywordInput')?.value.trim() || '';
      const category = document.getElementById('keywordCategory')?.value || '';
      
      // 키워드 입력이 없어도 카테고리만 선택하면 가능
      if (!keyword && !category) {
        alert('키워드를 입력하거나 카테고리를 선택해주세요');
        return;
      }

      const source = document.getElementById('keywordSource')?.value || 'naver';
      const limitRadio = document.querySelector('input[name="keywordLimit"]:checked');
      const limitValue = limitRadio?.value || '10';
      const customLimit = document.getElementById('customKeywordLimit')?.value;
      
      // 개수 제한 계산
      let maxCount = null; // null이면 무제한
      if (limitValue === 'unlimited') {
        maxCount = null; // 무제한
      } else if (limitValue === 'custom' && customLimit) {
        maxCount = parseInt(customLimit);
      } else if (limitValue !== 'custom') {
        maxCount = parseInt(limitValue);
      }
      
      if (maxCount !== null && (isNaN(maxCount) || maxCount < 1)) {
        alert('올바른 개수를 입력하세요');
        return;
      }

      const discoveryBtn = document.getElementById('discoveryBtn');
      const stopBtn = document.getElementById('stopBtn');
      const resultsDiv = document.getElementById('goldenResults');
      const statusDiv = document.getElementById('discoveryStatus');
      const statusText = document.getElementById('statusText');
      const countSpan = document.getElementById('discoveryCount');
      const exportSection = document.getElementById('exportSection');
      
      if (!discoveryBtn || !stopBtn || !resultsDiv) return;

      // window.blogger 준비 확인
      let retries = 0;
      while ((!window.blogger || typeof window.blogger.findGoldenKeywords !== 'function') && retries < 50) {
        await new Promise(resolve => setTimeout(resolve, 100));
        retries++;
      }
      
      // 개발 환경에서 핸들러가 없으면 직접 IPC 호출 시도
      if (!window.blogger || typeof window.blogger.findGoldenKeywords !== 'function') {
        console.warn('[KEYWORD-MASTER] window.blogger.findGoldenKeywords가 없습니다.');
        
        // 개발 환경에서는 직접 IPC 호출 가능
        let isDevelopment = false;
        try {
          if (window.electronAPI && typeof window.electronAPI.isPackaged === 'function') {
            const packaged = await window.electronAPI.isPackaged();
            isDevelopment = !packaged;
          } else {
            isDevelopment = true;
          }
        } catch (e) {
          isDevelopment = true;
        }
        
        if (isDevelopment) {
          console.log('[KEYWORD-MASTER] 개발 환경: IPC 직접 호출 시도');
          
          // window.blogger.findGoldenKeywords가 없으면 직접 생성
          window.blogger = window.blogger || {};
          
          // preload에서 노출된 findGoldenKeywords 사용 시도
          if (window.blogger.findGoldenKeywords && typeof window.blogger.findGoldenKeywords === 'function') {
            console.log('[KEYWORD-MASTER] ✅ window.blogger.findGoldenKeywords 발견');
          } else if (typeof sendIPCRequest === 'function') {
            // sendIPCRequest 함수를 직접 사용
            console.log('[KEYWORD-MASTER] sendIPCRequest를 사용하여 함수 생성');
            window.blogger.findGoldenKeywords = async (keyword, options) => {
              try {
                return await sendIPCRequest('find-golden-keywords', keyword, options);
              } catch (error) {
                console.error('[KEYWORD-MASTER] IPC 호출 실패:', error);
                return {
                  error: 'IPC 호출 실패',
                  message: error.message || '키워드 발굴 중 오류가 발생했습니다.',
                  requiresRestart: true
                };
              }
            };
            console.log('[KEYWORD-MASTER] ✅ sendIPCRequest를 통한 래퍼 함수 생성 완료');
          } else if (window.electronAPI && window.electronAPI.findGoldenKeywords) {
            // electronAPI에서 직접 사용
            window.blogger.findGoldenKeywords = window.electronAPI.findGoldenKeywords;
            console.log('[KEYWORD-MASTER] ✅ electronAPI.findGoldenKeywords 사용');
          } else {
            console.error('[KEYWORD-MASTER] ❌ IPC 호출 방법을 찾을 수 없습니다.');
          }
        } else {
        resultsDiv.innerHTML = `<div style="padding: 20px; background: #fee2e2; border-radius: 12px; color: #991b1b; text-align: center;">
          ❌ 오류: window.blogger.findGoldenKeywords를 찾을 수 없습니다.<br>
          콘솔을 확인하거나 앱을 재시작해주세요.
        </div>`;
        return;
        }
      }

      // 발굴 시작
      isDiscovering = true;
      discoveryAbort = false;
      discoveryResults = [];
      
      discoveryBtn.disabled = true;
      discoveryBtn.style.display = 'none';
      stopBtn.style.display = 'block';
      statusDiv.style.display = 'block';
      exportSection.style.display = 'none';
      
      // 초기 상태 설정
      if (statusText) {
        statusText.textContent = '키워드 발굴을 시작합니다...';
      }
      
      // 진행률 초기화
      const progressBar = document.getElementById('progressBar');
      const progressPercent = document.getElementById('progressPercent');
      const progressStatus = document.getElementById('progressStatus');
      if (progressBar) {
        progressBar.style.width = '0%';
      }
      if (progressPercent) {
        progressPercent.textContent = '0%';
      }
      if (progressStatus) {
        progressStatus.textContent = '준비 중...';
      }
      
      resultsDiv.innerHTML = '<div class="loading" style="padding: 20px; text-align: center; color: #667eea;">⏳ 키워드를 검색하고 있습니다...</div>';
      
      try {
        let collectedCount = 0;
        let page = 0;
        const batchSize = 50; // 한 번에 50개씩 수집 (속도 개선)
        
        while (!discoveryAbort && (maxCount === null || collectedCount < maxCount)) {
          // 중지 플래그 확인 (API 호출 전)
          if (discoveryAbort) {
            console.log('[KEYWORD-MASTER] 중지 플래그 감지, 루프 종료');
            break;
          }
          
          if (statusText) {
            statusText.textContent = `발굴 중... (${source === 'naver' ? '네이버' : source === 'google' ? '구글' : '유튜브'}${category ? ' - ' + category : ''})`;
          }
          
          // 배치로 키워드 발굴
          const remainingLimit = maxCount !== null ? Math.min(batchSize, maxCount - collectedCount) : batchSize;
          console.log('[KEYWORD-MASTER] API 호출 시작:', { 
            keyword, 
            source, 
            category, 
            page, 
            limit: remainingLimit,
            collectedCount: collectedCount,
            maxCount: maxCount,
            remaining: maxCount !== null ? maxCount - collectedCount : '무제한'
          });
          
          let batchResults;
          try {
            // 타임아웃 설정 (10분 - 무제한 모드 지원)
            const timeoutDuration = 600000; // 10분
            const timeoutPromise = new Promise((_, reject) => 
              setTimeout(() => reject(new Error(`API 호출 타임아웃 (${timeoutDuration / 1000}초)`)), timeoutDuration)
            );
            
            // 중지 플래그 확인 (API 호출 직전)
            if (discoveryAbort) {
              console.log('[KEYWORD-MASTER] 중지 플래그 감지, API 호출 취소');
              break;
            }
            
            // limit 계산: 남은 개수만큼만 요청 (정확히 제한)
            const remainingLimit = maxCount !== null ? Math.min(batchSize, maxCount - collectedCount) : batchSize;
            
            // limit이 0 이하이면 더 이상 요청하지 않음
            if (maxCount !== null && remainingLimit <= 0) {
              console.log(`[KEYWORD-MASTER] 남은 개수 없음: ${collectedCount}/${maxCount} - API 호출 중단`);
              break;
            }
            
            const apiCall = window.blogger.findGoldenKeywords(keyword, {
            source: source,
            category: category,
            page: page,
            limit: remainingLimit // 정확한 남은 개수만 요청
          });
          
            batchResults = await Promise.race([apiCall, timeoutPromise]);
            console.log('[KEYWORD-MASTER] API 호출 완료:', {
              isArray: Array.isArray(batchResults),
              length: Array.isArray(batchResults) ? batchResults.length : 'N/A',
              type: typeof batchResults,
              hasError: batchResults && batchResults.error,
              hasMessage: batchResults && batchResults.message,
              firstItem: Array.isArray(batchResults) && batchResults.length > 0 ? batchResults[0] : 'N/A',
              fullResult: batchResults
            });
          } catch (apiError) {
            console.error('[KEYWORD-MASTER] API 호출 중 에러:', {
              message: apiError.message,
              stack: apiError.stack,
              name: apiError.name,
              fullError: apiError
            });
            batchResults = {
              error: apiError.message || 'API 호출 실패',
              message: apiError.message || '키워드 발굴 중 오류가 발생했습니다.',
              requiresRestart: false
            };
          }
          
          // 에러 객체인지 확인 (error 속성이 있거나 배열이 아닌 경우)
          if (batchResults && (batchResults.error || (!Array.isArray(batchResults) && typeof batchResults === 'object' && batchResults.message))) {
            // 개발 환경 체크
            let isDevelopment = false;
            try {
              if (window.electronAPI && typeof window.electronAPI.isPackaged === 'function') {
                const packaged = await window.electronAPI.isPackaged();
                isDevelopment = !packaged;
              } else {
                isDevelopment = true;
              }
            } catch (e) {
              isDevelopment = true;
            }
            
            // API 키 관련 에러
            if (batchResults.requiresApiKey && batchResults.apiKeyType === 'naver') {
              resultsDiv.innerHTML = `<div style="padding: 20px; background: #fff3cd; border-radius: 12px; color: #856404; text-align: center;">
                <div style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">⚠️ 네이버 API 키가 필요합니다</div>
                <div style="margin-bottom: 12px;">${batchResults.message || '환경설정에서 네이버 API 키를 등록해주세요.'}</div>
                <button onclick="showTab('settings')" style="margin-top: 10px; padding: 8px 16px; background: #ffc107; color: #000; border: none; border-radius: 6px; cursor: pointer; font-weight: 600;">
                  환경설정 열기
                </button>
              </div>`;
              break;
            }
            
            // 핸들러 로드 실패 에러는 개발 환경에서 완전히 무시
            if (batchResults.requiresRestart) {
              // 개발 환경에서는 완전히 무시하고 계속 진행
              if (isDevelopment) {
                console.warn('[KEYWORD-MASTER] 개발 환경: 핸들러 경고 무시하고 계속 진행');
                // 에러 메시지 표시하지 않고 계속 진행
                // 빈 결과로 처리하여 다음 페이지로 진행하지 않음
                if (page === 0 && (!batchResults || Array.isArray(batchResults) && batchResults.length === 0)) {
                  // 첫 페이지이고 결과가 없으면 조용히 종료
                  break;
                }
                // 그 외에는 계속 진행하지 않음
                continue;
              } else {
                // 배포 환경에서만 에러 표시
                resultsDiv.innerHTML = `<div style="padding: 20px; background: #fee2e2; border-radius: 12px; color: #991b1b; text-align: center;">
                  <div style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">⚠️ 핸들러 로드 실패</div>
                  <div style="margin-bottom: 12px;">${batchResults.message || '키워드 마스터 핸들러가 제대로 로드되지 않았습니다. 앱을 재시작해주세요.'}</div>
                </div>`;
                break;
              }
            }
            
            // 라이선스 에러 (개발 환경이 아닐 때만)
            if (batchResults.requiresUnlimited && !isDevelopment) {
            resultsDiv.innerHTML = `<div style="padding: 20px; background: #fee2e2; border-radius: 12px; color: #991b1b; text-align: center;">
              <div style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">🔒 프리미엄 라이선스가 필요합니다</div>
              <div style="margin-bottom: 12px;">${batchResults.message || '이 기능은 3개월 이상 구매자만 사용할 수 있습니다.'}</div>
            </div>`;
            break;
            }
            
            // 개발 환경에서는 에러를 완전히 무시하고 계속 진행
            if (isDevelopment) {
              // 에러 객체 상세 정보 로깅
              const errorDetails = {
                message: batchResults.message,
                error: batchResults.error,
                requiresApiKey: batchResults.requiresApiKey,
                requiresRestart: batchResults.requiresRestart,
                requiresUnlimited: batchResults.requiresUnlimited,
                apiKeyType: batchResults.apiKeyType,
                fullError: JSON.stringify(batchResults, null, 2)
              };
              console.warn('[KEYWORD-MASTER] 개발 환경: 에러 발생. 상세 정보:', errorDetails);
              
              // 개발 환경에서도 에러 정보는 표시 (디버깅용)
              if (statusText) {
                const errorMsg = batchResults.message || batchResults.error || 
                  (typeof batchResults === 'string' ? batchResults : '알 수 없는 오류');
                statusText.textContent = `에러: ${errorMsg}`;
              }
              // 에러 메시지를 표시하고 종료
              if (!batchResults.requiresApiKey && !batchResults.requiresRestart && !batchResults.requiresUnlimited) {
                // 일반 에러는 UI에 표시
                const errorMsg = batchResults.message || batchResults.error || 
                  (typeof batchResults === 'string' ? batchResults : JSON.stringify(batchResults));
                resultsDiv.innerHTML = `<div style="padding: 20px; background: #fef3c7; border-radius: 12px; color: #92400e; text-align: center;">
                  <div style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">⚠️ 키워드 발굴 중 오류</div>
                  <div style="margin-bottom: 12px;">${errorMsg}</div>
                  <div style="font-size: 12px; color: #78350f; margin-top: 8px;">개발 환경: 콘솔에서 상세 정보를 확인하세요.</div>
                  <pre style="font-size: 10px; margin-top: 8px; background: rgba(0,0,0,0.1); padding: 8px; border-radius: 4px; overflow: auto; max-height: 100px;">${JSON.stringify(batchResults, null, 2)}</pre>
                </div>`;
              }
              // 페이지 증가하지 않고 종료
              if (page > 0) {
                break;
              }
              // 첫 페이지면 계속 시도하지 않음
              break;
            } else {
              // 배포 환경에서 일반 에러 처리
              console.error('[KEYWORD-MASTER] 에러 발생:', batchResults);
              resultsDiv.innerHTML = `<div style="padding: 20px; background: #fee2e2; border-radius: 12px; color: #991b1b; text-align: center;">
                <div style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">❌ 키워드 발굴 실패</div>
                <div style="margin-bottom: 12px;">${batchResults.message || batchResults.error || '알 수 없는 오류가 발생했습니다.'}</div>
              </div>`;
              break;
            }
          }
          
          if (Array.isArray(batchResults) && batchResults.length > 0) {
            // 중복 제거
            let newKeywords = batchResults.filter(item => 
              !discoveryResults.some(existing => existing.keyword === item.keyword)
            );
            
            // maxCount가 설정되어 있으면 정확히 그 개수만 초과하지 않도록 제한
            if (maxCount && collectedCount + newKeywords.length > maxCount) {
              const remainingCount = maxCount - collectedCount;
              if (remainingCount > 0) {
                newKeywords = newKeywords.slice(0, remainingCount);
                console.log(`[KEYWORD-MASTER] 개수 제한 적용: ${newKeywords.length}개만 추가 (남은 개수: ${remainingCount})`);
              } else {
                // 이미 도달했으면 추가하지 않음
                console.log(`[KEYWORD-MASTER] 개수 제한 도달: ${collectedCount}/${maxCount}, 추가 중단`);
                newKeywords = [];
              }
            }
            
            if (newKeywords.length > 0) {
            discoveryResults.push(...newKeywords);
            collectedCount += newKeywords.length;
            
              console.log(`[KEYWORD-MASTER] 새로운 키워드 ${newKeywords.length}개 추가됨. 총 ${discoveryResults.length}개 (제한: ${maxCount || '무제한'})`);
              
              // 카운트 실시간 업데이트
            if (countSpan) {
              countSpan.textContent = `${discoveryResults.length}개`;
            }
            
              // 상태 메시지 실시간 업데이트
              if (statusText) {
                statusText.textContent = `발굴 중... ${discoveryResults.length}개 키워드 발견${maxCount ? ` (목표: ${maxCount}개)` : ''}`;
              }
              
              // 진행률 업데이트
              if (maxCount) {
                const progress = Math.min(100, Math.round((discoveryResults.length / maxCount) * 100));
                const progressBar = document.getElementById('progressBar');
                const progressPercent = document.getElementById('progressPercent');
                const progressStatus = document.getElementById('progressStatus');
                
                if (progressBar) {
                  progressBar.style.width = `${progress}%`;
                }
                if (progressPercent) {
                  progressPercent.textContent = `${progress}%`;
                }
                if (progressStatus) {
                  progressStatus.textContent = `진행 중... (${discoveryResults.length}/${maxCount})`;
                }
                
                // 100% 완료 시 결과 자동 표시
                if (progress >= 100) {
                  console.log('[KEYWORD-MASTER] 진행률 100% 완료, 결과 자동 표시');
                  if (progressStatus) {
                    progressStatus.textContent = '완료!';
                  }
                }
              }
              
              // 결과 실시간 업데이트 (각 배치마다)
            displayGoldenResults(discoveryResults);
              
              // UI 업데이트가 표시되도록 짧은 대기
              await new Promise(resolve => setTimeout(resolve, 50));
            }
            
            // 개수 제한에 도달했으면 중지 (정확히 체크)
            if (maxCount && collectedCount >= maxCount) {
              console.log(`[KEYWORD-MASTER] ✅ 개수 제한 도달: ${collectedCount}/${maxCount} - 검색 종료`);
              break;
            }
            
            // 중지 플래그 확인 (배치 처리 후)
            if (discoveryAbort) {
              console.log('[KEYWORD-MASTER] 중지 플래그 감지, 배치 처리 중단');
              break;
            }
          } else {
            // 더 이상 결과가 없으면 중지
            console.log('[KEYWORD-MASTER] 결과 없음:', { 
              batchResults,
              isArray: Array.isArray(batchResults),
              length: Array.isArray(batchResults) ? batchResults.length : 'N/A',
              type: typeof batchResults,
              page, 
              collectedCount,
              maxCount,
              hasError: batchResults && batchResults.error,
              errorMessage: batchResults && batchResults.message
            });
            
            // 개수 제한에 도달했는지 먼저 확인
            if (maxCount && collectedCount >= maxCount) {
              console.log(`[KEYWORD-MASTER] ✅ 개수 제한 도달: ${collectedCount}/${maxCount} - 검색 종료`);
              break;
            }
            
            // 결과가 없고 페이지가 진행되었으면 중지
            if (page > 0 && (!batchResults || (Array.isArray(batchResults) && batchResults.length === 0))) {
              console.log('[KEYWORD-MASTER] 더 이상 결과가 없어 종료');
              break;
            }
            
            // 첫 페이지에서 결과가 없으면 에러 가능성
            if (page === 0 && (!batchResults || (Array.isArray(batchResults) && batchResults.length === 0))) {
              console.error('[KEYWORD-MASTER] ❌ 첫 페이지에서 결과 없음 - 원인 분석:', {
                keyword: keyword,
                source: source,
                category: category,
                batchResultsType: typeof batchResults,
                batchResultsIsArray: Array.isArray(batchResults),
                batchResultsLength: Array.isArray(batchResults) ? batchResults.length : 'N/A',
                hasError: batchResults && batchResults.error,
                errorMessage: batchResults && batchResults.message,
                fullBatchResults: batchResults
              });
              
              // 에러 메시지가 있는 경우 표시
              if (batchResults && batchResults.message) {
                if (statusText) {
                  statusText.textContent = `오류: ${batchResults.message}`;
                }
                resultsDiv.innerHTML = `<div style="padding: 20px; background: #fee2e2; border-radius: 12px; color: #991b1b; text-align: center;">
                  <div style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">❌ 키워드 발굴 실패</div>
                  <div style="margin-bottom: 12px;">${batchResults.message}</div>
                  <div style="font-size: 14px; color: #78350f;">네이버 API 키를 확인하거나 다른 키워드로 시도해보세요.</div>
                </div>`;
              } else {
                if (statusText) {
                  statusText.textContent = '키워드를 찾을 수 없습니다. 다른 키워드를 시도해보세요.';
                }
              }
              break;
            }
          }
          
          // 개수 제한에 도달했으면 페이지 증가하지 않고 종료
          if (maxCount && collectedCount >= maxCount) {
            console.log(`[KEYWORD-MASTER] ✅ 개수 제한 도달 (페이지 증가 전): ${collectedCount}/${maxCount} - 검색 종료`);
            break;
          }
          
          // 중지 플래그 확인 (페이지 증가 전)
          if (discoveryAbort) {
            console.log('[KEYWORD-MASTER] 중지 플래그 감지, 페이지 증가 중단');
            break;
          }
          
          page++;
          
          // API 호출 제한을 위한 대기 (1초)
          await new Promise(resolve => setTimeout(resolve, 1000));
        }
        
        // 결과 표시 및 정리
        // 진행률 100%로 설정
        if (maxCount) {
          const progressBar = document.getElementById('progressBar');
          const progressPercent = document.getElementById('progressPercent');
          const progressStatus = document.getElementById('progressStatus');
          
          if (progressBar) {
            progressBar.style.width = '100%';
          }
          if (progressPercent) {
            progressPercent.textContent = '100%';
          }
          if (progressStatus) {
            progressStatus.textContent = '완료!';
          }
        }
        
        if (discoveryResults.length > 0) {
          exportSection.style.display = 'block';
        if (statusText) {
          statusText.textContent = `발굴 완료! 총 ${discoveryResults.length}개 키워드를 발굴했습니다.`;
          }
          // resultsDiv는 displayGoldenResults에서 업데이트됨
        } else {
          // 결과가 없을 때
          if (statusText) {
            statusText.textContent = '발굴 완료! 총 0개 키워드를 발굴했습니다.';
          }
          // 에러가 아닌 경우에만 결과 없음 메시지 표시
          if (!resultsDiv.innerHTML.includes('오류') && !resultsDiv.innerHTML.includes('에러') && !resultsDiv.innerHTML.includes('실패')) {
            resultsDiv.innerHTML = `<div style="padding: 20px; background: #fef3c7; border-radius: 12px; color: #92400e; text-align: center;">
              <div style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">🔍 키워드를 찾을 수 없습니다</div>
              <div style="margin-bottom: 12px;">입력하신 키워드 "${keyword}"에 대한 연관 키워드를 찾을 수 없습니다.</div>
              <div style="font-size: 14px; color: #78350f;">다른 키워드로 시도해보시거나 네이버 API 키 설정을 확인해주세요.</div>
            </div>`;
          }
        }
        
      } catch (error) {
        console.error('키워드 발굴 실패:', error);
        if (statusText) {
          statusText.textContent = '발굴 실패';
        }
        resultsDiv.innerHTML = `<div style="padding: 20px; background: #fee2e2; border-radius: 12px; color: #991b1b; text-align: center;">
          <div style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">❌ 키워드 발굴 실패</div>
          <div style="margin-bottom: 12px;">${error.message || '키워드 발굴에 실패했습니다'}</div>
        </div>`;
      } finally {
        // UI 복원
        isDiscovering = false;
        const discoveryBtn = document.getElementById('discoveryBtn');
        const stopBtn = document.getElementById('stopBtn');
        if (discoveryBtn) {
        discoveryBtn.disabled = false;
        discoveryBtn.style.display = 'block';
        }
        if (stopBtn) {
        stopBtn.style.display = 'none';
      }
    }
    };

    // 키워드 발굴 중지 함수 (전역 스코프에 노출)
    window.stopKeywordDiscovery = async function stopKeywordDiscovery() {
      console.log('[KEYWORD-MASTER] ⏹️ 중지 버튼 클릭됨');
      discoveryAbort = true;
      isDiscovering = false;
      
      // 백엔드에도 중지 신호 전송
      try {
        if (window.blogger && window.blogger.stopKeywordDiscovery) {
          await window.blogger.stopKeywordDiscovery(keyword);
          console.log('[KEYWORD-MASTER] 백엔드 중지 신호 전송 완료');
        }
      } catch (err) {
        console.error('[KEYWORD-MASTER] 백엔드 중지 신호 전송 실패:', err);
      }
      
      const discoveryBtn = document.getElementById('discoveryBtn');
      const stopBtn = document.getElementById('stopBtn');
      const statusText = document.getElementById('statusText');
      const resultsDiv = document.getElementById('goldenResults');
      
      if (discoveryBtn) {
        discoveryBtn.disabled = false;
        discoveryBtn.style.display = 'block';
      }
      if (stopBtn) {
        stopBtn.style.display = 'none';
      }
      if (statusText) {
        statusText.textContent = '⏹️ 발굴이 중지되었습니다.';
      }
      if (resultsDiv && resultsDiv.innerHTML.includes('loading')) {
        resultsDiv.innerHTML = '<div style="padding: 20px; text-align: center; color: #ef4444;">⏹️ 사용자가 발굴을 중지했습니다.</div>';
    }
      
      console.log('[KEYWORD-MASTER] ✅ 키워드 발굴 중지 완료');
    };


    function displayGoldenResults(results) {
      const resultsDiv = document.getElementById('goldenResults');
      
      if (!resultsDiv) {
        console.error('[KEYWORD-MASTER] goldenResults 요소를 찾을 수 없습니다.');
        return;
      }
      
      // 에러 응답 체크
      if (!Array.isArray(results)) {
        if (results && results.error) {
          resultsDiv.innerHTML = `<div style="padding: 20px; background: #fee2e2; border-radius: 12px; color: #991b1b; text-align: center;">
            <div style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">🔒 프리미엄 라이선스가 필요합니다</div>
            <div style="margin-bottom: 12px;">${results.message || '이 기능은 3개월 이상 구매자만 사용할 수 있습니다.'}</div>
          </div>`;
          return;
        }
        resultsDiv.innerHTML = '<div class="loading">발굴된 키워드가 없습니다.</div>';
        return;
      }
      
      if (!results || results.length === 0) {
        resultsDiv.innerHTML = '<div class="loading">발굴된 키워드가 없습니다.</div>';
        return;
      }
      
      console.log(`[KEYWORD-MASTER] displayGoldenResults 호출: ${results.length}개 키워드 표시`);

      // 테이블 형식으로 결과 표시
      let html = `
        <div style="margin-bottom: 16px; font-size: 18px; font-weight: 700; color: #92400e;">🎯 발굴 결과 (${results.length}개)</div>
        <div style="overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse; background: white; border-radius: 12px; overflow: hidden;">
            <thead>
              <tr style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                <th style="padding: 12px; text-align: left; font-weight: 700; border-bottom: 2px solid rgba(255,255,255,0.2);">순위</th>
                <th style="padding: 12px; text-align: left; font-weight: 700; border-bottom: 2px solid rgba(255,255,255,0.2);">키워드</th>
                <th style="padding: 12px; text-align: right; font-weight: 700; border-bottom: 2px solid rgba(255,255,255,0.2);">PC 검색량</th>
                <th style="padding: 12px; text-align: right; font-weight: 700; border-bottom: 2px solid rgba(255,255,255,0.2);">모바일 검색량</th>
                <th style="padding: 12px; text-align: right; font-weight: 700; border-bottom: 2px solid rgba(255,255,255,0.2);">검색량 합산</th>
                <th style="padding: 12px; text-align: right; font-weight: 700; border-bottom: 2px solid rgba(255,255,255,0.2);">문서량</th>
                <th style="padding: 12px; text-align: right; font-weight: 700; border-bottom: 2px solid rgba(255,255,255,0.2);">황금비율</th>
                <th style="padding: 12px; text-align: center; font-weight: 700; border-bottom: 2px solid rgba(255,255,255,0.2);">검색</th>
              </tr>
            </thead>
            <tbody>
      `;
      
      results.forEach((item, idx) => {
        const pcVolume = item.pcSearchVolume || item.searchVolumePC || 0;
        const mobileVolume = item.mobileSearchVolume || item.searchVolumeMobile || 0;
        const totalVolume = pcVolume + mobileVolume;
        const docCount = item.documentCount || 0;
        // 황금비율: 검색량 ÷ 문서량 (높을수록 좋음 - 검색량 많고 문서수 적음)
        // 새 계산 방식: 검색량/문서량 = 높을수록 황금키워드
        let goldenRatio;
        let goldenRatioDisplay;
        if (docCount > 0 && totalVolume > 0) {
          goldenRatio = totalVolume / docCount; // 검색량/문서수 (높을수록 좋음)
          goldenRatioDisplay = goldenRatio.toFixed(2);
        } else if (docCount === 0 && totalVolume > 0) {
          // 문서량 0 = 초황금 (경쟁자 없음)
          goldenRatio = 9999;
          goldenRatioDisplay = '∞ (초황금)';
        } else {
          goldenRatio = 0;
          goldenRatioDisplay = '-';
        }
        
        // 황금비율 색상 (높을수록 좋음)
        let goldenRatioColor = '#64748b';
        if (goldenRatio >= 100) goldenRatioColor = '#10b981'; // 최고 - 초록
        else if (goldenRatio >= 50) goldenRatioColor = '#22c55e'; // 매우 좋음 - 연두
        else if (goldenRatio >= 10) goldenRatioColor = '#fbbf24'; // 좋음 - 노랑
        else if (goldenRatio >= 1) goldenRatioColor = '#f59e0b'; // 보통 - 주황
        else goldenRatioColor = '#ef4444'; // 나쁨 - 빨강
        
        html += `
          <tr style="border-bottom: 1px solid #e0e0e0; transition: background 0.2s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='white'">
            <td style="padding: 12px; font-weight: 700; color: #667eea;">${idx + 1}</td>
            <td style="padding: 12px; font-weight: 600; color: #1e293b;">${item.keyword || ''}</td>
            <td style="padding: 12px; text-align: right; font-weight: 700; color: #1e293b;">${pcVolume.toLocaleString()}</td>
            <td style="padding: 12px; text-align: right; font-weight: 700; color: #1e293b;">${mobileVolume.toLocaleString()}</td>
            <td style="padding: 12px; text-align: right; font-weight: 700; color: #1e293b;">${totalVolume.toLocaleString()}</td>
            <td style="padding: 12px; text-align: right; font-weight: 700; color: #1e293b;">${docCount.toLocaleString()}</td>
            <td style="padding: 12px; text-align: right; color: ${goldenRatioColor}; font-weight: 700;">${goldenRatioDisplay}</td>
            <td style="padding: 12px; text-align: center;">
              <button onclick="window.blogger.openExternal('https://search.naver.com/search.naver?query=' + encodeURIComponent('${item.keyword || ''}'))" 
                style="padding: 6px 12px; background: #3b82f6; color: white; border: none; border-radius: 6px; cursor: pointer; font-weight: 600; font-size: 12px;">
                검색
              </button>
            </td>
          </tr>
        `;
      });
      
      html += `
            </tbody>
          </table>
        </div>
      `;
      
      resultsDiv.innerHTML = html;
    }

    // 엑셀로 내보내기
    async function exportToExcel() {
      if (!discoveryResults || discoveryResults.length === 0) {
        alert('내보낼 키워드가 없습니다.');
        return;
      }

      try {
        // CSV 형식으로 변환
        const headers = ['순위', '키워드', 'PC 검색량', '모바일 검색량', '검색량 합산', '문서량', '황금비율'];
        
        const rows = discoveryResults.map((item, idx) => {
          const pcVolume = item.pcSearchVolume || item.searchVolumePC || 0;
          const mobileVolume = item.mobileSearchVolume || item.searchVolumeMobile || 0;
          const totalVolume = pcVolume + mobileVolume;
          const docCount = item.documentCount || 0;
          // 검색량/문서수 (높을수록 좋음)
          let goldenRatio;
          if (docCount > 0 && totalVolume > 0) {
            goldenRatio = (totalVolume / docCount).toFixed(2);
          } else if (docCount === 0 && totalVolume > 0) {
            goldenRatio = '∞';
          } else {
            goldenRatio = '-';
          }
          
          return [
            idx + 1,
            item.keyword || '',
            pcVolume,
            mobileVolume,
            totalVolume,
            docCount,
            goldenRatio
          ];
        });

        // CSV 문자열 생성
        const csvContent = [
          headers.join(','),
          ...rows.map(row => row.map(cell => `"${String(cell).replace(/"/g, '""')}"`).join(','))
        ].join('\n');

        // BOM 추가 (Excel에서 한글 깨짐 방지)
        const BOM = '\uFEFF';
        const blob = new Blob([BOM + csvContent], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = `키워드_발굴_결과_${new Date().toISOString().slice(0, 10)}.csv`;
        link.click();
        URL.revokeObjectURL(url);
        
        alert(`엑셀 파일로 내보내기가 완료되었습니다. (${discoveryResults.length}개 키워드)`);
      } catch (error) {
        console.error('엑셀 내보내기 실패:', error);
        alert('엑셀 내보내기 중 오류가 발생했습니다.');
      }
    }

    // ========================================
    // 라이선스 관리
    // ========================================
    let currentLicenseInfo = null;

    async function checkLicenseStatus(autoLogin = true) {
      try {
        console.log('[LICENSE] 라이선스 상태 확인 시작...');
        const result = await window.blogger.getLicenseInfo();
        currentLicenseInfo = result;
        
        const badge = document.getElementById('licenseBadge');
        
        if (!badge) {
          console.warn('[LICENSE] licenseBadge 요소를 찾을 수 없습니다.');
          return result;
        }
        
        if (result.isUnlimited) {
          // 무제한 라이선스 (관리자)
          console.log('[LICENSE] ✅ 무제한 사용자:', result.userId);
          badge.style.background = 'linear-gradient(135deg, #c084fc 0%, #a855f7 100%)';
          badge.style.color = '#ffffff';
          badge.querySelector('span:first-child').textContent = '💎';
          badge.querySelector('span:last-child').textContent = `무제한: ${result.userId || '관리자'}`;
          enableAllFeatures(); // 모든 기능 활성화
        } else if (result.isPremium) {
          // 3개월 이상 프리미엄 사용자
          console.log('[LICENSE] ✅ 프리미엄 사용자:', result.userId);
          badge.style.background = 'linear-gradient(135deg, #fef3c7 0%, #fcd34d 100%)';
          badge.style.color = '#92400e';
          badge.querySelector('span:first-child').textContent = '👑';
          badge.querySelector('span:last-child').textContent = `프리미엄: ${result.userId || '인증됨'}`;
          if (result.expiresAt) {
            const daysLeft = Math.ceil((new Date(result.expiresAt) - new Date()) / (1000 * 60 * 60 * 24));
            badge.querySelector('span:last-child').textContent += ` (${daysLeft}일 남음)`;
          }
          enableAllFeatures(); // 모든 기능 활성화
        } else if (result.hasLicense) {
          // 1개월 사용자 (기본 기능만)
          console.log('[LICENSE] ✅ 1개월 사용자:', result.userId);
          badge.style.background = 'linear-gradient(135deg, #dbeafe 0%, #93c5fd 100%)';
          badge.style.color = '#1e40af';
          badge.querySelector('span:first-child').textContent = '✅';
          badge.querySelector('span:last-child').textContent = `1개월: ${result.userId || '인증됨'}`;
          if (result.expiresAt) {
            const daysLeft = Math.ceil((new Date(result.expiresAt) - new Date()) / (1000 * 60 * 60 * 24));
            badge.querySelector('span:last-child').textContent += ` (${daysLeft}일 남음)`;
          }
          enableBasicFeatures(); // 기본 기능만 활성화 (프리미엄 제외)
        } else {
          // 라이선스 없음 - 앱 시작 시 인증창이 뜨므로 여기에 오면 안됨
          console.log('[LICENSE] ⚠️ 라이선스 없음');
          badge.style.background = 'linear-gradient(135deg, #fee2e2 0%, #fecaca 100%)';
          badge.style.color = '#991b1b';
          badge.querySelector('span:first-child').textContent = '⚠️';
          badge.querySelector('span:last-child').textContent = '라이선스 필요';
          disableAllFeatures();
        }
        
        return result;
      } catch (error) {
        console.error('[LICENSE] 라이선스 확인 실패:', error);
        disableAllFeatures();
        return { hasLicense: false, isPremium: false };
      }
    }
    
    function enableAllFeatures() {
      // 모든 기능 버튼 활성화
      document.querySelectorAll('.feature-button, button[onclick*="openModal"]').forEach(btn => {
        if (btn && btn.style) {
          btn.style.opacity = '1';
          btn.style.pointerEvents = 'auto';
          btn.style.cursor = 'pointer';
        }
      });
    }
    
    function enableBasicFeatures() {
      // 무료 사용자: 기본 기능만 활성화
      document.querySelectorAll('.feature-button, button[onclick*="openModal"]').forEach(btn => {
        if (btn && btn.style) {
          btn.style.opacity = '1';
          btn.style.pointerEvents = 'auto';
          btn.style.cursor = 'pointer';
        }
      });
      // 실시간 검색어는 무료 사용자도 볼 수 있음
    }
    
    function disableAllFeatures() {
      // 모든 기능 버튼 비활성화
      document.querySelectorAll('.feature-button, button[onclick*="openModal"]').forEach(btn => {
        if (btn && btn.style) {
          btn.style.opacity = '0.5';
          btn.style.pointerEvents = 'none';
          btn.style.cursor = 'not-allowed';
        }
      });
      
      // 실시간 검색어 영역 숨기기
      const realtimeSection = document.querySelector('.realtime-section');
      if (realtimeSection && realtimeSection.style) {
        realtimeSection.style.display = 'none';
      }
    }

