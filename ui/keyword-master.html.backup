    function createGoldenFromRelatedModal() {
      const container = document.getElementById('modalContainer');
      container.innerHTML = `
        <div class="modal-overlay" onclick="closeModal()">
          <div class="modal-content" onclick="event.stopPropagation()" style="max-width: 1000px; width: 95%;">
            <div class="modal-header">
              <div style="display: flex; align-items: center; gap: 12px;">
                <span style="font-size: 32px;">🔍</span>
                <h2 style="margin: 0; font-size: 24px; font-weight: 700; color: #1e293b;">연상 키워드 → 황금키워드</h2>
              </div>
              <button class="modal-close" onclick="closeModal()">&times;</button>
            </div>

            <div style="padding: 32px;">
              <div style="padding: 20px; background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border-radius: 16px; border-left: 4px solid #f59e0b; margin-bottom: 24px;">
                <div style="font-size: 16px; font-weight: 700; color: #92400e; margin-bottom: 8px;">💡 연관 키워드에서 황금키워드 발굴</div>
                <div style="font-size: 14px; color: #78350f; line-height: 1.6;">
                  입력한 키워드의 연관/연상 키워드를 분석하여<br>
                  <strong>경쟁은 낮고 검색량은 높은 황금키워드</strong>를 자동으로 찾아드립니다!
                </div>
              </div>

              <div style="display: flex; gap: 12px; margin-bottom: 24px;">
                <input type="text" id="goldenRelatedInput" placeholder="기본 키워드 입력 (예: 다이어트, 맛집, 여행)" 
                  style="flex: 1; padding: 16px 20px; border: 2px solid #e2e8f0; border-radius: 12px; font-size: 16px; font-weight: 600;"
                  onkeypress="if(event.key==='Enter') huntGoldenFromRelated()">
                <button onclick="huntGoldenFromRelated()" id="goldenRelatedBtn"
                  style="padding: 16px 32px; background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: white; border: none; border-radius: 12px; font-size: 16px; font-weight: 700; cursor: pointer; white-space: nowrap; box-shadow: 0 4px 12px rgba(217, 119, 6, 0.3); transition: all 0.3s;"
                  onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
                  🔍 황금키워드 찾기
                  </button>
              </div>

              <div id="goldenRelatedResults" style="min-height: 300px;">
                <div style="text-align: center; padding: 60px 20px; color: #94a3b8;">
                  <div style="font-size: 48px; margin-bottom: 16px;">🔍</div>
                  <div style="font-size: 16px; font-weight: 600;">키워드를 입력하고 황금키워드를 찾아보세요!</div>
                  <div style="font-size: 14px; margin-top: 8px;">연관 키워드 분석을 통해 숨겨진 기회를 발견합니다</div>
                  </div>
                  </div>
                </div>
          </div>
        </div>
      `;
    }

    // 연상 키워드 기반 황금키워드 찾기
    async function huntGoldenFromRelated() {
      const input = document.getElementById('goldenRelatedInput');
      const btn = document.getElementById('goldenRelatedBtn');
      const resultsDiv = document.getElementById('goldenRelatedResults');
      
      const keyword = input.value.trim();
      if (!keyword) {
        alert('키워드를 입력해주세요.');
        return;
      }
      
      btn.disabled = true;
      btn.textContent = '🔄 분석 중...';
      
      resultsDiv.innerHTML = `
        <div style="text-align: center; padding: 60px 20px;">
          <div style="width: 48px; height: 48px; border: 4px solid #f59e0b; border-top-color: transparent; border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto 16px;"></div>
          <div style="font-size: 16px; font-weight: 600; color: #92400e;">연관 키워드 분석 중...</div>
          <div style="font-size: 14px; color: #78350f; margin-top: 8px;">약 10-30초 소요됩니다</div>
                  </div>
        <style>@keyframes spin { to { transform: rotate(360deg); } }</style>
      `;
      
      try {
        const result = await sendIPCRequest('hunt-golden-from-related', keyword);
        
        if (result.error) {
          resultsDiv.innerHTML = `
            <div style="text-align: center; padding: 40px; background: #fef2f2; border-radius: 12px;">
              <div style="font-size: 32px; margin-bottom: 12px;">⚠️</div>
              <div style="font-size: 16px; font-weight: 600; color: #991b1b;">${result.message || result.error}</div>
                  </div>
          `;
          return;
        }
        
        if (!result.goldenKeywords || result.goldenKeywords.length === 0) {
          resultsDiv.innerHTML = `
            <div style="text-align: center; padding: 40px; background: #fef3c7; border-radius: 12px;">
              <div style="font-size: 32px; margin-bottom: 12px;">🔍</div>
              <div style="font-size: 16px; font-weight: 600; color: #92400e;">황금 키워드를 찾지 못했습니다</div>
              <div style="font-size: 14px; color: #78350f; margin-top: 8px;">다른 키워드로 시도해보세요</div>
                </div>
          `;
          return;
        }
        
        // 결과 표시
        let html = `
          <div style="margin-bottom: 20px; padding: 16px; background: #d1fae5; border-radius: 12px; display: flex; align-items: center; gap: 12px;">
            <span style="font-size: 24px;">🎉</span>
            <div>
              <div style="font-weight: 700; color: #065f46;">"${keyword}"에서 ${result.goldenKeywords.length}개의 황금 키워드 발견!</div>
              <div style="font-size: 13px; color: #047857;">총 ${result.totalAnalyzed}개 연관 키워드 분석 완료</div>
                  </div>
                  </div>
          
          <div style="display: grid; gap: 12px;">
        `;
        
        result.goldenKeywords.forEach((kw, index) => {
          const bgColor = kw.type.includes('초황금') ? '#fef3c7' : 
                         kw.type.includes('황금') ? '#d1fae5' : '#f0f9ff';
          const borderColor = kw.type.includes('초황금') ? '#f59e0b' : 
                             kw.type.includes('황금') ? '#10b981' : '#3b82f6';
          
          html += `
            <div style="background: ${bgColor}; border-radius: 12px; padding: 16px; border-left: 4px solid ${borderColor}; cursor: pointer; transition: all 0.3s;"
              onmouseover="this.style.transform='translateX(4px)'" onmouseout="this.style.transform='translateX(0)'"
              onclick="copyToClipboard('${kw.keyword}')">
              <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
                <div style="display: flex; align-items: center; gap: 8px;">
                  <span style="font-size: 14px;">${kw.type}</span>
                  <span style="font-size: 16px; font-weight: 700; color: #1e293b;">${kw.keyword}</span>
                </div>
                <span style="padding: 4px 12px; background: white; border-radius: 8px; font-size: 12px; font-weight: 700; color: #1e293b;">
                  점수: ${kw.score}점
                </span>
              </div>
              <div style="font-size: 13px; color: #64748b; margin-bottom: 8px;">${kw.description}</div>
              <div style="display: flex; gap: 16px; font-size: 12px; color: #94a3b8;">
                <span>📊 검색량: ${kw.searchVolume.toLocaleString()}회</span>
                <span>📝 문서수: ${kw.documentCount.toLocaleString()}개</span>
                <span>⚖️ 황금비율: ${kw.goldenRatio}</span>
              </div>
            </div>
          `;
        });
        
        html += `</div>`;
        resultsDiv.innerHTML = html;
        
      } catch (error) {
        console.error('황금키워드 찾기 오류:', error);
        resultsDiv.innerHTML = `
          <div style="text-align: center; padding: 40px; background: #fef2f2; border-radius: 12px;">
            <div style="font-size: 32px; margin-bottom: 12px;">❌</div>
            <div style="font-size: 16px; font-weight: 600; color: #991b1b;">오류가 발생했습니다</div>
            <div style="font-size: 14px; color: #dc2626; margin-top: 8px;">${error.message || '잠시 후 다시 시도해주세요'}</div>
                  </div>
        `;
      } finally {
        btn.disabled = false;
        btn.textContent = '🔍 황금키워드 찾기';
      }
    }

    // ===== 🏆 PRO 트래픽 키워드 헌터 =====
    const PRO_TRAFFIC_CATEGORIES = [
      { value: 'all', label: '📌 전체 (추천)' },
      { value: 'life', label: '🏠 생활/살림' },
      { value: 'travel', label: '✈️ 여행' },
      { value: 'food', label: '🍽️ 음식/맛집' },
      { value: 'tech', label: '📱 IT/테크' },
      { value: 'beauty', label: '💄 뷰티' },
      { value: 'health', label: '💪 건강/운동' },
      { value: 'finance', label: '💰 재테크' },
      { value: 'education', label: '📚 교육/자격증' },
      { value: 'entertainment', label: '🎬 엔터테인먼트' }
    ];

    function openProTrafficModal() {
      const existingModal = document.getElementById('proTrafficModal');
      if (existingModal) existingModal.remove();
      
      const modal = document.createElement('div');
      modal.id = 'proTrafficModal';
      modal.style.cssText = 'display: flex; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.85); z-index: 10000; backdrop-filter: blur(8px); overflow-y: auto; padding: 20px; box-sizing: border-box; align-items: flex-start; justify-content: center;';
      
      modal.innerHTML = `
        <div style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); border-radius: 24px; padding: 32px; max-width: 1000px; width: 100%; margin: 20px auto; box-shadow: 0 25px 80px rgba(0, 0, 0, 0.6); border: 2px solid rgba(234, 179, 8, 0.3); position: relative; max-height: calc(100vh - 40px); overflow-y: auto;">
          <button onclick="closeProTrafficModal()" style="position: absolute; top: 16px; right: 16px; width: 40px; height: 40px; background: rgba(255, 255, 255, 0.1); border: none; border-radius: 50%; color: white; font-size: 20px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease; z-index: 10;" onmouseover="this.style.background='rgba(255, 255, 255, 0.2)'" onmouseout="this.style.background='rgba(255, 255, 255, 0.1)'">✕</button>
          
          <div style="text-align: center; margin-bottom: 28px;">
            <div style="display: inline-block; background: linear-gradient(135deg, #7c3aed 0%, #5b21b6 100%); padding: 6px 16px; border-radius: 20px; font-size: 12px; font-weight: 800; color: white; margin-bottom: 12px;">💎 영구제 라이선스 전용</div>
            <h2 style="font-size: 28px; font-weight: 800; background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin: 0 0 8px 0;">🏆 PRO 트래픽 키워드 헌터 <span style="font-size: 16px; color: #7c3aed;">끝판왕</span></h2>
            <p style="font-size: 14px; color: rgba(255, 255, 255, 0.7); margin: 0;">10개 데이터 소스 · 8단계 확장 · 3차 재귀분석 · 2,000개 키워드 분석</p>
                  </div>
          
          <!-- 🎯 선별 기준 안내 -->
          <div style="background: rgba(34, 197, 94, 0.1); border-radius: 12px; padding: 14px; margin-bottom: 20px; border: 1px solid rgba(34, 197, 94, 0.2);">
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
              <span style="font-size: 16px;">📊</span>
              <span style="font-weight: 700; color: #22c55e; font-size: 13px;">황금 키워드 선별 기준 (높을수록 상위노출 쉬움!)</span>
            </div>
            <div style="display: flex; flex-wrap: wrap; gap: 8px; font-size: 11px;">
              <span style="background: rgba(255,255,255,0.1); padding: 4px 10px; border-radius: 6px; color: rgba(255,255,255,0.9);">💎 <strong style="color: #fbbf24;">황금비율</strong> = 검색량÷문서수 (10+최고, 5+좋음, 1미만 경쟁치열)</span>
              <span style="background: rgba(255,255,255,0.1); padding: 4px 10px; border-radius: 6px; color: rgba(255,255,255,0.9);">🏆 <strong style="color: #ff6b9d;">SSS등급</strong>: 황금비율10+ & 문서1만↓</span>
              <span style="background: rgba(255,255,255,0.1); padding: 4px 10px; border-radius: 6px; color: rgba(255,255,255,0.9);">🌊 <strong style="color: #3b82f6;">블루오션</strong>: 검색량100+ & 문서5천↓ & 비율0.05+</span>
            </div>
          </div>
          
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px;">
            <div style="background: rgba(255, 255, 255, 0.05); border-radius: 14px; padding: 16px; border: 1px solid rgba(255, 255, 255, 0.1);">
              <label style="font-size: 13px; font-weight: 700; color: #fbbf24; display: block; margin-bottom: 10px;">📁 카테고리</label>
              <select id="proTrafficCategory" style="width: 100%; padding: 12px 14px; border: 2px solid rgba(234, 179, 8, 0.3); border-radius: 10px; font-size: 14px; background: rgba(30, 41, 59, 0.8); color: white; cursor: pointer; outline: none;">
                ${PRO_TRAFFIC_CATEGORIES.map(c => `<option value="${c.value}">${c.label}</option>`).join('')}
              </select>
                </div>

            <div style="background: rgba(255, 255, 255, 0.05); border-radius: 14px; padding: 16px; border: 1px solid rgba(255, 255, 255, 0.1);">
              <label style="font-size: 13px; font-weight: 700; color: #fbbf24; display: block; margin-bottom: 10px;">🎯 추가 시드 키워드 (선택)</label>
              <input id="proTrafficSeeds" type="text" placeholder="예: 여행, 맛집 (쉼표로 구분)" style="width: 100%; padding: 12px 14px; border: 2px solid rgba(234, 179, 8, 0.3); border-radius: 10px; font-size: 14px; background: rgba(30, 41, 59, 0.8); color: white; outline: none; box-sizing: border-box;">
                  </div>
                  </div>
          
          <div style="display: flex; gap: 16px; margin-bottom: 20px; align-items: center; justify-content: center; flex-wrap: wrap;">
            <label style="display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.8); font-size: 14px; cursor: pointer;">
              <input type="checkbox" id="proTrafficRookie" checked style="width: 18px; height: 18px; accent-color: #fbbf24;">
              🆕 신생 블로거 우선
            </label>
            <label style="display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.8); font-size: 14px; cursor: pointer;">
              <input type="checkbox" id="proTrafficSeason" checked style="width: 18px; height: 18px; accent-color: #fbbf24;">
              🌸 시즌 키워드 포함
            </label>
            <select id="proTrafficCount" style="padding: 8px 14px; border: 2px solid rgba(234, 179, 8, 0.3); border-radius: 8px; font-size: 13px; background: rgba(30, 41, 59, 0.8); color: white; cursor: pointer; outline: none;">
              <option value="10">10개</option>
              <option value="20" selected>20개</option>
              <option value="30">30개</option>
            </select>
                </div>

          <button id="proTrafficBtn" onclick="huntProTrafficKeywords()" style="width: 100%; padding: 16px; background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%); border: none; border-radius: 12px; font-size: 17px; font-weight: 700; color: #1a1a2e; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 4px 20px rgba(251, 191, 36, 0.4);" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 30px rgba(251, 191, 36, 0.5)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 20px rgba(251, 191, 36, 0.4)';">
            🏆 황금 키워드 헌팅 시작
          </button>
          
          <div style="margin-top: 14px; padding: 10px 14px; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3); border-radius: 8px;">
            <p style="font-size: 11px; color: #f87171; margin: 0; line-height: 1.5;">
              ⚠️ <strong>주의:</strong> 모든 수치는 <strong>추정치</strong>이며 실제와 다를 수 있습니다. 상위노출과 트래픽은 콘텐츠 품질, 블로그 지수, 경쟁 상황에 따라 달라집니다.
            </p>
                  </div>
          
          <div id="proTrafficResults" style="margin-top: 24px;"></div>
                  </div>
      `;
      
      document.body.appendChild(modal);
      modal.addEventListener('click', (e) => {
        if (e.target === modal) closeProTrafficModal();
      });
    }
    
    function closeProTrafficModal() {
      const modal = document.getElementById('proTrafficModal');
      if (modal) modal.remove();
    }
    
    // 🔥 PRO 트래픽 헌터 전역 변수
    let proTrafficAllKeywords = [];
    let proTrafficDisplayIndex = 0;
    let proTrafficSummary = null;
    const PRO_TRAFFIC_PAGE_SIZE = 10;
    
    async function huntProTrafficKeywords(isRefresh = true) {
      const category = document.getElementById('proTrafficCategory').value;
      const seedsInput = document.getElementById('proTrafficSeeds').value;
      const targetRookie = document.getElementById('proTrafficRookie').checked;
      const includeSeason = document.getElementById('proTrafficSeason').checked;
      const btn = document.getElementById('proTrafficBtn');
      const resultsDiv = document.getElementById('proTrafficResults');
      
      const seedKeywords = seedsInput ? seedsInput.split(',').map(s => s.trim()).filter(s => s) : [];
      
      // 새로고침 시 초기화
      if (isRefresh) {
        proTrafficAllKeywords = [];
        proTrafficDisplayIndex = 0;
        proTrafficSummary = null;
      }
      
      btn.disabled = true;
      btn.innerHTML = '<span style="display: inline-block; animation: spin 1s linear infinite;">🔄</span> 헌팅 중...';
      
      // 🔥 진행률 로그 표시
      resultsDiv.innerHTML = `
        <div style="background: rgba(30, 41, 59, 0.9); border-radius: 16px; padding: 24px; border: 1px solid rgba(251, 191, 36, 0.3);">
          <div style="text-align: center; margin-bottom: 20px;">
            <div style="font-size: 48px; margin-bottom: 12px;">🏆</div>
            <div style="font-size: 16px; font-weight: 600; color: #fbbf24;">끝판왕 PRO 키워드 헌팅 중...</div>
          </div>
          
          <!-- 진행률 바 -->
          <div style="margin-bottom: 20px;">
            <div style="background: rgba(255,255,255,0.1); border-radius: 8px; height: 12px; overflow: hidden;">
              <div id="proProgressBar" style="background: linear-gradient(90deg, #fbbf24, #f59e0b); height: 100%; width: 0%; transition: width 0.5s ease; border-radius: 8px;"></div>
            </div>
            <div id="proProgressText" style="text-align: center; font-size: 12px; color: rgba(255,255,255,0.7); margin-top: 8px;">0% 완료</div>
          </div>
          
          <!-- 로그 -->
          <div id="proProgressLog" style="background: rgba(0,0,0,0.3); border-radius: 8px; padding: 12px; max-height: 200px; overflow-y: auto; font-family: monospace; font-size: 11px; color: rgba(255,255,255,0.7);">
            <div style="color: #22c55e;">✓ 시작: 실시간 트렌드 수집 중...</div>
          </div>
        </div>
      `;
      
      // 진행률 시뮬레이션
      const progressBar = document.getElementById('proProgressBar');
      const progressText = document.getElementById('proProgressText');
      const progressLog = document.getElementById('proProgressLog');
      
      const progressSteps = [
        { percent: 10, message: '🔥 Signal.bz 실시간 검색어 수집 중...' },
        { percent: 20, message: '🔥 Zum 실시간 검색어 수집 중...' },
        { percent: 30, message: '🔥 Daum 실시간 검색어 수집 중...' },
        { percent: 40, message: '🔥 Nate 실시간 검색어 수집 중...' },
        { percent: 50, message: '📰 네이버 뉴스 헤드라인 분석 중...' },
        { percent: 60, message: '📋 정책브리핑 키워드 수집 중...' },
        { percent: 70, message: '🔍 네이버 검색광고 API 연관키워드 수집 중...' },
        { percent: 80, message: '📊 검색량/문서수 분석 중...' },
        { percent: 90, message: '💎 황금비율 계산 & 등급 산정 중...' },
        { percent: 95, message: '✨ 최종 필터링 & 정렬 중...' }
      ];
      
      let stepIndex = 0;
      const progressInterval = setInterval(() => {
        if (stepIndex < progressSteps.length) {
          const step = progressSteps[stepIndex];
          progressBar.style.width = step.percent + '%';
          progressText.innerHTML = step.percent + '% 완료';
          progressLog.innerHTML += '<div style="color: #3b82f6;">' + step.message + '</div>';
          progressLog.scrollTop = progressLog.scrollHeight;
          stepIndex++;
        }
      }, 800);
      
      try {
        const response = await window.electronAPI.invoke('hunt-pro-traffic-keywords', {
          seedKeywords,
          category,
          targetRookie,
          includeSeasonKeywords: includeSeason,
          count: 50 // 50개 가져와서 10개씩 표시
        });
        
        // 진행률 완료
        clearInterval(progressInterval);
        if (progressBar) {
          progressBar.style.width = '100%';
          progressText.innerHTML = '100% 완료!';
          progressLog.innerHTML += '<div style="color: #22c55e; font-weight: bold;">✅ 완료! ' + (response?.keywords?.length || 0) + '개 황금키워드 발굴!</div>';
        }
        
        if (!response || !response.success || !response.keywords || response.keywords.length === 0) {
          resultsDiv.innerHTML = `
            <div style="text-align: center; padding: 40px; background: rgba(251, 191, 36, 0.1); border-radius: 12px; border: 1px solid rgba(251, 191, 36, 0.3);">
              <div style="font-size: 40px; margin-bottom: 12px;">🔍</div>
              <div style="font-size: 16px; font-weight: 600; color: #fbbf24;">키워드를 찾지 못했습니다</div>
              <div style="font-size: 14px; color: rgba(255,255,255,0.6); margin-top: 8px;">다른 카테고리나 시드 키워드로 시도해보세요</div>
                </div>
          `;
          return;
        }
        
        // 전역 변수에 저장
        proTrafficAllKeywords = response.keywords;
        proTrafficSummary = response.summary;
        proTrafficDisplayIndex = 0;
        
        // 10개 표시
        renderProTrafficKeywords();
        
      } catch (error) {
        console.error('PRO 트래픽 헌팅 오류:', error);
        resultsDiv.innerHTML = `
          <div style="text-align: center; padding: 40px; background: rgba(239, 68, 68, 0.1); border-radius: 12px; border: 1px solid rgba(239, 68, 68, 0.3);">
            <div style="font-size: 40px; margin-bottom: 12px;">❌</div>
            <div style="font-size: 16px; font-weight: 600; color: #ef4444;">오류가 발생했습니다</div>
            <div style="font-size: 14px; color: rgba(255,255,255,0.6); margin-top: 8px;">${error.message || '잠시 후 다시 시도해주세요'}</div>
                  </div>
        `;
      } finally {
        btn.disabled = false;
        btn.innerHTML = '🏆 황금 키워드 헌팅 시작';
      }
    }
    
    function loadMoreProTrafficKeywords() {
      proTrafficDisplayIndex += PRO_TRAFFIC_PAGE_SIZE;
      renderProTrafficKeywords(false);
    }
    
    function renderProTrafficKeywords(isNew = true) {
      const resultsDiv = document.getElementById('proTrafficResults');
      const keywords = proTrafficAllKeywords;
      const summary = proTrafficSummary;
      
      if (!keywords || keywords.length === 0) return;
      
      const displayKeywords = keywords.slice(0, proTrafficDisplayIndex + PRO_TRAFFIC_PAGE_SIZE);
      const hasMore = keywords.length > displayKeywords.length;
      
      let html = `
        <div style="margin-bottom: 20px; padding: 16px; background: rgba(251, 191, 36, 0.15); border-radius: 12px; border: 1px solid rgba(251, 191, 36, 0.3);">
          <div style="display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 12px; flex-wrap: wrap;">
            <div style="display: flex; align-items: center; gap: 12px;">
              <span style="font-size: 28px;">🎉</span>
              <div>
                <div style="font-weight: 700; color: #fbbf24; font-size: 16px;">총 ${keywords.length}개 황금 키워드 발굴! (${displayKeywords.length}개 표시중)</div>
                <div style="font-size: 13px; color: rgba(255,255,255,0.7);">🏆 끝판왕 PRO 트래픽 헌터</div>
                  </div>
                </div>
            <button onclick="huntProTrafficKeywords(true)" style="padding: 8px 16px; background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%); border: none; border-radius: 8px; font-size: 13px; font-weight: 600; color: white; cursor: pointer; transition: all 0.3s;">
              🔄 새로고침
            </button>
          </div>
          <div style="display: flex; gap: 12px; flex-wrap: wrap; font-size: 12px;">
            <span style="background: rgba(255,0,100,0.2); padding: 4px 10px; border-radius: 6px; color: #ff6b9d;">🏆 SSS급: ${summary.sssCount}개</span>
            <span style="background: rgba(255,100,0,0.2); padding: 4px 10px; border-radius: 6px; color: #ff9f43;">⭐ SS급: ${summary.ssCount}개</span>
            <span style="background: rgba(34, 197, 94, 0.2); padding: 4px 10px; border-radius: 6px; color: #22c55e;">🆕 신생적합: ${summary.rookieFriendlyCount}개</span>
            <span style="background: rgba(59, 130, 246, 0.2); padding: 4px 10px; border-radius: 6px; color: #3b82f6;">🌊 블루오션: ${summary.blueOceanCount}개</span>
          </div>
        </div>
        
        <!-- 🎯 황금 키워드 선별 기준 안내 -->
        <div style="margin-bottom: 20px; padding: 16px; background: rgba(59, 130, 246, 0.1); border-radius: 12px; border: 1px solid rgba(59, 130, 246, 0.2);">
          <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 10px;">
            <span style="font-size: 18px;">📊</span>
            <span style="font-weight: 700; color: #60a5fa; font-size: 14px;">황금 키워드 선별 기준</span>
          </div>
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px; font-size: 12px;">
            <div style="background: rgba(255,255,255,0.05); padding: 10px; border-radius: 8px;">
              <div style="color: #22c55e; font-weight: 600; margin-bottom: 4px;">💎 황금비율 = 검색량 ÷ 문서수</div>
              <div style="color: rgba(255,255,255,0.6); line-height: 1.5;">
                <span style="color: #22c55e;">10+</span> 최고 | 
                <span style="color: #fbbf24;">5+</span> 좋음 | 
                <span style="color: #f59e0b;">1+</span> 보통 | 
                <span style="color: #ef4444;">&lt;1</span> 경쟁치열
              </div>
            </div>
            <div style="background: rgba(255,255,255,0.05); padding: 10px; border-radius: 8px;">
              <div style="color: #8b5cf6; font-weight: 600; margin-bottom: 4px;">🏆 등급 기준</div>
              <div style="color: rgba(255,255,255,0.6); line-height: 1.5;">
                <span style="color: #ff6b9d;">SSS</span> 황금비율10+문서1만↓ |
                <span style="color: #ff9f43;">SS</span> 비율5+문서2만↓
              </div>
            </div>
            <div style="background: rgba(255,255,255,0.05); padding: 10px; border-radius: 8px;">
              <div style="color: #3b82f6; font-weight: 600; margin-bottom: 4px;">🌊 블루오션 조건</div>
              <div style="color: rgba(255,255,255,0.6); line-height: 1.5;">
                검색량 100+ & 문서수 5,000↓ & 황금비율 0.05+
              </div>
            </div>
          </div>
        </div>
      `;
      
      displayKeywords.forEach((kw, index) => {
          const gradeColors = { 'SSS': '#ff6b9d', 'SS': '#ff9f43', 'S': '#fbbf24', 'A': '#22c55e', 'B': '#3b82f6', 'C': '#94a3b8' };
          const gradeColor = gradeColors[kw.grade] || '#94a3b8';
          const urgencyColors = { 'NOW': '#ef4444', 'TODAY': '#f59e0b', 'THIS_WEEK': '#22c55e', 'ANYTIME': '#94a3b8' };
          const urgencyColor = urgencyColors[kw.timing.urgency] || '#94a3b8';
          const safetyColors = { 'safe': '#22c55e', 'caution': '#f59e0b', 'danger': '#ef4444' };
          const safetyColor = safetyColors[kw.safetyLevel] || '#94a3b8';
          
          html += `
            <div style="background: rgba(255, 255, 255, 0.03); border-radius: 14px; padding: 18px; margin-bottom: 14px; border: 1px solid rgba(255, 255, 255, 0.08); transition: all 0.3s;" onmouseover="this.style.borderColor='rgba(251, 191, 36, 0.3)'; this.style.background='rgba(255, 255, 255, 0.06)'" onmouseout="this.style.borderColor='rgba(255, 255, 255, 0.08)'; this.style.background='rgba(255, 255, 255, 0.03)'">
              <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 14px; flex-wrap: wrap; gap: 10px;">
                <div style="flex: 1; min-width: 200px;">
                  <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 6px; flex-wrap: wrap;">
                    <span style="background: ${gradeColor}; color: white; padding: 3px 8px; border-radius: 6px; font-size: 11px; font-weight: 700;">${kw.grade}급</span>
                    <span style="background: rgba(255,255,255,0.1); padding: 3px 8px; border-radius: 6px; font-size: 11px; color: rgba(255,255,255,0.8);">${kw.type}</span>
                    <span style="background: ${urgencyColor}20; color: ${urgencyColor}; padding: 3px 8px; border-radius: 6px; font-size: 11px;">${kw.timing.urgency}</span>
                  </div>
                  <div style="font-size: 16px; font-weight: 700; color: white; cursor: pointer;" onclick="copyToClipboard('${kw.keyword}')" title="클릭하여 복사">📋 ${kw.keyword}</div>
                </div>
                <div style="text-align: right;">
                  <div style="font-size: 24px; font-weight: 800; color: ${gradeColor};">${kw.totalScore}</div>
                  <div style="font-size: 11px; color: rgba(255,255,255,0.5);">종합점수</div>
                  </div>
                </div>

              <!-- 🔥🔥🔥 검색량/문서수 핵심 지표 🔥🔥🔥 -->
              <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-bottom: 12px;">
                <div style="background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%); border-radius: 10px; padding: 12px; text-align: center;">
                  <div style="font-size: 18px; font-weight: 800; color: white;">${(kw.searchVolume || 0).toLocaleString()}</div>
                  <div style="font-size: 10px; color: rgba(255,255,255,0.8);">📊 월 검색량</div>
                </div>
                <div style="background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); border-radius: 10px; padding: 12px; text-align: center;">
                  <div style="font-size: 18px; font-weight: 800; color: white;">${(kw.documentCount || 0).toLocaleString()}</div>
                  <div style="font-size: 10px; color: rgba(255,255,255,0.8);">📄 문서수</div>
                </div>
                <div style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); border-radius: 10px; padding: 12px; text-align: center;">
                  <div style="font-size: 18px; font-weight: 800; color: white;">${kw.goldenRatio ? kw.goldenRatio.toFixed(1) : '0'}</div>
                  <div style="font-size: 10px; color: rgba(255,255,255,0.8);">💎 황금비율</div>
                </div>
                <div style="background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%); border-radius: 10px; padding: 12px; text-align: center;">
                  <div style="font-size: 18px; font-weight: 800; color: white;">${kw.blueOcean.score}</div>
                  <div style="font-size: 10px; color: rgba(255,255,255,0.8);">🌊 블루오션</div>
                </div>
              </div>
              
              <!-- 급상승 이유 -->
              ${kw.trendAnalysis ? `
              <div style="background: rgba(255, 100, 0, 0.1); border-radius: 10px; padding: 12px; margin-bottom: 12px; border: 1px solid rgba(255, 100, 0, 0.3);">
                <div style="font-size: 12px; font-weight: 700; color: #ff6b35; margin-bottom: 6px;">🔥 급상승 이유 (${kw.trendAnalysis.newsSource || '자동분석'})</div>
                <div style="font-size: 12px; color: rgba(255,255,255,0.85); line-height: 1.6; margin-bottom: 6px;">${kw.trendAnalysis.trendingReason}</div>
                <div style="font-size: 11px; color: #22c55e; font-weight: 600;">✅ 지금 쓰면 좋은 이유: ${kw.trendAnalysis.whyNow}</div>
              </div>
              ` : ''}

              <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 10px; margin-bottom: 12px;">
                <div style="background: rgba(34, 197, 94, 0.1); border-radius: 8px; padding: 10px; border: 1px solid rgba(34, 197, 94, 0.2);">
                  <div style="font-size: 11px; font-weight: 600; color: #22c55e; margin-bottom: 6px;">🆕 신생 적합도: ${kw.rookieFriendly.score}/100 [${kw.rookieFriendly.grade}급]</div>
                  <div style="font-size: 11px; color: rgba(255,255,255,0.7);">
                    <div>📅 상위노출: ${kw.rookieFriendly.canRankWithin}</div>
                  </div>
                </div>
                <div style="background: rgba(251, 191, 36, 0.1); border-radius: 8px; padding: 10px; border: 1px solid rgba(251, 191, 36, 0.2);">
                  <div style="font-size: 11px; font-weight: 600; color: #fbbf24; margin-bottom: 6px;">⏰ 타이밍: ${kw.timing.score}/100</div>
                  <div style="font-size: 11px; color: rgba(255,255,255,0.7);">
                    <div>📌 발행: ${kw.timing.bestPublishTime}</div>
                  </div>
                </div>
                <div style="background: rgba(59, 130, 246, 0.1); border-radius: 8px; padding: 10px; border: 1px solid rgba(59, 130, 246, 0.2);">
                  <div style="font-size: 11px; font-weight: 600; color: #3b82f6; margin-bottom: 6px;">📝 초고수 전략</div>
                  <div style="font-size: 11px; color: rgba(255,255,255,0.7);">
                    <div>• ${kw.proStrategy.monetization}</div>
                  </div>
                </div>
              </div>

              <div style="background: rgba(139, 92, 246, 0.1); border-radius: 8px; padding: 10px; margin-bottom: 10px; border: 1px solid rgba(139, 92, 246, 0.2);">
                <div style="font-size: 12px; color: rgba(255,255,255,0.8); margin-bottom: 4px;">📝 추천제목: ${kw.proStrategy.title}</div>
                <div style="font-size: 11px; color: rgba(255,255,255,0.6);">• 글자수: ${kw.proStrategy.wordCount}자</div>
                </div>
              
              <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;">
                <div style="font-size: 11px; color: rgba(255,255,255,0.5);">
                  📈 예상 트래픽 (일): ${kw.trafficEstimate.daily} | 신뢰도 ${kw.trafficEstimate.confidence}%
                </div>
                <div style="font-size: 11px; color: ${safetyColor};">
                  ${kw.safetyReason}
                </div>
              </div>
            </div>
          `;
        });
        
        // 10개 더보기 버튼
        if (hasMore) {
          html += `
            <div style="text-align: center; margin-top: 20px;">
              <button onclick="loadMoreProTrafficKeywords()" style="padding: 14px 32px; background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); border: none; border-radius: 12px; font-size: 15px; font-weight: 700; color: white; cursor: pointer; transition: all 0.3s; box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 20px rgba(59, 130, 246, 0.4)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 15px rgba(59, 130, 246, 0.3)';">
                📥 10개 더보기 (${keywords.length - displayKeywords.length}개 남음)
                  </button>
                </div>
          `;
        } else {
          html += `
            <div style="text-align: center; margin-top: 20px; padding: 20px; background: rgba(34, 197, 94, 0.1); border-radius: 12px; border: 1px solid rgba(34, 197, 94, 0.3);">
              <div style="font-size: 24px; margin-bottom: 8px;">✅</div>
              <div style="font-size: 14px; color: #22c55e; font-weight: 600;">모든 황금 키워드를 확인했습니다!</div>
              <button onclick="huntProTrafficKeywords(true)" style="margin-top: 12px; padding: 10px 24px; background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%); border: none; border-radius: 8px; font-size: 13px; font-weight: 600; color: white; cursor: pointer;">
                🔄 새로운 키워드 찾기
              </button>
              </div>
          `;
        }
        
        resultsDiv.innerHTML = html;
    }

    // ===== 황금 롱테일 키워드 발굴기 =====
    const CATEGORY_OPTIONS = [
      { value: '제품리뷰', label: '🛒 제품 리뷰/추천' },
      { value: '건강', label: '💊 건강/영양제' },
      { value: '여행', label: '✈️ 여행/관광' },
      { value: '뷰티', label: '💄 뷰티/화장품' },
      { value: '육아', label: '👶 육아/아기용품' },
      { value: '전자제품', label: '📱 전자제품/가전' },
      { value: '패션', label: '👗 패션/의류' },
      { value: '재테크', label: '💰 재테크/투자' },
      { value: '교육', label: '📚 교육/자격증' },
      { value: '식품', label: '🍱 식품/밀키트' }
    ];
    
    const TARGET_OPTIONS = [
      { value: '시니어', label: '👴 시니어 (50-70대)' },
      { value: '20대', label: '🎓 20대 (대학생/사회초년생)' },
      { value: '30대', label: '💼 30대 (직장인/신혼)' },
      { value: '40대', label: '👨‍👩‍👧 40대 (학부모/중년)' },
      { value: '직장인', label: '🏢 직장인' },
      { value: '주부', label: '🏠 주부/엄마' },
      { value: '학생', label: '📖 학생/수험생' },
      { value: '신혼부부', label: '💑 신혼부부' },
      { value: '자취생', label: '🏠 자취생/1인가구' },
      { value: '반려동물', label: '🐕 반려동물 양육자' }
    ];

    function openCategoryLongtailModal() {
      const existingModal = document.getElementById('categoryLongtailModal');
      if (existingModal) existingModal.remove();
      
      const modal = document.createElement('div');
      modal.id = 'categoryLongtailModal';
      modal.style.cssText = 'display: flex; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.8); z-index: 10000; backdrop-filter: blur(8px); overflow-y: auto; padding: 20px; box-sizing: border-box; align-items: flex-start; justify-content: center;';
      
      modal.innerHTML = `
        <div style="background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); border-radius: 24px; padding: 32px; max-width: 900px; width: 100%; margin: 20px auto; box-shadow: 0 25px 80px rgba(0, 0, 0, 0.6); border: 2px solid rgba(34, 197, 94, 0.3); position: relative; max-height: calc(100vh - 40px); overflow-y: auto;">
          <!-- 닫기 버튼 -->
          <button onclick="closeCategoryLongtailModal()" style="position: absolute; top: 16px; right: 16px; width: 40px; height: 40px; background: rgba(255, 255, 255, 0.1); border: none; border-radius: 50%; color: white; font-size: 20px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease; z-index: 10;" onmouseover="this.style.background='rgba(255, 255, 255, 0.2)'" onmouseout="this.style.background='rgba(255, 255, 255, 0.1)'">✕</button>
          
          <!-- 헤더 -->
          <div style="text-align: center; margin-bottom: 28px;">
            <h2 style="font-size: 28px; font-weight: 800; background: linear-gradient(135deg, #22c55e 0%, #86efac 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin: 0 0 8px 0;">💎 황금 롱테일 키워드 발굴기</h2>
            <p style="font-size: 14px; color: rgba(255, 255, 255, 0.7); margin: 0;">카테고리와 타겟층을 선택하면 수익화 가능한 키워드를 분석해 드립니다</p>
            </div>
          
          <!-- 선택 영역 -->
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px;">
            <!-- 카테고리 선택 -->
            <div style="background: rgba(255, 255, 255, 0.05); border-radius: 16px; padding: 20px; border: 1px solid rgba(255, 255, 255, 0.1);">
              <label style="font-size: 14px; font-weight: 700; color: #22c55e; display: block; margin-bottom: 12px;">📁 카테고리 선택</label>
              <select id="categorySelect" style="width: 100%; padding: 14px 16px; border: 2px solid rgba(34, 197, 94, 0.3); border-radius: 12px; font-size: 15px; background: rgba(30, 41, 59, 0.8); color: white; cursor: pointer; outline: none;" onchange="this.style.borderColor='rgba(34, 197, 94, 0.6)'">
                ${CATEGORY_OPTIONS.map(opt => `<option value="${opt.value}">${opt.label}</option>`).join('')}
              </select>
          </div>
            
            <!-- 타겟층 선택 -->
            <div style="background: rgba(255, 255, 255, 0.05); border-radius: 16px; padding: 20px; border: 1px solid rgba(255, 255, 255, 0.1);">
              <label style="font-size: 14px; font-weight: 700; color: #22c55e; display: block; margin-bottom: 12px;">👥 타겟층 선택</label>
              <select id="targetSelect" style="width: 100%; padding: 14px 16px; border: 2px solid rgba(34, 197, 94, 0.3); border-radius: 12px; font-size: 15px; background: rgba(30, 41, 59, 0.8); color: white; cursor: pointer; outline: none;" onchange="this.style.borderColor='rgba(34, 197, 94, 0.6)'">
                ${TARGET_OPTIONS.map(opt => `<option value="${opt.value}">${opt.label}</option>`).join('')}
              </select>
            </div>
          </div>
          
          <!-- 키워드 수 선택 -->
          <div style="display: flex; gap: 16px; margin-bottom: 24px; align-items: center; justify-content: center;">
            <label style="font-size: 14px; color: rgba(255, 255, 255, 0.8);">생성할 키워드 수:</label>
            <select id="keywordCountSelect" style="padding: 10px 16px; border: 2px solid rgba(34, 197, 94, 0.3); border-radius: 10px; font-size: 14px; background: rgba(30, 41, 59, 0.8); color: white; cursor: pointer; outline: none;">
              <option value="5">5개</option>
              <option value="10" selected>10개</option>
              <option value="20">20개</option>
            </select>
          </div>
          
          <!-- 분석 버튼 -->
          <button id="analyzeLongtailBtn" onclick="analyzeCategoryLongtail()" style="width: 100%; padding: 18px; background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%); border: none; border-radius: 14px; font-size: 18px; font-weight: 700; color: white; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 4px 20px rgba(34, 197, 94, 0.4);" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 30px rgba(34, 197, 94, 0.5)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 20px rgba(34, 197, 94, 0.4)';">
            🔍 황금 키워드 분석 시작
          </button>
          
          <!-- 경고 메시지 -->
          <div style="margin-top: 16px; padding: 12px 16px; background: rgba(251, 191, 36, 0.1); border: 1px solid rgba(251, 191, 36, 0.3); border-radius: 10px;">
            <p style="font-size: 12px; color: #fbbf24; margin: 0; line-height: 1.6;">
              ⚠️ <strong>주의:</strong> 제공되는 수익/검색량 정보는 <strong>추정치</strong>이며 실제와 다를 수 있습니다. 상위노출과 수익은 블로그 지수, 콘텐츠 품질, 경쟁 상황 등에 따라 크게 달라집니다.
            </p>
          </div>
          
          <!-- 결과 영역 -->
          <div id="longtailResults" style="margin-top: 24px;"></div>
        </div>
      `;
      
      document.body.appendChild(modal);
      modal.addEventListener('click', (e) => {
        if (e.target === modal) closeCategoryLongtailModal();
      });
    }
    
    function closeCategoryLongtailModal() {
      const modal = document.getElementById('categoryLongtailModal');
      if (modal) modal.remove();
    }
    
    async function analyzeCategoryLongtail() {
      const category = document.getElementById('categorySelect').value;
      const target = document.getElementById('targetSelect').value;
      const count = parseInt(document.getElementById('keywordCountSelect').value);
      const btn = document.getElementById('analyzeLongtailBtn');
      const resultsDiv = document.getElementById('longtailResults');
      
      btn.disabled = true;
      btn.innerHTML = '<span style="display: inline-block; animation: spin 1s linear infinite;">🔄</span> 분석 중...';
      resultsDiv.innerHTML = '<div style="text-align: center; padding: 40px; color: rgba(255,255,255,0.6);"><div style="font-size: 48px; margin-bottom: 16px;">🔍</div><div>황금 키워드를 발굴하고 있습니다...</div></div>';
      
      try {
        const response = await window.electronAPI.invoke('hunt-category-longtail-keywords', {
          category,
          target,
          count,
          includeYear: true,
          buyIntentOnly: false
        });
        
        // 응답에서 keywords 추출
        const result = response && response.success ? response.keywords : [];
        
        if (!result || result.length === 0) {
          resultsDiv.innerHTML = `
            <div style="text-align: center; padding: 40px; background: rgba(251, 191, 36, 0.1); border-radius: 12px; border: 1px solid rgba(251, 191, 36, 0.3);">
              <div style="font-size: 40px; margin-bottom: 12px;">🔍</div>
              <div style="font-size: 16px; font-weight: 600; color: #fbbf24;">키워드를 찾지 못했습니다</div>
              <div style="font-size: 14px; color: rgba(255,255,255,0.6); margin-top: 8px;">다른 카테고리나 타겟층으로 시도해보세요</div>
            </div>
          `;
          return;
        }
        
        // 결과 표시
        let html = `
          <div style="margin-bottom: 20px; padding: 16px; background: rgba(34, 197, 94, 0.15); border-radius: 12px; border: 1px solid rgba(34, 197, 94, 0.3); display: flex; align-items: center; gap: 12px;">
            <span style="font-size: 28px;">🎉</span>
            <div>
              <div style="font-weight: 700; color: #22c55e; font-size: 16px;">${result.length}개의 황금 키워드 발굴 완료!</div>
              <div style="font-size: 13px; color: rgba(255,255,255,0.7);">${CATEGORY_OPTIONS.find(o => o.value === category)?.label} + ${TARGET_OPTIONS.find(o => o.value === target)?.label}</div>
            </div>
          </div>
        `;
        
        result.forEach((kw, index) => {
          const scoreColor = kw.score >= 90 ? '#22c55e' : kw.score >= 70 ? '#fbbf24' : '#3b82f6';
          const competitionColor = kw.competition.level === 'low' ? '#22c55e' : kw.competition.level === 'medium' ? '#fbbf24' : '#ef4444';
          const competitionText = kw.competition.level === 'low' ? '낮음 ✅' : kw.competition.level === 'medium' ? '보통 ⚠️' : '높음 ❌';
          
          html += `
            <div style="background: rgba(255, 255, 255, 0.05); border-radius: 16px; padding: 20px; margin-bottom: 16px; border: 1px solid rgba(255, 255, 255, 0.1); transition: all 0.3s;" onmouseover="this.style.borderColor='rgba(34, 197, 94, 0.4)'; this.style.background='rgba(255, 255, 255, 0.08)'" onmouseout="this.style.borderColor='rgba(255, 255, 255, 0.1)'; this.style.background='rgba(255, 255, 255, 0.05)'">
              <!-- 헤더 -->
              <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px;">
                <div style="flex: 1;">
                  <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 8px;">
                    <span style="background: ${scoreColor}; color: white; padding: 4px 10px; border-radius: 8px; font-size: 12px; font-weight: 700;">${index + 1}위</span>
                    <span style="background: rgba(255,255,255,0.1); padding: 4px 10px; border-radius: 8px; font-size: 12px; color: rgba(255,255,255,0.8);">점수 ${kw.score}/100</span>
                  </div>
                  <div style="font-size: 18px; font-weight: 700; color: white; cursor: pointer;" onclick="copyToClipboard('${kw.keyword}')" title="클릭하여 복사">📋 ${kw.keyword}</div>
                </div>
              </div>
              
              <!-- 제품 정보 -->
              <div style="background: rgba(0,0,0,0.2); border-radius: 12px; padding: 14px; margin-bottom: 14px;">
                <div style="font-size: 13px; font-weight: 600; color: #22c55e; margin-bottom: 10px;">📦 제품 정보</div>
                <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; font-size: 13px; color: rgba(255,255,255,0.8);">
                  <div>• 카테고리: ${kw.product.category}</div>
                  <div>• 가격대: ${kw.product.priceRange}</div>
                  <div>• 평균가: ${kw.product.avgPrice.toLocaleString()}원</div>
                  <div>• 브랜드: ${kw.product.popularBrands.slice(0, 3).join(', ')}</div>
                </div>
              </div>
              
              <!-- 수익화/경쟁 분석 (2열) -->
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 14px;">
                <div style="background: rgba(251, 191, 36, 0.1); border-radius: 10px; padding: 12px; border: 1px solid rgba(251, 191, 36, 0.2);">
                  <div style="font-size: 12px; font-weight: 600; color: #fbbf24; margin-bottom: 8px;">💰 수익화 (추정)</div>
                  <div style="font-size: 12px; color: rgba(255,255,255,0.7); line-height: 1.6;">
                    <div>• CPC: ${kw.monetization.estimatedCPC.toLocaleString()}원</div>
                    <div>• 수수료: ${kw.monetization.estimatedCommission}</div>
                    <div>• 클릭당: ${kw.monetization.estimatedRevenuePerClick}</div>
                  </div>
                </div>
                <div style="background: rgba(59, 130, 246, 0.1); border-radius: 10px; padding: 12px; border: 1px solid rgba(59, 130, 246, 0.2);">
                  <div style="font-size: 12px; font-weight: 600; color: #3b82f6; margin-bottom: 8px;">📊 경쟁 분석</div>
                  <div style="font-size: 12px; color: rgba(255,255,255,0.7); line-height: 1.6;">
                    <div>• 경쟁도: <span style="color: ${competitionColor}">${competitionText}</span></div>
                    <div>• 난이도: ${kw.competition.topRankDifficulty}</div>
                    <div>• 예상 상위노출: ${kw.competition.expectedRankingTime}</div>
                  </div>
                </div>
              </div>
              
              <!-- 콘텐츠 가이드 -->
              <div style="background: rgba(139, 92, 246, 0.1); border-radius: 10px; padding: 12px; margin-bottom: 14px; border: 1px solid rgba(139, 92, 246, 0.2);">
                <div style="font-size: 12px; font-weight: 600; color: #a78bfa; margin-bottom: 8px;">📝 콘텐츠 가이드</div>
                <div style="font-size: 12px; color: rgba(255,255,255,0.8);">
                  <div style="margin-bottom: 6px;">• 추천 형식: ${kw.contentGuide.recommendedFormat}</div>
                  <div style="margin-bottom: 6px;">• 추천 제목: <span style="color: #22c55e;">${kw.contentGuide.suggestedTitle}</span></div>
                  <div>• 권장 길이: ${kw.contentGuide.contentLength}</div>
                </div>
              </div>
              
              <!-- 황금키워드 이유 -->
              <div style="background: rgba(34, 197, 94, 0.1); border-radius: 10px; padding: 12px; border: 1px solid rgba(34, 197, 94, 0.2);">
                <div style="font-size: 12px; font-weight: 600; color: #22c55e; margin-bottom: 8px;">💎 황금키워드인 이유</div>
                <div style="font-size: 12px; color: rgba(255,255,255,0.7); line-height: 1.8;">
                  ${kw.recommendation.whyGolden.slice(0, 4).map(r => `<div>${r}</div>`).join('')}
                </div>
              </div>
              
              <!-- 리스크 -->
              <div style="margin-top: 12px; padding: 10px 14px; background: rgba(239, 68, 68, 0.1); border-radius: 8px; border: 1px solid rgba(239, 68, 68, 0.2);">
                <div style="font-size: 11px; color: #f87171;">
                  ${kw.recommendation.riskFactors.slice(0, 2).join(' | ')}
                </div>
              </div>
            </div>
          `;
        });
        
        resultsDiv.innerHTML = html;
        
      } catch (error) {
        console.error('롱테일 키워드 분석 오류:', error);
        resultsDiv.innerHTML = `
          <div style="text-align: center; padding: 40px; background: rgba(239, 68, 68, 0.1); border-radius: 12px; border: 1px solid rgba(239, 68, 68, 0.3);">
            <div style="font-size: 40px; margin-bottom: 12px;">❌</div>
            <div style="font-size: 16px; font-weight: 600; color: #ef4444;">오류가 발생했습니다</div>
            <div style="font-size: 14px; color: rgba(255,255,255,0.6); margin-top: 8px;">${error.message || '잠시 후 다시 시도해주세요'}</div>
          </div>
        `;
      } finally {
        btn.disabled = false;
        btn.innerHTML = '🔍 황금 키워드 분석 시작';
      }
    }

  </script>
</body>
</html>
