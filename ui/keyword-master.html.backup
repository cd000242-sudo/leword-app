            <p style="font-size: 13px; color: #94a3b8;">라이선스가 없으신가요?</p>
            <a href="https://open.kakao.com/o/sPcaslwh" target="_blank" style="display: inline-block; margin-top: 8px; padding: 10px 20px; background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%); color: white; text-decoration: none; border-radius: 10px; font-weight: 600; font-size: 13px;">💬 카카오톡으로 구매 문의</a>
          </div>
        </div>
      `;
      
      document.body.appendChild(modal);
      
      // ESC 키로 닫기
      modal.addEventListener('click', (e) => {
        if (e.target === modal) closeLicenseModal();
      });
    }

    function formatLicenseCode(input) {
      let value = input.value.replace(/[^A-Z0-9]/gi, '').toUpperCase();
      let formatted = '';
      for (let i = 0; i < value.length && i < 16; i++) {
        if (i > 0 && i % 4 === 0) formatted += '-';
        formatted += value[i];
      }
      input.value = formatted;
    }

    function closeLicenseModal() {
      const modal = document.getElementById('licenseModal');
      if (modal) {
        modal.style.animation = 'fadeOut 0.3s ease';
        setTimeout(() => modal.remove(), 300);
      }
    }

    async function registerLicense() {
      // 라이선스 코드 섹션 (우선)
      const licenseCode = document.getElementById('licenseCode').value.trim();
      const userId2 = document.getElementById('licenseUserId2').value.trim();
      const userPassword2 = document.getElementById('licenseUserPassword2').value.trim();
      
      // 아이디/비밀번호 로그인 섹션
      const userId = document.getElementById('licenseUserId').value.trim();
      const userPassword = document.getElementById('licenseUserPassword').value.trim();
      
      const serverUrl = document.getElementById('licenseServerUrl')?.value.trim() || '';
      const messageDiv = document.getElementById('licenseMessage');
      
      // 입력값 우선순위: 라이선스 코드 > 아이디/비밀번호 로그인
      let finalUserId, finalUserPassword, finalLicenseCode;
      
      if (licenseCode) {
        // 라이선스 코드로 신규 등록
        finalLicenseCode = licenseCode;
        finalUserId = userId2;
        finalUserPassword = userPassword2;
        
        if (!finalUserId || !finalUserPassword) {
        messageDiv.style.display = 'block';
        messageDiv.style.background = '#fee2e2';
        messageDiv.style.color = '#991b1b';
          messageDiv.textContent = '⚠️ 라이선스 코드와 함께 아이디/비밀번호를 모두 입력해주세요.';
        return;
      }
      } else if (userId && userPassword) {
        // 아이디/비밀번호로 로그인 (기존 사용자)
        finalUserId = userId;
        finalUserPassword = userPassword;
        finalLicenseCode = '';
      } else {
        messageDiv.style.display = 'block';
        messageDiv.style.background = '#fee2e2';
        messageDiv.style.color = '#991b1b';
        messageDiv.textContent = '⚠️ 라이선스 코드를 입력하거나 아이디/비밀번호로 로그인해주세요.';
        return;
      }
      
      try {
        messageDiv.style.display = 'block';
        messageDiv.style.background = '#dbeafe';
        messageDiv.style.color = '#1e40af';
        messageDiv.textContent = finalLicenseCode ? '🔄 라이선스 등록 중...' : '🔄 로그인 중...';
        
        const result = await window.blogger.registerLicense({
          userId: finalUserId,
          userPassword: finalUserPassword,
          licenseCode: finalLicenseCode || undefined,
          serverUrl: serverUrl || undefined
        });
        
        if (result.success) {
          messageDiv.style.background = '#d1fae5';
          messageDiv.style.color = '#065f46';
          messageDiv.textContent = '✅ ' + result.message;
          
          setTimeout(() => {
            closeLicenseModal();
            checkLicenseStatus(); // 상태 업데이트
            
            if (result.isPremium) {
              alert('🎉 프리미엄 라이선스가 등록되었습니다!\n프리미엄 기능을 이용하실 수 있습니다.');
            }
          }, 1500);
        } else {
          messageDiv.style.background = '#fee2e2';
          messageDiv.style.color = '#991b1b';
          messageDiv.textContent = '❌ ' + result.message;
        }
      } catch (error) {
        console.error('[LICENSE] 등록 실패:', error);
        messageDiv.style.display = 'block';
        messageDiv.style.background = '#fee2e2';
        messageDiv.style.color = '#991b1b';
        messageDiv.textContent = '❌ 라이선스 등록에 실패했습니다: ' + error.message;
      }
    }

    // 프리미엄 탭 표시
    function showPremiumTab() {
      openModal('premium');
    }
    
    // 프리미엄 인증 필요 모달
