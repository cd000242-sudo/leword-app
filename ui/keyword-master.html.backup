              tip: '이미 프로젝트가 있다면 해당 프로젝트를 선택해도 됩니다.'
            },
            {
              title: '3단계: YouTube Data API v3 활성화',
              content: '좌측 메뉴 "API 및 서비스" → "라이브러리" 클릭<br>"YouTube Data API v3" 검색 → 클릭 → "사용" 버튼 클릭',
              tip: 'API를 활성화해야 사용할 수 있습니다.'
            },
            {
              title: '4단계: API 키 생성',
              content: '좌측 메뉴 "API 및 서비스" → "사용자 인증 정보" 클릭<br>"+ 사용자 인증 정보 만들기" → "API 키" 선택',
              tip: ''
            },
            {
              title: '5단계: API 키 복사',
              content: '생성된 API 키를 복사하여 LEWORD 설정에 붙여넣기 하세요.',
              tip: 'API 키는 외부에 노출되지 않도록 주의하세요!'
            }
          ]
        },
        searchad: {
          title: '🔍 네이버 검색광고 API 발급 가이드',
          color: '#03c75a',
          steps: [
            {
              title: '1단계: 네이버 검색광고 가입',
              content: 'searchad.naver.com 에 접속하여 회원가입 또는 로그인합니다.',
              tip: '네이버 계정으로 로그인할 수 있습니다.'
            },
            {
              title: '2단계: 광고 계정 생성',
              content: '처음 접속하면 광고 계정을 생성해야 합니다.<br>사업자/개인 선택 후 기본 정보를 입력합니다.',
              tip: '개인 블로거도 개인으로 가입 가능합니다. 실제 광고를 집행하지 않아도 됩니다.'
            },
            {
              title: '3단계: API 라이선스 발급',
              content: '로그인 후 우측 상단 "도구" → "API 사용 관리" 클릭<br>"API 라이선스 발급" 버튼 클릭',
              tip: ''
            },
            {
              title: '4단계: API 키 확인',
              content: '발급된 정보를 확인합니다:<br>• Access License: 긴 문자열<br>• Secret Key: 비밀 키<br>• Customer ID: 숫자로 된 고객 ID',
              tip: '3가지 정보가 모두 필요합니다.'
            },
            {
              title: '5단계: LEWORD에 입력',
              content: 'Access License, Secret Key, Customer ID를<br>각각 LEWORD 설정에 붙여넣기 하세요.',
              tip: '검색광고 API가 있으면 정확한 월간 검색량을 조회할 수 있습니다!'
            }
          ]
        }
      };

      const guide = guides[apiType];
      if (!guide) return;

      const modal = document.createElement('div');
      modal.id = 'apiGuideModal';
      modal.style.cssText = `
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0, 0, 0, 0.85); display: flex; justify-content: center;
        align-items: center; z-index: 20000; animation: fadeIn 0.3s ease;
      `;

      let stepsHtml = guide.steps.map((step, index) => `
        <div style="background: rgba(255,255,255,0.05); border-radius: 12px; padding: 20px; margin-bottom: 16px; border-left: 4px solid ${guide.color};">
          <div style="font-size: 16px; font-weight: 700; color: ${guide.color}; margin-bottom: 12px;">${step.title}</div>
          <div style="font-size: 14px; color: #e2e8f0; line-height: 1.8;">${step.content}</div>
          ${step.tip ? `<div style="margin-top: 12px; padding: 10px 14px; background: rgba(251, 191, 36, 0.1); border-radius: 8px; font-size: 13px; color: #fbbf24;">💡 ${step.tip}</div>` : ''}
        </div>
      `).join('');

      modal.innerHTML = `
        <div style="background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); border-radius: 24px; padding: 32px; max-width: 700px; width: 95%; max-height: 90vh; overflow-y: auto; box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5); border: 1px solid rgba(255, 255, 255, 0.1);">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
            <h2 style="margin: 0; font-size: 24px; font-weight: 700; color: white;">${guide.title}</h2>
            <button onclick="closeApiGuideModal()" style="background: none; border: none; color: #94a3b8; font-size: 28px; cursor: pointer; padding: 0; line-height: 1;">&times;</button>
          </div>
          
          <div style="margin-bottom: 24px;">
            ${stepsHtml}
          </div>
          
          <div style="display: flex; gap: 12px; justify-content: center;">
            <button onclick="closeApiGuideModal()" style="padding: 14px 28px; background: #334155; color: white; border: none; border-radius: 12px; font-size: 16px; font-weight: 600; cursor: pointer;">닫기</button>
          </div>
        </div>
      `;

      document.body.appendChild(modal);
    };

    window.closeApiGuideModal = function closeApiGuideModal() {
      const modal = document.getElementById('apiGuideModal');
      if (modal) {
        modal.remove();
      }
    };

    // 모달 외부 클릭 시 닫기
    document.addEventListener('click', function(event) {
      const modal = document.getElementById('keywordSettingsModal');
      if (modal && event.target === modal) {
        closeKeywordSettingsModal();
      }
    });
    // ========================================
    // 블로그 지수 & 진입성 분석 모달
    // ========================================
    window.createBlogIndexModal = function() {
      const modalHTML = `
        <div class="modal-overlay" onclick="closeModal()">
          <div class="modal-content" onclick="event.stopPropagation()" style="max-width: 1200px; max-height: 90vh; overflow-y: auto;">
            <button class="modal-close" onclick="closeModal()">✕</button>
            <h2 style="margin-bottom: 20px; font-size: 28px; font-weight: 800; background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
              📊 블로그 지수 & 진입성 분석 <span style="font-size: 14px; background: #22c55e; color: white; padding: 4px 12px; border-radius: 20px; margin-left: 8px;">🆓 무료</span>
            </h2>
            
            <div style="margin-bottom: 16px; padding: 12px 16px; background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border-radius: 10px; border-left: 4px solid #f59e0b;">
              <div style="font-size: 13px; color: #92400e; line-height: 1.6;">
                ⚠️ <strong>양심 고백:</strong> 블로그 지수는 <strong>추정치</strong>이며 실제 네이버 내부 지표와 다를 수 있습니다. 참고용으로만 사용하세요. 이에 따라 무료로 제공합니다.
              </div>
            </div>
            
            <div style="margin-bottom: 24px; padding: 20px; background: linear-gradient(135deg, #dbeafe 0%, #e0f2fe 100%); border-radius: 12px; border-left: 4px solid #3b82f6;">
              <div style="font-weight: 600; color: #1e40af; margin-bottom: 12px; font-size: 16px;">💡 블로그 지수란? (추정 데이터)</div>
              <div style="font-size: 14px; color: #1e3a8a; line-height: 1.6; margin-bottom: 8px;">
                상위 노출 블로그의 <strong>4가지 검증 가능한 지표</strong>를 종합 분석하여 진입 난이도를 측정합니다.
              </div>
              <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; margin-top: 12px; margin-bottom: 12px;">
                <div style="padding: 10px; background: white; border-radius: 8px; border-left: 3px solid #3b82f6;">
                  <div style="font-weight: 700; color: #1e40af; font-size: 13px; margin-bottom: 4px;">1. 글 개수 ✅</div>
                  <div style="font-size: 11px; color: #6b7280;">많을수록 경쟁 치열</div>
                </div>
                <div style="padding: 10px; background: white; border-radius: 8px; border-left: 3px solid #8b5cf6;">
                  <div style="font-weight: 700; color: #6b21a8; font-size: 13px; margin-bottom: 4px;">2. 운영 기간 ✅</div>
                  <div style="font-size: 11px; color: #6b7280;">오래될수록 파워블로그</div>
                </div>
                <div style="padding: 10px; background: white; border-radius: 8px; border-left: 3px solid #ec4899;">
                  <div style="font-weight: 700; color: #be185d; font-size: 13px; margin-bottom: 4px;">3. 포스팅 빈도 ✅</div>
                  <div style="font-size: 11px; color: #6b7280;">자주 올릴수록 활발함</div>
                </div>
                <div style="padding: 10px; background: white; border-radius: 8px; border-left: 3px solid #f59e0b;">
                  <div style="font-weight: 700; color: #92400e; font-size: 13px; margin-bottom: 4px;">4. 댓글/공감 수 ✅</div>
                  <div style="font-size: 11px; color: #6b7280;">많을수록 영향력 큼</div>
                </div>
              </div>
              <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 8px;">
                <div style="padding: 8px; background: white; border-radius: 6px; text-align: center;">
                  <div style="font-weight: 700; color: #10b981; font-size: 12px;">최적5 (진입 매우 쉬움)</div>
                  <div style="font-size: 11px; color: #6b7280;">신생 블로그, 활동 적음</div>
                </div>
                <div style="padding: 8px; background: white; border-radius: 6px; text-align: center;">
                  <div style="font-weight: 700; color: #3b82f6; font-size: 12px;">준최5 (보통)</div>
                  <div style="font-size: 11px; color: #6b7280;">중간 규모 블로그</div>
                </div>
                <div style="padding: 8px; background: white; border-radius: 6px; text-align: center;">
                  <div style="font-weight: 700; color: #f59e0b; font-size: 12px;">일반 (진입 어려움)</div>
                  <div style="font-size: 11px; color: #6b7280;">파워 블로그, 활발함</div>
                </div>
              </div>
            </div>

            <div style="display: flex; gap: 12px; margin-bottom: 20px;">
              <input type="text" id="blogIndexKeyword" placeholder="키워드 입력 (예: 소파, 인테리어)" 
                style="flex: 1; padding: 14px 16px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 15px;"
                onkeypress="if(event.key==='Enter') window.analyzeBlogIndex()">
              <button onclick="window.analyzeBlogIndex()" 
                style="padding: 14px 32px; background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); color: white; border: none; border-radius: 8px; font-weight: 700; cursor: pointer; font-size: 15px; box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);">
                🔍 분석 시작
              </button>
            </div>

            <div id="blogIndexResults"></div>
          </div>
        </div>
      `;

      const container = document.getElementById('modalContainer');
      if (container) {
        container.innerHTML = modalHTML;
      }
    };

    window.analyzeBlogIndex = async function() {
      const keywordInput = document.getElementById('blogIndexKeyword');
      const resultsDiv = document.getElementById('blogIndexResults');
      
      if (!keywordInput || !resultsDiv) return;
      
      const keyword = keywordInput.value.trim();
      if (!keyword) {
        alert('키워드를 입력해주세요.');
        return;
      }

      resultsDiv.innerHTML = '<div style="text-align: center; padding: 40px; color: #64748b;"><div class="spinner"></div><div style="margin-top: 16px;">블로그 지수 분석 중... (약 30초 소요)</div></div>';

      try {
        const result = await window.electronAPI.invoke('crawl-blog-index', keyword);
        
        if (!result.success) {
          throw new Error(result.error || '블로그 지수 조회 실패');
        }

        const data = result.data;
        
        // 블로그 지수 등급 색상 (최적1이 가장 높은 등급)
        const indexColors = {
          '최적1': '#ef4444', '최적2': '#f97316', '최적3': '#f59e0b', '최적4': '#eab308', '최적5': '#84cc16',
          '준최1': '#22c55e', '준최2': '#10b981', '준최3': '#14b8a6', '준최4': '#06b6d4', '준최5': '#0ea5e9',
          '일반': '#94a3b8'
        };
        
        const indexColor = indexColors[data.averageBlogIndex] || '#6b7280';
        
        resultsDiv.innerHTML = `
          <div style="padding: 24px; background: white; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
              <h3 style="font-size: 22px; font-weight: 700; color: #1e293b; margin: 0;">
                "${data.keyword}" 상위 노출 분석
              </h3>
              <div style="padding: 10px 20px; background: ${indexColor}; color: white; border-radius: 20px; font-weight: 700; font-size: 16px;">
                평균 ${data.averageBlogIndex}
              </div>
            </div>
            
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 20px;">
              <div style="padding: 16px; background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%); border-radius: 12px;">
                <div style="font-size: 12px; color: #0369a1; margin-bottom: 6px; font-weight: 600;">평균 블로그 지수</div>
                <div style="font-size: 28px; font-weight: 800; color: #0284c7;">${data.averageBlogIndex}</div>
                <div style="font-size: 11px; color: #0369a1; margin-top: 4px;">상위 5개 평균</div>
              </div>
              <div style="padding: 16px; background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%); border-radius: 12px;">
                <div style="font-size: 12px; color: #047857; margin-bottom: 6px; font-weight: 600;">진입 가능성</div>
                <div style="font-size: 28px; font-weight: 800; color: #059669;">${data.entryPossibility}</div>
                <div style="font-size: 11px; color: #047857; margin-top: 4px;">점 / 100점</div>
              </div>
              <div style="padding: 16px; background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border-radius: 12px;">
                <div style="font-size: 12px; color: #92400e; margin-bottom: 6px; font-weight: 600;">경쟁 강도</div>
                <div style="font-size: 20px; font-weight: 800; color: #b45309;">${data.competitionLevel}</div>
                <div style="font-size: 11px; color: #92400e; margin-top: 4px;">평균 ${data.averageDaysAgo}일 전</div>
              </div>
            </div>

            <div style="padding: 20px; background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%); border-radius: 12px; margin-bottom: 20px;">
              <div style="font-weight: 700; color: #1e40af; margin-bottom: 12px; font-size: 16px;">🏆 상위 노출 블로그 (1~10위)</div>
              <div style="max-height: 500px; overflow-y: auto;">
                ${!data.topPosts || data.topPosts.length === 0 
                  ? '<div style="text-align: center; padding: 40px; color: #64748b;">블로그 정보를 수집 중입니다...</div>'
                  : data.topPosts.map((post) => {
                  const postIndexColor = indexColors[post.blogIndex] || '#6b7280';
                  return `
                    <div style="padding: 16px; background: white; border-radius: 12px; margin-bottom: 12px; border: 2px solid #e5e7eb; position: relative;">
                      <div style="position: absolute; top: 12px; right: 12px; padding: 6px 12px; background: ${postIndexColor}; color: white; border-radius: 16px; font-weight: 700; font-size: 12px; text-align: center;">
                        ${post.blogIndex}<br/>
                        <span style="font-size: 10px; opacity: 0.9;">${post.postDate}</span>
                      </div>
                      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
                        <div style="padding: 4px 12px; background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); color: white; border-radius: 16px; font-weight: 700; font-size: 14px;">
                          ${post.rank}위
                        </div>
                        <div style="font-weight: 700; color: #1e293b; font-size: 15px; flex: 1; padding-right: 80px;">
                          ${post.title}
                        </div>
                      </div>
                      <div style="display: flex; flex-wrap: wrap; gap: 12px; margin-top: 12px;">
                        <div style="font-size: 13px; color: #64748b;">
                          <span style="font-weight: 600;">📝 블로그:</span> ${post.blogName}
                        </div>
                        <div style="font-size: 13px; color: #64748b;">
                          <span style="font-weight: 600;">📅 작성일:</span> <span style="font-weight: 700; color: ${post.daysAgo <= 7 ? '#10b981' : post.daysAgo <= 30 ? '#f59e0b' : '#ef4444'}">${post.daysAgo === 0 ? '오늘' : `${post.daysAgo}일 전`}</span>
                        </div>
                      </div>
                      <div style="margin-top: 8px; display: flex; gap: 8px;">
                        <button onclick="(function(e){ e.preventDefault(); e.stopPropagation(); const url = '${post.postUrl.replace(/'/g, "\\'").replace(/"/g, '&quot;')}'; if (window.electronAPI && window.electronAPI.openExternal) { window.electronAPI.openExternal(url).catch(() => window.open(url, '_blank')); } else if (window.blogger && window.blogger.openExternal) { window.blogger.openExternal(url).catch(() => window.open(url, '_blank')); } else { window.open(url, '_blank'); } })(event)" style="padding: 6px 12px; background: #f1f5f9; color: #475569; border-radius: 6px; font-size: 12px; text-decoration: none; font-weight: 600; border: none; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.background='#e2e8f0';" onmouseout="this.style.background='#f1f5f9';">
                          글 보기 →
                        </button>
                        <button onclick="(function(e){ e.preventDefault(); e.stopPropagation(); const url = '${post.blogUrl.replace(/'/g, "\\'").replace(/"/g, '&quot;')}'; if (window.electronAPI && window.electronAPI.openExternal) { window.electronAPI.openExternal(url).catch(() => window.open(url, '_blank')); } else if (window.blogger && window.blogger.openExternal) { window.blogger.openExternal(url).catch(() => window.open(url, '_blank')); } else { window.open(url, '_blank'); } })(event)" style="padding: 6px 12px; background: #f1f5f9; color: #475569; border-radius: 6px; font-size: 12px; text-decoration: none; font-weight: 600; border: none; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.background='#e2e8f0';" onmouseout="this.style.background='#f1f5f9';">
                          블로그 보기 →
                        </button>
                      </div>
                    </div>
                  `;
                }).join('')}
              </div>
            </div>

            <div style="padding: 20px; background: linear-gradient(135deg, ${data.entryPossibility >= 70 ? '#d1fae5' : data.entryPossibility >= 50 ? '#fef3c7' : '#fee2e2'} 0%, ${data.entryPossibility >= 70 ? '#a7f3d0' : data.entryPossibility >= 50 ? '#fde68a' : '#fecaca'} 100%); border-radius: 12px; border-left: 4px solid ${data.entryPossibility >= 70 ? '#10b981' : data.entryPossibility >= 50 ? '#f59e0b' : '#ef4444'};">
              <div style="font-weight: 700; color: ${data.entryPossibility >= 70 ? '#047857' : data.entryPossibility >= 50 ? '#92400e' : '#991b1b'}; margin-bottom: 8px; font-size: 16px;">
                ${data.entryPossibility >= 70 ? '✅ 진입 추천' : data.entryPossibility >= 50 ? '⚠️ 보통' : '❌ 진입 어려움'}
              </div>
              <div style="font-size: 14px; color: ${data.entryPossibility >= 70 ? '#065f46' : data.entryPossibility >= 50 ? '#78350f' : '#7f1d1d'}; line-height: 1.6;">
                ${data.entryPossibility >= 70 
                  ? '상위 노출 블로그들의 지수가 낮고 최신 글도 많지 않아 진입하기 좋은 키워드입니다. 지금 작성하면 상위 노출 가능성이 높습니다!' 
                  : data.entryPossibility >= 50 
                  ? '경쟁이 보통 수준입니다. 고품질 콘텐츠와 꾸준한 업데이트로 진입 가능합니다.' 
                  : '상위 노출 블로그들이 모두 고지수이고 최신 글이 많습니다. 다른 롱테일 키워드를 고려하거나, 차별화된 콘텐츠가 필요합니다.'}
              </div>
            </div>
          </div>
        `;
        
      } catch (error) {
        console.error('[BLOG-INDEX] 분석 실패:', error);
        resultsDiv.innerHTML = `
          <div style="text-align: center; padding: 40px; color: #ef4444;">
            <div style="font-size: 48px; margin-bottom: 16px;">😕</div>
            <div style="font-size: 18px; font-weight: 600; margin-bottom: 8px;">분석 실패</div>
            <div style="font-size: 14px; color: #64748b;">${error.message}</div>
          </div>
        `;
      }
    };

    // ========================================
    // 연상 키워드 마인드맵 무한확장 모달
    // ========================================
    window.createKeywordMindmapModal = function() {
      const modalHTML = `
        <div class="modal-overlay" onclick="closeModal()">
          <div class="modal-content" onclick="event.stopPropagation()" style="max-width: 1400px; max-height: 90vh; overflow-y: auto;">
            <button class="modal-close" onclick="closeModal()">✕</button>
            <h2 style="margin-bottom: 20px; font-size: 28px; font-weight: 800; background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
              ♾️ 연상키워드 마인드맵 무한확장
            </h2>
            
            <div style="margin-bottom: 24px; padding: 20px; background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border-radius: 12px; border-left: 4px solid #f59e0b;">
              <div style="font-weight: 600; color: #92400e; margin-bottom: 12px; font-size: 16px;">💡 무한확장 키워드 발굴이란?</div>
              <div style="font-size: 14px; color: #78350f; line-height: 1.6;">
                입력한 키워드로부터 <strong>연관 → 자동완성 → 연상 키워드</strong>를 무한 반복하여 수천 개의 키워드를 자동으로 발굴합니다.<br/>
                키워드마스터의 무한키워드 기능과 동일한 원리로 작동합니다. 중지 버튼을 누르기 전까지 계속 확장됩니다!
              </div>
            </div>

            <!-- 설정 영역 -->
            <div style="display: flex; gap: 16px; margin-bottom: 20px; flex-wrap: wrap; align-items: flex-end;">
              <div style="flex: 1; min-width: 200px;">
                <label style="display: block; margin-bottom: 8px; font-weight: 600; color: #374151; font-size: 14px;">시드 키워드</label>
                <input type="text" id="mindmapKeyword" placeholder="예: 다이어트, 부동산, 인테리어" 
                  style="width: 100%; padding: 14px 16px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 15px;"
                onkeypress="if(event.key==='Enter') window.generateMindmap()">
              </div>
              <div style="min-width: 140px;">
                <label style="display: block; margin-bottom: 8px; font-weight: 600; color: #374151; font-size: 14px;">확장 깊이</label>
                <select id="mindmapMaxDepth" style="width: 100%; padding: 14px 16px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 15px; cursor: pointer;">
                  <option value="3">3단계 (빠름)</option>
                  <option value="5" selected>5단계 (권장)</option>
                  <option value="10">10단계 (깊음)</option>
                  <option value="0">무제한</option>
                </select>
              </div>
              <div style="min-width: 140px;">
                <label style="display: block; margin-bottom: 8px; font-weight: 600; color: #374151; font-size: 14px;">목표 개수</label>
                <select id="mindmapTargetCount" style="width: 100%; padding: 14px 16px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 15px; cursor: pointer;">
                  <option value="100">100개</option>
                  <option value="500" selected>500개</option>
                  <option value="1000">1,000개</option>
                  <option value="5000">5,000개</option>
                  <option value="0">무제한</option>
                </select>
              </div>
            </div>

            <!-- 버튼 영역 -->
            <div style="display: flex; gap: 12px; margin-bottom: 20px;">
              <button id="startMindmapBtn" onclick="window.generateMindmap()" 
                style="flex: 1; padding: 14px 32px; background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: white; border: none; border-radius: 8px; font-weight: 700; cursor: pointer; font-size: 15px; box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3); display: flex; align-items: center; justify-content: center; gap: 8px;">
                <span>♾️</span> 무한확장 시작
              </button>
              <button id="stopMindmapBtn" onclick="window.stopMindmapGeneration()" 
                style="padding: 14px 24px; background: #ef4444; color: white; border: none; border-radius: 8px; font-weight: 700; cursor: pointer; font-size: 15px; display: none; align-items: center; justify-content: center; gap: 8px;">
                <span>⏹️</span> 중지
              </button>
              <button id="exportMindmapBtn" onclick="window.exportMindmapKeywords()" 
                style="padding: 14px 24px; background: #10b981; color: white; border: none; border-radius: 8px; font-weight: 700; cursor: pointer; font-size: 15px; display: none; align-items: center; justify-content: center; gap: 8px;">
                <span>📊</span> 엑셀 저장
              </button>
            </div>

            <div id="mindmapResults"></div>
          </div>
        </div>
      `;

      const container = document.getElementById('modalContainer');
      if (container) {
        container.innerHTML = modalHTML;
      }
    };

    // 무한확장 상태 관리
    window.mindmapRunning = false;
    window.mindmapKeywordsSet = new Set();
    window.mindmapKeywordsList = [];

    window.stopMindmapGeneration = function() {
      window.mindmapRunning = false;
      document.getElementById('stopMindmapBtn').style.display = 'none';
      document.getElementById('startMindmapBtn').style.display = 'flex';
      const statusEl = document.getElementById('mindmapProgressMessage');
      if (statusEl) {
        statusEl.textContent = '⏹️ 중지됨';
        statusEl.style.color = '#f59e0b';
      }
    };

    window.exportMindmapKeywords = function() {
      if (!window.mindmapKeywordsList || window.mindmapKeywordsList.length === 0) {
        alert('내보낼 키워드가 없습니다.');
        return;
      }

      try {
        let csv = '번호,키워드,깊이,소스\n';
        window.mindmapKeywordsList.forEach((item, idx) => {
          csv += `${idx + 1},"${item.keyword}",${item.depth},${item.source}\n`;
        });

        const blob = new Blob(['\ufeff' + csv], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = `무한키워드_${new Date().toISOString().slice(0, 10)}_${window.mindmapKeywordsList.length}개.csv`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        URL.revokeObjectURL(url);

        alert(`${window.mindmapKeywordsList.length.toLocaleString()}개 키워드가 저장되었습니다.`);
      } catch (error) {
        console.error('엑셀 저장 실패:', error);
        alert('저장 중 오류가 발생했습니다.');
      }
    };

    window.generateMindmap = async function() {
      const keywordInput = document.getElementById('mindmapKeyword');
      const resultsDiv = document.getElementById('mindmapResults');
      const maxDepthSelect = document.getElementById('mindmapMaxDepth');
      const targetCountSelect = document.getElementById('mindmapTargetCount');
      
      if (!keywordInput || !resultsDiv) return;
      
      const keyword = keywordInput.value.trim();
      if (!keyword) {
        alert('키워드를 입력해주세요.');
        return;
      }

      const maxDepth = parseInt(maxDepthSelect?.value || '5');
      const targetCount = parseInt(targetCountSelect?.value || '500');

      // 상태 초기화
      window.mindmapRunning = true;
      window.mindmapKeywordsSet = new Set();
      window.mindmapKeywordsList = [];

      // UI 업데이트
      document.getElementById('startMindmapBtn').style.display = 'none';
      document.getElementById('stopMindmapBtn').style.display = 'flex';
      document.getElementById('exportMindmapBtn').style.display = 'none';

      // 진행 상황 UI 생성
      let progressHTML = `
        <div style="padding: 24px; background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border-radius: 12px; margin-bottom: 20px;">
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
            <div style="font-weight: 700; font-size: 18px; color: #92400e;">♾️ 무한확장 중...</div>
            <div class="spinner" style="width: 24px; height: 24px; border: 3px solid #fde68a; border-top-color: #f59e0b;"></div>
          </div>
          <div id="mindmapProgressMessage" style="font-size: 14px; color: #78350f; margin-bottom: 12px;">준비 중...</div>
          <div style="width: 100%; height: 12px; background: rgba(245, 158, 11, 0.2); border-radius: 6px; overflow: hidden;">
            <div id="mindmapProgressBar" style="height: 100%; background: linear-gradient(90deg, #f59e0b 0%, #d97706 100%); width: 0%; transition: width 0.3s ease;"></div>
          </div>
          <div id="mindmapProgressStats" style="margin-top: 12px; font-size: 12px; color: #78350f; display: flex; gap: 16px;">
            <span>수집: <strong id="mindmapCollectedCount">0</strong>개</span>
            <span>대기: <strong id="mindmapQueueCount">0</strong>개</span>
            <span>깊이: <strong id="mindmapCurrentLevel">0</strong>/${maxDepth === 0 ? '∞' : maxDepth}</span>
          </div>
        </div>
        <div id="mindmapKeywordList" style="max-height: 400px; overflow-y: auto; border: 1px solid #e5e7eb; border-radius: 12px; padding: 16px; background: white;"></div>
      `;
      
      resultsDiv.innerHTML = progressHTML;

      try {
        // 무한확장 키워드 추출 시작
        await window.extractMindmapKeywords(keyword, 0, maxDepth, targetCount);
      } catch (error) {
        console.error('[MINDMAP] 생성 실패:', error);
      }

      // 완료 처리
      window.mindmapRunning = false;
      document.getElementById('startMindmapBtn').style.display = 'flex';
      document.getElementById('stopMindmapBtn').style.display = 'none';
      if (window.mindmapKeywordsList.length > 0) {
        document.getElementById('exportMindmapBtn').style.display = 'flex';
      }
      
      const statusEl = document.getElementById('mindmapProgressMessage');
      if (statusEl && window.mindmapKeywordsList.length > 0) {
        statusEl.textContent = `✅ 완료! ${window.mindmapKeywordsList.length.toLocaleString()}개 키워드 발굴`;
        statusEl.style.color = '#059669';
        statusEl.style.fontWeight = '700';
      }

      // 최종 결과 표시
      window.displayMindmapResults();
    };

    window.extractMindmapKeywords = async function(keyword, depth, maxDepth, targetCount) {
      if (!window.mindmapRunning) return;
      if (maxDepth > 0 && depth >= maxDepth) return;
      if (targetCount > 0 && window.mindmapKeywordsList.length >= targetCount) return;

      // 현재 키워드 표시
      const messageEl = document.getElementById('mindmapProgressMessage');
      if (messageEl) {
        messageEl.textContent = `확장 중: ${keyword} (깊이: ${depth})`;
      }

      // 이미 처리한 키워드는 스킵
      if (window.mindmapKeywordsSet.has(keyword.toLowerCase())) return;
      window.mindmapKeywordsSet.add(keyword.toLowerCase());

      // 키워드 추가
      if (keyword && keyword.length > 1) {
        window.mindmapKeywordsList.push({
          keyword: keyword,
          depth: depth,
          source: depth === 0 ? '시드' : '확장'
        });
        window.updateMindmapProgress(targetCount, maxDepth);
      }

      try {
        let relatedKeywords = [];

        // 1. 자동완성 키워드 가져오기
        if (window.blogger && typeof window.blogger.getAutoComplete === 'function') {
          try {
            const autoComplete = await window.blogger.getAutoComplete(keyword);
            if (Array.isArray(autoComplete)) {
              relatedKeywords = [...relatedKeywords, ...autoComplete.slice(0, 10)];
            }
          } catch (e) { /* 무시 */ }
        }

        // 2. 연관 키워드 가져오기 (네이버 검색광고 API)
        if (window.blogger && typeof window.blogger.getRelatedKeywords === 'function') {
          try {
            const related = await window.blogger.getRelatedKeywords(keyword);
            if (Array.isArray(related)) {
              relatedKeywords = [...relatedKeywords, ...related.slice(0, 10).map(r => r.keyword || r)];
            }
          } catch (e) { /* 무시 */ }
        }

        // 중복 제거
        relatedKeywords = [...new Set(relatedKeywords)].filter(k => k && !window.mindmapKeywordsSet.has(k.toLowerCase()));

        // 재귀적으로 각 연관 키워드 처리
        for (const relatedKw of relatedKeywords) {
          if (!window.mindmapRunning) break;
          if (targetCount > 0 && window.mindmapKeywordsList.length >= targetCount) break;
          
          await window.extractMindmapKeywords(relatedKw, depth + 1, maxDepth, targetCount);
          
          // 속도 조절 (API 제한 방지)
          await new Promise(resolve => setTimeout(resolve, 100));
        }
      } catch (error) {
        console.error(`키워드 확장 실패 (${keyword}):`, error);
      }
    };

    window.updateMindmapProgress = function(targetCount, maxDepth) {
      const count = window.mindmapKeywordsList.length;
      const collectedEl = document.getElementById('mindmapCollectedCount');
      const queueEl = document.getElementById('mindmapQueueCount');
      const levelEl = document.getElementById('mindmapCurrentLevel');
      const progressBarEl = document.getElementById('mindmapProgressBar');

      if (collectedEl) collectedEl.textContent = count.toLocaleString();
      if (queueEl) queueEl.textContent = window.mindmapKeywordsSet.size.toLocaleString();
      
      // 현재 최대 깊이 찾기
      const currentMaxDepth = window.mindmapKeywordsList.reduce((max, item) => Math.max(max, item.depth), 0);
      if (levelEl) levelEl.textContent = currentMaxDepth;

      if (progressBarEl) {
        if (targetCount > 0) {
          const percent = Math.min(100, (count / targetCount) * 100);
          progressBarEl.style.width = `${percent}%`;
        } else {
          progressBarEl.style.width = '100%';
        }
      }

      // 실시간 결과 업데이트 (30개마다)
      if (count % 30 === 0) {
        window.displayMindmapResults();
      }
    };

    window.displayMindmapResults = function() {
      const listDiv = document.getElementById('mindmapKeywordList');
      if (!listDiv) return;

      if (window.mindmapKeywordsList.length === 0) {
        listDiv.innerHTML = '<div style="text-align: center; padding: 40px; color: #64748b;">키워드를 발굴하는 중...</div>';
        return;
      }

      // 레벨별로 그룹화
      const levelGroups = {};
      window.mindmapKeywordsList.forEach(item => {
        if (!levelGroups[item.depth]) levelGroups[item.depth] = [];
        levelGroups[item.depth].push(item.keyword);
      });

      let html = `
        <div style="margin-bottom: 16px; padding: 16px; background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border-radius: 12px; border-left: 4px solid #f59e0b;">
          <div style="font-size: 18px; font-weight: 700; color: #92400e;">♾️ 발굴된 키워드: ${window.mindmapKeywordsList.length.toLocaleString()}개</div>
              </div>
      `;

      Object.keys(levelGroups).sort((a, b) => a - b).forEach(level => {
        const keywords = levelGroups[level];
        html += `
          <div style="margin-bottom: 20px;">
            <div style="font-weight: 700; color: #92400e; margin-bottom: 12px; font-size: 14px; display: flex; align-items: center; gap: 8px;">
              <span style="padding: 4px 12px; background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border-radius: 16px; font-size: 12px;">
                    Level ${level}
                  </span>
              <span style="font-size: 12px; color: #9ca3af;">${keywords.length}개</span>
                </div>
            <div style="display: flex; flex-wrap: wrap; gap: 6px;">
              ${keywords.slice(0, 50).map(kw => `
                <div style="padding: 6px 12px; background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 16px; font-size: 13px; color: #1e293b; cursor: pointer; transition: all 0.2s;"
                     onmouseover="this.style.background='#fef3c7'; this.style.borderColor='#f59e0b'"
                     onmouseout="this.style.background='#f9fafb'; this.style.borderColor='#e5e7eb'">
                      ${kw}
                    </div>
                  `).join('')}
              ${keywords.length > 50 ? `<div style="padding: 6px 12px; color: #9ca3af; font-size: 13px;">... 외 ${keywords.length - 50}개</div>` : ''}
                </div>
              </div>
        `;
      });

      listDiv.innerHTML = html;
    };

