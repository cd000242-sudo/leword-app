        ">
          <div style="
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            font-size: 40px;
          ">🔒</div>
          
          <h2 style="
            color: #f8fafc;
            font-size: 24px;
            font-weight: 700;
            margin: 0 0 12px 0;
          ">프리미엄 인증이 필요합니다</h2>
          
          <p style="
            color: #94a3b8;
            font-size: 16px;
            line-height: 1.6;
            margin: 0 0 32px 0;
          ">
            이 기능은 <strong style="color: #fbbf24;">3개월 이상 구매자 전용</strong>입니다.<br>
            프리미엄 라이선스를 등록하시면 모든 프리미엄 기능을<br>
            이용하실 수 있습니다.
          </p>
          
          <div style="
            background: rgba(251, 191, 36, 0.1);
            border: 1px solid rgba(251, 191, 36, 0.3);
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 24px;
          ">
            <div style="color: #fbbf24; font-weight: 600; margin-bottom: 8px;">💎 프리미엄 혜택</div>
            <div style="color: #94a3b8; font-size: 14px; line-height: 1.8;">
              ✅ PRO 트래픽 키워드 헌터 (영구제)<br>
              ✅ 트래픽 폭발 키워드 헌터<br>
              ✅ 황금 롱테일 키워드 발굴기<br>
              ✅ 유튜브 황금키워드 분석기
            </div>
          </div>
          
          <div style="display: flex; gap: 12px; justify-content: center;">
            <button onclick="closePremiumRequiredModal()" style="
              padding: 14px 28px;
              background: #334155;
              color: #f8fafc;
              border: none;
              border-radius: 12px;
              font-size: 16px;
              font-weight: 600;
              cursor: pointer;
              transition: all 0.2s;
            " onmouseover="this.style.background='#475569'" onmouseout="this.style.background='#334155'">닫기</button>
            
            <button onclick="closePremiumRequiredModal(); openLicenseModal();" style="
              padding: 14px 28px;
              background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
              color: white;
              border: none;
              border-radius: 12px;
              font-size: 16px;
              font-weight: 700;
              cursor: pointer;
              transition: all 0.2s;
              box-shadow: 0 4px 15px rgba(245, 158, 11, 0.4);
            " onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 20px rgba(245, 158, 11, 0.5)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 15px rgba(245, 158, 11, 0.4)'">🔑 라이선스 등록하기</button>
          </div>
        </div>
      `;
      
      document.body.appendChild(modal);
      
      // 배경 클릭시 닫기
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          closePremiumRequiredModal();
        }
      });
    }
    
    function closePremiumRequiredModal() {
      const modal = document.getElementById('premiumRequiredModal');
      if (modal) {
        modal.remove();
      }
    }
    
    // 범용 입력 모달
    function showInputModal(title, placeholder, callback) {
      const modal = document.createElement('div');
      modal.id = 'inputModal';
      modal.style.cssText = `
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center;
        z-index: 10000; animation: fadeIn 0.3s ease;
      `;
      
      modal.innerHTML = `
        <div style="background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
          border-radius: 16px; padding: 32px; max-width: 500px; width: 90%;
          box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5); border: 1px solid rgba(255, 255, 255, 0.1);">
          <h3 style="color: white; margin: 0 0 20px 0; font-size: 20px;">${title}</h3>
          <input type="text" id="inputModalValue" placeholder="${placeholder}" 
            style="width: 100%; padding: 14px 16px; background: rgba(255, 255, 255, 0.1);
            border: 2px solid rgba(255, 255, 255, 0.2); border-radius: 8px; color: white;
            font-size: 15px; margin-bottom: 20px; box-sizing: border-box;"
            onfocus="this.style.borderColor='#3b82f6'" onblur="this.style.borderColor='rgba(255, 255, 255, 0.2)'">
          <div style="display: flex; gap: 12px; justify-content: flex-end;">
            <button onclick="closeInputModal()" style="padding: 12px 24px; background: #334155;
              color: white; border: none; border-radius: 8px; cursor: pointer; font-weight: 600;">취소</button>
            <button onclick="submitInputModal()" style="padding: 12px 24px;
              background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); color: white;
              border: none; border-radius: 8px; cursor: pointer; font-weight: 600;">확인</button>
          </div>
        </div>
      `;
      
      document.body.appendChild(modal);
      document.getElementById('inputModalValue').focus();
      
      window._inputModalCallback = callback;
      
      // Enter 키로 제출
      document.getElementById('inputModalValue').addEventListener('keypress', (e) => {
        if (e.key === 'Enter') submitInputModal();
      });
    }
    
    function closeInputModal() {
      const modal = document.getElementById('inputModal');
      if (modal) modal.remove();
      window._inputModalCallback = null;
    }
    
    function submitInputModal() {
      const value = document.getElementById('inputModalValue')?.value?.trim();
      const callback = window._inputModalCallback;
      closeInputModal();
      if (callback && value) callback(value);
    }
    
    // 수익 예측 입력 모달
    function showRevenueInputModal() {
      const modal = document.createElement('div');
      modal.id = 'revenueInputModal';
      modal.style.cssText = `
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center;
        z-index: 10000; animation: fadeIn 0.3s ease;
      `;
      
      modal.innerHTML = `
        <div style="background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
          border-radius: 16px; padding: 32px; max-width: 500px; width: 90%;
          box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5); border: 1px solid rgba(255, 255, 255, 0.1);">
          <h3 style="color: white; margin: 0 0 20px 0; font-size: 20px;">💰 수익 예측 계산</h3>
          <div style="margin-bottom: 16px;">
            <label style="display: block; color: rgba(255,255,255,0.7); margin-bottom: 8px; font-size: 14px;">키워드</label>
            <input type="text" id="revKeywordInput" placeholder="키워드 입력" 
              style="width: 100%; padding: 12px; background: rgba(255,255,255,0.1);
              border: 2px solid rgba(255,255,255,0.2); border-radius: 8px; color: white;
              font-size: 14px; box-sizing: border-box;">
          </div>
          <div style="margin-bottom: 16px;">
            <label style="display: block; color: rgba(255,255,255,0.7); margin-bottom: 8px; font-size: 14px;">월간 검색량</label>
            <input type="number" id="revSearchVolume" placeholder="1000" value="1000"
              style="width: 100%; padding: 12px; background: rgba(255,255,255,0.1);
              border: 2px solid rgba(255,255,255,0.2); border-radius: 8px; color: white;
              font-size: 14px; box-sizing: border-box;">
          </div>
          <div style="margin-bottom: 20px;">
            <label style="display: block; color: rgba(255,255,255,0.7); margin-bottom: 8px; font-size: 14px;">경쟁도 점수 (0-10)</label>
            <input type="number" id="revCompetition" placeholder="5" value="5" min="0" max="10"
              style="width: 100%; padding: 12px; background: rgba(255,255,255,0.1);
              border: 2px solid rgba(255,255,255,0.2); border-radius: 8px; color: white;
              font-size: 14px; box-sizing: border-box;">
          </div>
          <div style="display: flex; gap: 12px; justify-content: flex-end;">
            <button onclick="document.getElementById('revenueInputModal').remove()" 
              style="padding: 12px 24px; background: #334155; color: white; border: none; border-radius: 8px; cursor: pointer; font-weight: 600;">취소</button>
            <button onclick="submitRevenueCalculation()" 
              style="padding: 12px 24px; background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
              color: white; border: none; border-radius: 8px; cursor: pointer; font-weight: 600;">계산하기</button>
          </div>
        </div>
      `;
      
      document.body.appendChild(modal);
      document.getElementById('revKeywordInput').focus();
    }
    
    function submitRevenueCalculation() {
      const keyword = document.getElementById('revKeywordInput')?.value?.trim();
      const searchVolume = parseInt(document.getElementById('revSearchVolume')?.value) || 1000;
      const competition = parseFloat(document.getElementById('revCompetition')?.value) || 5;
      document.getElementById('revenueInputModal')?.remove();
      if (keyword) {
        calculateRevenue(keyword, searchVolume, competition);
      }
    }
    
    // SEO 체크리스트 입력 모달
    function showSEOChecklistModal() {
      const modal = document.createElement('div');
      modal.id = 'seoChecklistModal';
      modal.style.cssText = `
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center;
        z-index: 10000; animation: fadeIn 0.3s ease;
      `;
      
      modal.innerHTML = `
        <div style="background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
          border-radius: 16px; padding: 32px; max-width: 600px; width: 90%;
          box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5); border: 1px solid rgba(255, 255, 255, 0.1);">
          <h3 style="color: white; margin: 0 0 20px 0; font-size: 20px;">✅ SEO 체크리스트</h3>
          <div style="margin-bottom: 16px;">
            <label style="display: block; color: rgba(255,255,255,0.7); margin-bottom: 8px; font-size: 14px;">타겟 키워드</label>
            <input type="text" id="seoKeywordInput" placeholder="키워드 입력" 
              style="width: 100%; padding: 12px; background: rgba(255,255,255,0.1);
              border: 2px solid rgba(255,255,255,0.2); border-radius: 8px; color: white;
              font-size: 14px; box-sizing: border-box;">
          </div>
          <div style="margin-bottom: 20px;">
            <label style="display: block; color: rgba(255,255,255,0.7); margin-bottom: 8px; font-size: 14px;">콘텐츠 (블로그 글 내용)</label>
            <textarea id="seoContentInput" placeholder="분석할 콘텐츠를 입력하세요..." rows="6"
              style="width: 100%; padding: 12px; background: rgba(255,255,255,0.1);
              border: 2px solid rgba(255,255,255,0.2); border-radius: 8px; color: white;
              font-size: 14px; box-sizing: border-box; resize: vertical;"></textarea>
          </div>
          <div style="display: flex; gap: 12px; justify-content: flex-end;">
            <button onclick="document.getElementById('seoChecklistModal').remove()" 
              style="padding: 12px 24px; background: #334155; color: white; border: none; border-radius: 8px; cursor: pointer; font-weight: 600;">취소</button>
            <button onclick="submitSEOChecklist()" 
              style="padding: 12px 24px; background: linear-gradient(135deg, #10b981 0%, #059669 100%);
              color: white; border: none; border-radius: 8px; cursor: pointer; font-weight: 600;">분석하기</button>
          </div>
        </div>
      `;
      
      document.body.appendChild(modal);
      document.getElementById('seoKeywordInput').focus();
    }
    
    function submitSEOChecklist() {
      const keyword = document.getElementById('seoKeywordInput')?.value?.trim();
      const content = document.getElementById('seoContentInput')?.value?.trim() || '테스트';
      document.getElementById('seoChecklistModal')?.remove();
      if (keyword) {
        evaluateSEO(content, keyword);
      }
    }
    
