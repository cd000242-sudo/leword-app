<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; font-src 'self' https://cdn.jsdelivr.net data:; img-src 'self' data: https:; connect-src 'self' https:;">
    <title>LEWORD - 키워드마스터</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/pretendard/dist/web/static/pretendard.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    }

    body {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      padding: 24px;
      color: #1e293b;
    }

    .keyword-master-container {
      max-width: 1400px;
      margin: 0 auto;
      background: rgba(255, 255, 255, 0.95);
      border-radius: 24px;
      padding: 32px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
      backdrop-filter: blur(20px);
    }

    .page-header {
      text-align: center;
      margin-bottom: 48px;
      padding-bottom: 24px;
      border-bottom: 2px solid #e0e0e0;
    }

    .page-header h1 {
      font-size: 42px;
      font-weight: 700;
      background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 12px;
    }

    .page-header p {
      font-size: 18px;
      color: #64748b;
      font-weight: 500;
    }

    .main-feature {
      margin-bottom: 48px;
    }

    .golden-keyword-finder {
      background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
      border-radius: 24px;
      padding: 40px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(20px);
    }

    .golden-keyword-finder h2 {
      font-size: 32px;
      font-weight: 800;
      background: linear-gradient(135deg, #60a5fa 0%, #a78bfa 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 32px;
      display: flex;
      align-items: center;
      gap: 16px;
      letter-spacing: -0.5px;
    }

    .keyword-input-section {
      display: flex;
      gap: 16px;
      margin-bottom: 28px;
      flex-direction: column;
    }

    .keyword-input-section input {
      flex: 1;
      padding: 18px 24px;
      border: 2px solid rgba(96, 165, 250, 0.3);
      border-radius: 16px;
      font-size: 16px;
      background: rgba(30, 41, 59, 0.8);
      color: #ffffff;
      transition: all 0.3s ease;
      font-weight: 600;
    }

    .keyword-input-section input:focus {
      outline: none;
      border-color: #60a5fa;
      box-shadow: 0 0 0 4px rgba(96, 165, 250, 0.2);
      background: rgba(30, 41, 59, 1);
    }
    
    .keyword-input-section select {
      transition: all 0.3s ease;
      color: #ffffff !important;
      background-color: rgba(30, 41, 59, 0.8) !important;
    }
    
    .keyword-input-section select:focus {
      outline: none;
      border-color: #60a5fa;
      box-shadow: 0 0 0 4px rgba(96, 165, 250, 0.2);
      background: rgba(30, 41, 59, 1) !important;
    }
    
    /* 드롭다운 옵션 스타일 */
    .keyword-input-section select option {
      background-color: #ffffff !important;
      color: #1e293b !important;
      font-weight: 600;
      padding: 12px 16px;
    }
    
    /* 드롭다운 옵션 호버/선택 상태 */
    .keyword-input-section select option:hover,
    .keyword-input-section select option:checked,
    .keyword-input-section select option:focus {
      background-color: #60a5fa !important;
      color: #ffffff !important;
    }
    
    /* optgroup 라벨 스타일 */
    .keyword-input-section select optgroup {
      background-color: #f8fafc !important;
      color: #1e293b !important;
      font-weight: 700;
      font-size: 13px;
      padding: 8px 12px;
    }
    
    /* optgroup 내 옵션들 */
    .keyword-input-section select optgroup option {
      background-color: #ffffff !important;
      color: #1e293b !important;
      padding-left: 24px;
      font-weight: 500;
    }
    
    /* optgroup 내 옵션 호버 */
    .keyword-input-section select optgroup option:hover {
      background-color: #e0e7ff !important;
      color: #1e293b !important;
    }

    .keyword-input-section button {
      padding: 16px 32px;
      background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
      border: none;
      border-radius: 12px;
      color: white;
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: 0 4px 15px rgba(217, 119, 6, 0.3);
    }

    .keyword-input-section button:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(217, 119, 6, 0.4);
    }

    .keyword-input-section button:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      transform: none;
    }

    .additional-features {
      margin-top: 48px;
      padding-top: 32px;
      border-top: 2px solid #e0e0e0;
    }

    .additional-features h2 {
      font-size: 32px;
      font-weight: 700;
      margin-bottom: 32px;
      text-align: center;
      color: #1e293b;
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
      max-width: 1000px;
      margin: 0 auto;
    }

    .feature-button {
      background: white;
      border: none;
      border-radius: 20px;
      padding: 32px 28px;
      text-align: left;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
      position: relative;
      overflow: hidden;
      min-height: 180px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .feature-button::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
      transition: left 0.5s;
    }

    .feature-button:hover::before {
      left: 100%;
    }

    .feature-button:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
    }

    .feature-button .icon {
      font-size: 56px;
      margin-bottom: 20px;
      display: block;
      line-height: 1;
    }

    .feature-button .title {
      font-size: 24px;
      font-weight: 700;
      margin-bottom: 12px;
      color: #1e293b;
      line-height: 1.3;
    }

    .feature-button .description {
      font-size: 16px;
      color: #64748b;
      line-height: 1.6;
    }

    .feature-button.red { border-left: 4px solid #ef4444; }
    .feature-button.blue { border-left: 4px solid #3b82f6; }
    .feature-button.purple { border-left: 4px solid #8b5cf6; }
    .feature-button.green { border-left: 4px solid #10b981; }
    .feature-button.orange { border-left: 4px solid #f59e0b; }
    .feature-button.indigo { border-left: 4px solid #6366f1; }
    .feature-button.pink { border-left: 4px solid #ec4899; }
    .feature-button.cyan { border-left: 4px solid #06b6d4; }

    /* 모달 스타일 */
    .modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.7);
      display: flex;
        align-items: flex-start;
      justify-content: center;
      z-index: 1000;
      animation: fadeIn 0.2s;
      backdrop-filter: blur(5px);
        overflow-y: auto;
        padding: 20px;
        box-sizing: border-box;
        /* 스크롤 가능하게 설정 */
      }
      
      /* 스크롤에 따라 모달 위치 조정 */
      body.scrolling .modal-overlay {
        align-items: flex-start;
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    .modal-content {
      background: white;
      border-radius: 20px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
      max-height: calc(100vh - 40px);
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      animation: slideUp 0.3s;
      width: 90%;
      max-width: 1400px;
      /* 스크롤 시 모달이 따라다니도록 */
      margin: 20px auto;
      position: relative;
      /* 스크롤 시 상단에서 20px 떨어진 위치 유지 */
      align-self: flex-start;
      margin-top: 20px;
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 24px 32px;
      border-bottom: 2px solid #e0e0e0;
      background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
    }

    .modal-header h2 {
      margin: 0;
      font-size: 24px;
      font-weight: 700;
      color: #1e293b;
    }

    .close-btn,
    .modal-close {
      background: #ef4444;
      border: none;
      width: 40px;
      height: 40px;
      border-radius: 10px;
      font-size: 24px;
      color: white;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s ease;
      line-height: 1;
      z-index: 100;
    }

    .close-btn:hover,
    .modal-close:hover {
      background: #dc2626;
      transform: scale(1.1);
    }
    
    .close-btn:active,
    .modal-close:active {
      transform: scale(0.95);
    }

    .modal-body {
      padding: 32px;
      overflow-y: auto;
      flex: 1;
    }

    .result-container {
      margin-top: 24px;
    }

    .result-item {
      padding: 16px;
      background: #f8fafc;
      border-radius: 12px;
      margin-bottom: 12px;
      border-left: 4px solid #3b82f6;
      transition: all 0.2s ease;
    }

    .result-item:hover {
      background: #f1f5f9;
      transform: translateX(4px);
    }

    .loading {
      text-align: center;
      padding: 40px;
      color: #64748b;
      font-size: 16px;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
      margin-bottom: 24px;
    }

    .stat-card {
      padding: 24px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      border-radius: 16px;
      color: white;
      text-align: center;
    }

    .stat-card .label {
      font-size: 14px;
      opacity: 0.9;
      margin-bottom: 8px;
    }

    .stat-card .value {
      font-size: 32px;
      font-weight: 700;
    }

    @media (max-width: 768px) {
      .features-grid {
        grid-template-columns: 1fr;
      }
      
      .keyword-input-section {
        flex-direction: column;
      }
    }
  </style>
</head>
<body>
  <div class="keyword-master-container">
    <!-- 우측 상단 프리미엄 버튼 (고정) -->
    <button id="premiumFloatingBtn" onclick="showPremiumTab()" style="position: fixed; top: 20px; right: 20px; z-index: 1000; padding: 12px 24px; background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%); color: white; border: none; border-radius: 25px; font-size: 14px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 8px; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(251, 191, 36, 0.4);" onmouseover="this.style.transform='translateY(-2px) scale(1.05)'; this.style.boxShadow='0 6px 20px rgba(251, 191, 36, 0.5)'" onmouseout="this.style.transform='translateY(0) scale(1)'; this.style.boxShadow='0 4px 15px rgba(251, 191, 36, 0.4)'">
      <span>👑</span>
      <span>프리미엄 기능</span>
    </button>
    
    <!-- 헤더 -->
    <div class="page-header">
      <h1>💎LEWORD</h1>
      <p style="font-family: 'Brush Script MT', 'Lucida Handwriting', 'Comic Sans MS', cursive, serif; font-style: italic; font-size: 24px; color: #f59e0b;">leadernam gold keywrod</p>
      
      <!-- 라이선스 상태 배지 -->
      <div style="margin-top: 20px; display: flex; justify-content: center; align-items: center; gap: 12px; flex-wrap: wrap;">
        <div id="licenseBadge" style="padding: 8px 16px; border-radius: 20px; background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%); color: #475569; font-size: 13px; font-weight: 600; display: inline-flex; align-items: center; gap: 6px;">
          <span>👤</span>
          <span>무료 사용자</span>
        </div>
      </div>

      <!-- API 키 연동 상태 배지 -->
      <div style="margin-top: 12px; display: flex; justify-content: center; align-items: center; gap: 12px; flex-wrap: wrap;">
        <div id="naverApiBadge" style="padding: 8px 16px; border-radius: 20px; background: #fee2e2; color: #991b1b; font-size: 13px; font-weight: 600; display: inline-flex; align-items: center; gap: 6px;">
          <span>⚠️</span>
          <span>네이버 API: 미연동</span>
        </div>
        <div id="youtubeApiBadge" style="padding: 8px 16px; border-radius: 20px; background: #fee2e2; color: #991b1b; font-size: 13px; font-weight: 600; display: inline-flex; align-items: center; gap: 6px;">
          <span>⚠️</span>
          <span>유튜브 API: 미연동</span>
        </div>
        <div id="naverSearchAdApiBadge" style="padding: 8px 16px; border-radius: 20px; background: #fee2e2; color: #991b1b; font-size: 13px; font-weight: 600; display: inline-flex; align-items: center; gap: 6px;">
          <span>⚠️</span>
          <span>검색광고 API: 미연동</span>
        </div>
        <button onclick="openKeywordSettingsModal()" style="padding: 8px 16px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; border-radius: 20px; font-size: 13px; font-weight: 600; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; transition: all 0.3s ease; box-shadow: 0 2px 8px rgba(102, 126, 234, 0.3);" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 4px 12px rgba(102, 126, 234, 0.4)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 8px rgba(102, 126, 234, 0.3)'">
          <span>⚙️</span>
          <span>키워드 설정</span>
        </button>
      </div>
    </div>

    <!-- 실시간 검색어 모니터링 섹션 (2x2 그리드) -->
    <div id="realtimeKeywordsSection" style="margin-bottom: 32px; padding: 20px; background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%); border-radius: 16px; border: 2px solid #cbd5e1;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
        <h3 style="font-size: 20px; font-weight: 700; color: #1e293b; margin: 0;">
          📊 실시간 검색어 모니터링
        </h3>
        <div style="display: flex; gap: 8px; align-items: center;">
          <span id="realtimeTimestamp" style="font-size: 12px; color: #64748b;">마지막 업데이트: -</span>
              <button id="refreshRealtimeTop" 
                style="padding: 8px 16px; border: none; border-radius: 8px; background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%); color: white; font-weight: 600; cursor: pointer; font-size: 12px;">
                🔄 새로고침
              </button>
        </div>
      </div>
      
      <!-- 2x2 그리드 레이아웃 -->
      <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;">
        <!-- 네이버 (Signal.bz) - 메인! -->
        <div style="background: white; border-radius: 16px; padding: 20px; border: 3px solid #03c75a; box-shadow: 0 4px 12px rgba(3, 199, 90, 0.3);">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
            <div style="font-size: 18px; font-weight: 700; color: #03c75a;">
              🟢 네이버 <span style="font-size: 11px; color: #888; font-weight: 400;">(signal.bz)</span>
            </div>
            <a href="https://signal.bz/" target="_blank" style="font-size: 11px; color: #03c75a; text-decoration: none;">바로가기 →</a>
          </div>
          <div id="naverKeywordsTop" style="max-height: 280px; overflow-y: auto; font-size: 15px;">
            <div style="text-align: center; padding: 15px; color: #64748b;">로딩 중...</div>
          </div>
        </div>

        <!-- ZUM -->
        <div style="background: white; border-radius: 16px; padding: 20px; border: 3px solid #fbbf24; box-shadow: 0 4px 12px rgba(251, 191, 36, 0.2);">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
            <div style="font-size: 18px; font-weight: 700; color: #92400e;">
            🔥 ZUM
          </div>
            <a href="https://zum.com/" target="_blank" style="font-size: 11px; color: #92400e; text-decoration: none;">바로가기 →</a>
          </div>
          <div id="zumKeywordsTop" style="max-height: 280px; overflow-y: auto; font-size: 15px;">
            <div style="text-align: center; padding: 15px; color: #64748b;">로딩 중...</div>
          </div>
        </div>

        <!-- 네이트 -->
        <div style="background: white; border-radius: 16px; padding: 20px; border: 3px solid #ec4899; box-shadow: 0 4px 12px rgba(236, 72, 153, 0.2);">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
            <div style="font-size: 18px; font-weight: 700; color: #be185d;">
            💜 네이트
          </div>
            <a href="https://www.nate.com/" target="_blank" style="font-size: 11px; color: #be185d; text-decoration: none;">바로가기 →</a>
          </div>
          <div id="nateKeywordsTop" style="max-height: 280px; overflow-y: auto; font-size: 15px;">
            <div style="text-align: center; padding: 15px; color: #64748b;">로딩 중...</div>
          </div>
        </div>

        <!-- 다음 -->
        <div style="background: white; border-radius: 16px; padding: 20px; border: 3px solid #10b981; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
            <div style="font-size: 18px; font-weight: 700; color: #065f46;">
              🟡 다음
          </div>
            <a href="https://www.daum.net/" target="_blank" style="font-size: 11px; color: #065f46; text-decoration: none;">바로가기 →</a>
          </div>
          <div id="daumKeywordsTop" style="max-height: 280px; overflow-y: auto; font-size: 15px;">
            <div style="text-align: center; padding: 15px; color: #64748b;">로딩 중...</div>
          </div>
        </div>
      </div>
    </div>

    <!-- 사이트 바로가기 섹션 (실시간 검색어 아래) -->
    <div style="margin-bottom: 32px; padding: 24px; background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%); border-radius: 16px; border: 1px solid #e2e8f0;">
      <h3 style="font-size: 18px; font-weight: 700; color: #1e293b; margin: 0 0 20px 0; text-align: center;">
        🔗 키워드 찾으러 바로가기
      </h3>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px;">
        <button onclick="window.blogger?.openLink?.('https://news.naver.com/main/ranking/popularDay.naver') || window.open('https://news.naver.com/main/ranking/popularDay.naver', '_blank')" 
          style="background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border: none; border-radius: 12px; padding: 20px; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 2px 8px rgba(0,0,0,0.1);"
          onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 4px 12px rgba(0,0,0,0.15)';"
          onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 8px rgba(0,0,0,0.1)';">
          <div style="font-size: 32px; text-align: center; margin-bottom: 12px;">📰</div>
          <div style="font-size: 16px; font-weight: 700; color: #1e293b; margin-bottom: 6px; text-align: center;">네이버 뉴스 랭킹</div>
          <div style="font-size: 12px; color: #64748b; text-align: center; line-height: 1.4;">실시간 인기 뉴스 확인</div>
        </button>

        <button onclick="window.blogger?.openLink?.('https://creator-advisor.naver.com/introduction') || window.open('https://creator-advisor.naver.com/introduction', '_blank')" 
          style="background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%); border: none; border-radius: 12px; padding: 20px; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 2px 8px rgba(0,0,0,0.1);"
          onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 4px 12px rgba(0,0,0,0.15)';"
          onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 8px rgba(0,0,0,0.1)';">
          <div style="font-size: 32px; text-align: center; margin-bottom: 12px;">💡</div>
          <div style="font-size: 16px; font-weight: 700; color: #1e293b; margin-bottom: 6px; text-align: center;">네이버 크리에이터<br/>어드바이저</div>
          <div style="font-size: 12px; color: #64748b; text-align: center; line-height: 1.4;">콘텐츠 제작 가이드</div>
        </button>

        <button onclick="openModal('google-trends')" 
          style="background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%); border: none; border-radius: 12px; padding: 20px; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 2px 8px rgba(0,0,0,0.1);"
          onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 4px 12px rgba(0,0,0,0.15)';"
          onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 8px rgba(0,0,0,0.1)';">
          <div style="font-size: 32px; text-align: center; margin-bottom: 12px;">🔵</div>
          <div style="font-size: 16px; font-weight: 700; color: #1e293b; margin-bottom: 6px; text-align: center;">Google Trends</div>
          <div style="font-size: 12px; color: #64748b; text-align: center; line-height: 1.4;">실시간 트렌드<br/>키워드 확인</div>
        </button>

        <button onclick="window.blogger?.openLink?.('https://www.korea.kr/news/policyBriefingList.do') || window.open('https://www.korea.kr/news/policyBriefingList.do', '_blank')" 
          style="background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%); border: none; border-radius: 12px; padding: 20px; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 2px 8px rgba(0,0,0,0.1);"
          onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 4px 12px rgba(0,0,0,0.15)';"
          onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 8px rgba(0,0,0,0.1)';">
          <div style="font-size: 32px; text-align: center; margin-bottom: 12px;">🇰🇷</div>
          <div style="font-size: 16px; font-weight: 700; color: #1e293b; margin-bottom: 6px; text-align: center;">대한민국<br/>정책브리핑</div>
          <div style="font-size: 12px; color: #64748b; text-align: center; line-height: 1.4;">정책 뉴스 확인</div>
        </button>
      </div>
    </div>

    <!-- 메인 기능: 키워드 발굴 -->
    <div class="main-feature">
      <div class="golden-keyword-finder">
        <div style="display: flex; align-items: center; justify-content: center; gap: 12px; margin-bottom: 16px;">
          <h2 style="margin: 0;">LEWORD 키워드 조회</h2>
          <span onclick="showFeatureGuide('keyword-search');" style="width: 32px; height: 32px; background: rgba(255,255,255,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s; font-size: 16px;" onmouseover="this.style.background='rgba(255,255,255,0.3)'; this.style.transform='scale(1.1)'" onmouseout="this.style.background='rgba(255,255,255,0.2)'; this.style.transform='scale(1)'">❓</span>
        </div>
        <div style="margin-bottom: 24px; padding: 20px; background: rgba(96, 165, 250, 0.1); border-radius: 12px; border-left: 4px solid #60a5fa;">
          <p style="color: rgba(255, 255, 255, 0.9); font-size: 14px; line-height: 1.6; margin: 0;">
            <strong style="color: #60a5fa;">💡 키워드마스터 기능:</strong><br>
            • <strong>검색량 빠른 확인:</strong> 온라인 부업 및 사업에 필수적인 PC/모바일 검색량을 빠르게 확인할 수 있습니다.<br>
            • <strong>정확한 문서수:</strong> 각 키워드에 대한 정확한 문서수와 경쟁률을 제공합니다.<br>
            • <strong>광범위한 키워드 추출:</strong> 입력한 키워드에서 파생되는 다양한 관련 키워드를 자동으로 추출합니다 (가격, 비용, 종류, 기간, 보험 등).<br>
            • <strong>깊이 있는 확장:</strong> 연관 키워드의 연관 키워드를 재귀적으로 탐색하여 더 많은 키워드를 발견합니다.
          </p>
        </div>
        <div class="keyword-input-section" style="display: flex; flex-direction: column; gap: 16px;">
          <!-- 카테고리 및 소스 선택 -->
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div>
              <label style="display: block; margin-bottom: 8px; font-size: 13px; font-weight: 600; color: rgba(255, 255, 255, 0.7); text-transform: uppercase; letter-spacing: 0.5px;">검색 소스</label>
              <select id="keywordSource" style="width: 100%; padding: 14px 18px; border: 2px solid rgba(96, 165, 250, 0.3); border-radius: 12px; font-size: 15px; font-weight: 600; background: rgba(30, 41, 59, 0.8); color: #ffffff;">
                <option value="naver" style="background: #ffffff; color: #1e293b;">네이버</option>
            </select>
            </div>
            <div>
              <label style="display: block; margin-bottom: 8px; font-size: 13px; font-weight: 600; color: rgba(255, 255, 255, 0.7); text-transform: uppercase; letter-spacing: 0.5px;">카테고리</label>
              <select id="keywordCategory" style="width: 100%; padding: 14px 18px; border: 2px solid rgba(96, 165, 250, 0.3); border-radius: 12px; font-size: 15px; font-weight: 600; background: rgba(30, 41, 59, 0.8); color: #ffffff;">
              <option value="" style="background: #ffffff; color: #1e293b; font-weight: 700;">전체 카테고리</option>
              <optgroup label="📰 뉴스/시사" style="background: #f8fafc; color: #1e293b; font-weight: 700;">
                <option value="정치" style="background: #ffffff; color: #1e293b;">정치</option>
                <option value="경제" style="background: #ffffff; color: #1e293b;">경제</option>
                <option value="사회" style="background: #ffffff; color: #1e293b;">사회</option>
                <option value="국제" style="background: #ffffff; color: #1e293b;">국제/세계</option>
              </optgroup>
              <optgroup label="💻 기술/IT" style="background: #f8fafc; color: #1e293b; font-weight: 700;">
                <option value="IT" style="background: #ffffff; color: #1e293b;">IT/테크</option>
                <option value="과학" style="background: #ffffff; color: #1e293b;">과학</option>
                <option value="스마트폰" style="background: #ffffff; color: #1e293b;">스마트폰</option>
                <option value="컴퓨터" style="background: #ffffff; color: #1e293b;">컴퓨터/PC</option>
                <option value="AI" style="background: #ffffff; color: #1e293b;">AI/인공지능</option>
              </optgroup>
              <optgroup label="🏠 생활/문화" style="background: #f8fafc; color: #1e293b; font-weight: 700;">
                <option value="생활" style="background: #ffffff; color: #1e293b;">생활</option>
                <option value="건강" style="background: #ffffff; color: #1e293b;">건강/의료</option>
                <option value="육아" style="background: #ffffff; color: #1e293b;">육아/임신</option>
                <option value="반려동물" style="background: #ffffff; color: #1e293b;">반려동물</option>
                <option value="인테리어" style="background: #ffffff; color: #1e293b;">인테리어</option>
              </optgroup>
              <optgroup label="🎬 엔터테인먼트" style="background: #f8fafc; color: #1e293b; font-weight: 700;">
                <option value="엔터테인먼트" style="background: #ffffff; color: #1e293b;">엔터테인먼트</option>
                <option value="영화" style="background: #ffffff; color: #1e293b;">영화</option>
                <option value="드라마" style="background: #ffffff; color: #1e293b;">드라마</option>
                <option value="음악" style="background: #ffffff; color: #1e293b;">음악</option>
                <option value="예능" style="background: #ffffff; color: #1e293b;">예능</option>
              </optgroup>
              <optgroup label="🛒 쇼핑/구매" style="background: #f8fafc; color: #1e293b; font-weight: 700;">
                <option value="쇼핑" style="background: #ffffff; color: #1e293b;">쇼핑</option>
                <option value="패션" style="background: #ffffff; color: #1e293b;">패션/의류</option>
                <option value="뷰티" style="background: #ffffff; color: #1e293b;">뷰티/화장품</option>
                <option value="가전" style="background: #ffffff; color: #1e293b;">가전제품</option>
              </optgroup>
              <optgroup label="🍔 음식/요리" style="background: #f8fafc; color: #1e293b; font-weight: 700;">
                <option value="음식" style="background: #ffffff; color: #1e293b;">음식/요리</option>
                <option value="맛집" style="background: #ffffff; color: #1e293b;">맛집</option>
                <option value="카페" style="background: #ffffff; color: #1e293b;">카페/커피</option>
                <option value="레시피" style="background: #ffffff; color: #1e293b;">레시피</option>
              </optgroup>
              <optgroup label="✈️ 여행/레저" style="background: #f8fafc; color: #1e293b; font-weight: 700;">
                <option value="여행" style="background: #ffffff; color: #1e293b;">여행</option>
                <option value="국내여행" style="background: #ffffff; color: #1e293b;">국내여행</option>
                <option value="해외여행" style="background: #ffffff; color: #1e293b;">해외여행</option>
                <option value="호텔" style="background: #ffffff; color: #1e293b;">호텔/숙박</option>
              </optgroup>
              <optgroup label="🚗 자동차" style="background: #f8fafc; color: #1e293b; font-weight: 700;">
                <option value="자동차" style="background: #ffffff; color: #1e293b;">자동차</option>
                <option value="전기차" style="background: #ffffff; color: #1e293b;">전기차</option>
                <option value="중고차" style="background: #ffffff; color: #1e293b;">중고차</option>
              </optgroup>
              <optgroup label="🏠 부동산" style="background: #f8fafc; color: #1e293b; font-weight: 700;">
                <option value="부동산" style="background: #ffffff; color: #1e293b;">부동산</option>
                <option value="아파트" style="background: #ffffff; color: #1e293b;">아파트</option>
                <option value="오피스텔" style="background: #ffffff; color: #1e293b;">오피스텔</option>
                <option value="투자" style="background: #ffffff; color: #1e293b;">부동산 투자</option>
              </optgroup>
              <optgroup label="🎓 교육/학습" style="background: #f8fafc; color: #1e293b; font-weight: 700;">
                <option value="교육" style="background: #ffffff; color: #1e293b;">교육</option>
                <option value="자격증" style="background: #ffffff; color: #1e293b;">자격증</option>
                <option value="학원" style="background: #ffffff; color: #1e293b;">학원/강의</option>
                <option value="어학" style="background: #ffffff; color: #1e293b;">어학</option>
              </optgroup>
              <optgroup label="💰 금융/투자" style="background: #f8fafc; color: #1e293b; font-weight: 700;">
                <option value="금융" style="background: #ffffff; color: #1e293b;">금융</option>
                <option value="투자" style="background: #ffffff; color: #1e293b;">투자</option>
                <option value="주식" style="background: #ffffff; color: #1e293b;">주식</option>
                <option value="부동산투자" style="background: #ffffff; color: #1e293b;">부동산 투자</option>
              </optgroup>
              <optgroup label="⚽ 스포츠" style="background: #f8fafc; color: #1e293b; font-weight: 700;">
                <option value="스포츠" style="background: #ffffff; color: #1e293b;">스포츠</option>
                <option value="축구" style="background: #ffffff; color: #1e293b;">축구</option>
                <option value="야구" style="background: #ffffff; color: #1e293b;">야구</option>
                <option value="골프" style="background: #ffffff; color: #1e293b;">골프</option>
              </optgroup>
              <optgroup label="🎮 게임" style="background: #f8fafc; color: #1e293b; font-weight: 700;">
                <option value="게임" style="background: #ffffff; color: #1e293b;">게임</option>
                <option value="모바일게임" style="background: #ffffff; color: #1e293b;">모바일 게임</option>
                <option value="PC게임" style="background: #ffffff; color: #1e293b;">PC 게임</option>
                <option value="콘솔게임" style="background: #ffffff; color: #1e293b;">콘솔 게임</option>
              </optgroup>
              <optgroup label="🎨 취미/여가" style="background: #f8fafc; color: #1e293b; font-weight: 700;">
                <option value="취미" style="background: #ffffff; color: #1e293b;">취미</option>
                <option value="독서" style="background: #ffffff; color: #1e293b;">독서</option>
                <option value="영화감상" style="background: #ffffff; color: #1e293b;">영화 감상</option>
                <option value="음악감상" style="background: #ffffff; color: #1e293b;">음악 감상</option>
              </optgroup>
              <optgroup label="💼 비즈니스" style="background: #f8fafc; color: #1e293b; font-weight: 700;">
                <option value="비즈니스" style="background: #ffffff; color: #1e293b;">비즈니스</option>
                <option value="창업" style="background: #ffffff; color: #1e293b;">창업</option>
                <option value="마케팅" style="background: #ffffff; color: #1e293b;">마케팅</option>
                <option value="부업" style="background: #ffffff; color: #1e293b;">부업/사이드</option>
              </optgroup>
            </select>
          </div>
          
          <!-- 키워드 입력 및 발굴 컨트롤 -->
          <div>
            <label style="display: block; margin-bottom: 8px; font-size: 13px; font-weight: 600; color: rgba(255, 255, 255, 0.7); text-transform: uppercase; letter-spacing: 0.5px;">키워드 검색</label>
            <input 
              type="text" 
              id="keywordInput" 
              placeholder="검색할 키워드를 입력하세요 (예: 임플란트)"
              style="width: 100%; padding: 18px 24px; border: 2px solid rgba(96, 165, 250, 0.3); border-radius: 12px; font-size: 16px; background: rgba(30, 41, 59, 0.8); color: #ffffff; transition: all 0.3s ease;"
              onkeypress="if(event.key === 'Enter') startKeywordDiscovery()"
              onfocus="this.style.borderColor='#60a5fa'; this.style.boxShadow='0 0 0 4px rgba(96, 165, 250, 0.2)'; this.style.background='rgba(30, 41, 59, 1)';"
              onblur="this.style.borderColor='rgba(96, 165, 250, 0.3)'; this.style.boxShadow='none'; this.style.background='rgba(30, 41, 59, 0.8)';"
            >
          </div>
          
          <!-- 🆕 접미사/접두사 키워드 검색 -->
          <div style="margin-top: 16px; padding: 16px; background: linear-gradient(135deg, rgba(251, 191, 36, 0.1), rgba(245, 158, 11, 0.1)); border: 2px solid rgba(251, 191, 36, 0.3); border-radius: 12px;">
            <label style="display: block; margin-bottom: 8px; font-size: 13px; font-weight: 600; color: #fbbf24; text-transform: uppercase; letter-spacing: 0.5px;">
              ✨ 수식어 키워드 검색 (방법, 꿀팁 등)
            </label>
            <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: center;">
              <input 
                type="text" 
                id="suffixInput" 
                placeholder="접미사 (예: 방법, 꿀팁, 추천, 순위)"
                style="flex: 1; min-width: 200px; padding: 14px 18px; border: 2px solid rgba(251, 191, 36, 0.3); border-radius: 10px; font-size: 15px; background: rgba(30, 41, 59, 0.8); color: #ffffff; transition: all 0.3s ease;"
                onkeypress="if(event.key === 'Enter') searchSuffixKeywords()"
                onfocus="this.style.borderColor='#fbbf24'; this.style.boxShadow='0 0 0 4px rgba(251, 191, 36, 0.2)';"
                onblur="this.style.borderColor='rgba(251, 191, 36, 0.3)'; this.style.boxShadow='none';"
              >
              <button onclick="searchSuffixKeywords()" 
                style="padding: 14px 24px; background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%); color: #1e293b; border: none; border-radius: 10px; font-weight: 700; cursor: pointer; font-size: 15px; white-space: nowrap;">
                🔎 수식어 검색
              </button>
            </div>
            <p style="margin-top: 8px; font-size: 12px; color: rgba(255, 255, 255, 0.6);">
              💡 예: "방법" 입력 → 다이어트 방법, 영어공부 방법, 돈버는 방법 등 자동 수집
            </p>
          </div>
          
          <!-- 개수 제한 및 발굴 컨트롤 -->
          <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
            <label style="display: flex; align-items: center; gap: 8px; padding: 8px 16px; background: #f8fafc; border-radius: 8px; cursor: pointer;">
              <input type="radio" name="keywordLimit" value="10">
              <span style="font-size: 14px; font-weight: 600;">10개</span>
            </label>
            <label style="display: flex; align-items: center; gap: 8px; padding: 8px 16px; background: #f8fafc; border-radius: 8px; cursor: pointer;">
              <input type="radio" name="keywordLimit" value="50">
              <span style="font-size: 14px; font-weight: 600;">50개</span>
            </label>
            <label style="display: flex; align-items: center; gap: 8px; padding: 8px 16px; background: #f8fafc; border-radius: 8px; cursor: pointer;">
              <input type="radio" name="keywordLimit" value="100" checked>
              <span style="font-size: 14px; font-weight: 600;">100개</span>
            </label>
            <label style="display: flex; align-items: center; gap: 8px; padding: 8px 16px; background: #f8fafc; border-radius: 8px; cursor: pointer;">
              <input type="radio" name="keywordLimit" value="500">
              <span style="font-size: 14px; font-weight: 600;">500개</span>
            </label>
            <label style="display: flex; align-items: center; gap: 8px; padding: 8px 16px; background: #f8fafc; border-radius: 8px; cursor: pointer;">
              <input type="radio" name="keywordLimit" value="1000">
              <span style="font-size: 14px; font-weight: 600;">1000개</span>
            </label>
            <label style="display: flex; align-items: center; gap: 8px; padding: 8px 16px; background: linear-gradient(135deg, #fbbf24, #f59e0b); border-radius: 8px; cursor: pointer; border: 2px solid #f59e0b;">
              <input type="radio" name="keywordLimit" value="unlimited">
              <span style="font-size: 14px; font-weight: 700; color: #1e293b;">♾️ 무제한</span>
            </label>
            <button id="discoveryBtn" onclick="startKeywordDiscovery()" 
              style="padding: 12px 32px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; font-size: 16px;">
              🔍 키워드 조회
            </button>
            <button id="stopBtn" onclick="stopKeywordDiscovery()" 
              style="padding: 12px 32px; background: #ef4444; color: white; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; font-size: 16px; display: none;">
              ⏹️ 중지
            </button>
          </div>
        </div>
        
        <!-- 진행 상태 -->
        <div id="discoveryStatus" style="display: none; margin: 16px 0; padding: 20px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px; font-size: 14px; color: #ffffff;">
          <div style="margin-bottom: 12px;">
            <span id="statusText" style="font-weight: 600; font-size: 16px;">발굴 중...</span>
            <span id="discoveryCount" style="margin-left: 16px; font-weight: 700; font-size: 18px;">0개</span>
          </div>
          <!-- 진행률 막대 그래프 -->
          <div style="width: 100%; height: 24px; background: rgba(255, 255, 255, 0.2); border-radius: 12px; overflow: hidden; position: relative; margin-bottom: 8px;">
            <div id="progressBar" style="height: 100%; background: linear-gradient(90deg, #10b981 0%, #34d399 100%); width: 0%; transition: width 0.3s ease; border-radius: 12px; display: flex; align-items: center; justify-content: center; min-width: 0%;">
              <span id="progressPercent" style="font-weight: 700; font-size: 12px; color: white; text-shadow: 0 1px 2px rgba(0,0,0,0.3);">0%</span>
            </div>
          </div>
